<div
  class="testimonials"
  id="testimonials-{{ section.id }}"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-section-id="{{ section.id }}"
  data-min-rating="{{ section.settings.min_rating }}"
  data-max-reviews="{{ section.settings.max_reviews }}"
  data-product-handle="{{ section.settings.product_filter | escape }}"
>
  <div class="testimonials__container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="testimonials__header">
      <div class="testimonials__divider" aria-hidden="true">
        <span class="testimonials__divider-line"></span>
        <span class="testimonials__divider-diamond">✦</span>
        <span class="testimonials__divider-line"></span>
      </div>
      {%- if section.settings.title != blank -%}
        <h2 class="testimonials__title section-title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="testimonials__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- assign video_blocks = section.blocks | where: 'type', 'video' -%}

    {%- comment -%} Video cards row {%- endcomment -%}
    {%- if video_blocks.size > 0 -%}
      <div class="testimonials__videos-wrap">
        <div class="testimonials__videos">
          {%- for block in video_blocks -%}
            <div class="testimonials__video-card" {{ block.shopify_attributes }}>
              <div class="testimonials__video-thumb js-video-trigger"
                data-video-url="{{ block.settings.video.sources[0].url | default: block.settings.video_url }}"
                data-video-type="{{ block.settings.video.media_type | default: 'external' }}">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: class: 'testimonials__video-img', loading: 'lazy', alt: block.settings.alt | escape }}
                {%- elsif block.settings.video != blank -%}
                  {{ block.settings.video | image_url: width: 600 | image_tag: class: 'testimonials__video-img', loading: 'lazy', alt: block.settings.alt | escape }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'testimonials__video-img testimonials__video-img--placeholder' }}
                {%- endif -%}
                <div class="testimonials__play-btn" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                    <path d="M8 5.14v14l11-7-11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Judge.me reviews — marquee auto-scroll (populated via JS) {%- endcomment -%}
    <div class="testimonials__marquee-wrap" id="testimonials-reviews-{{ section.id }}">
      <div class="testimonials__marquee">
        <div class="testimonials__marquee-track" id="testimonials-track-1-{{ section.id }}"></div>
        <div class="testimonials__marquee-track" aria-hidden="true" id="testimonials-track-2-{{ section.id }}"></div>
      </div>
    </div>

    {%- comment -%} Loading / empty state {%- endcomment -%}
    <div class="testimonials__loading" id="testimonials-loading-{{ section.id }}">
      <p class="testimonials__loading-text">{{ 'sections.testimonials.loading' | t }}</p>
    </div>

  </div>
</div>

{%- comment -%} Video modal {%- endcomment -%}
<div class="testimonials__modal" id="testimonials-modal" aria-hidden="true">
  <div class="testimonials__modal-overlay js-modal-close"></div>
  <div class="testimonials__modal-box">
    <button class="testimonials__modal-close js-modal-close" aria-label="Close video">
      <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <div class="testimonials__modal-player" id="testimonials-player"></div>
  </div>
</div>

{% stylesheet %}
  .testimonials {
    background-color: var(--bg-color, #EFEEE9);
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 60px);
  }

  .testimonials__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 0 52px;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  /* ── Header ── */
  .testimonials__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .testimonials__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .testimonials__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .testimonials__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .testimonials__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 3rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .testimonials__subtitle {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Video cards ── */
  .testimonials__videos-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .testimonials__videos-wrap::-webkit-scrollbar { display: none; }

  .testimonials__videos {
    display: flex;
    gap: 20px;
    width: max-content;
  }

  .testimonials__video-card {
    width: 300px;
    flex-shrink: 0;
  }

  .testimonials__video-thumb {
    position: relative;
    aspect-ratio: 300 / 378;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    cursor: pointer;
  }

  .testimonials__video-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .testimonials__video-thumb:hover .testimonials__video-img {
    transform: scale(1.04);
  }

  .testimonials__video-img--placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .testimonials__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: background 0.2s ease;
  }

  .testimonials__video-thumb:hover .testimonials__play-btn {
    background: rgba(0,0,0,0.8);
  }

  /* ── Marquee reviews ── */
  .testimonials__marquee-wrap {
    overflow: hidden;
    width: 100%;
  }

  .testimonials__marquee {
    display: flex;
    width: max-content;
    animation: testimonials-marquee var(--marquee-duration, 40s) linear infinite;
  }

  .testimonials__marquee:hover {
    animation-play-state: paused;
  }

  @keyframes testimonials-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .testimonials__marquee-track {
    display: flex;
    gap: 12px;
    padding-right: 12px;
  }

  .testimonials__review-card {
    width: 322px;
    flex-shrink: 0;
    background: #f0e7db;
    border: 1px solid #efe2d1;
    border-radius: 6px;
    padding: 16px 15px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .testimonials__judgeme-icon {
    position: absolute;
    top: 12px;
    right: 12px;
  }

  .testimonials__reviewer {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .testimonials__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials__reviewer-info {
    display: flex;
    flex-direction: column;
  }

  .testimonials__reviewer-name {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: #212121;
    line-height: 1.28;
  }

  .testimonials__reviewer-date {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 12px;
    color: #737373;
    line-height: 1.2;
  }

  .testimonials__stars {
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .testimonials__review-text {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 14px;
    color: #737373;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Video modal ── */
  .testimonials__modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .testimonials__modal.is-open {
    display: flex;
  }

  .testimonials__modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    cursor: pointer;
  }

  .testimonials__modal-box {
    position: relative;
    z-index: 1;
    width: 90vw;
    max-width: 860px;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
  }

  .testimonials__modal-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    background: rgba(0,0,0,0.6);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
  }

  .testimonials__modal-player {
    aspect-ratio: 9 / 16;
    max-height: 80vh;
  }

  .testimonials__modal-player video,
  .testimonials__modal-player iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Loading state ── */
  .testimonials__loading {
    text-align: center;
    padding: 20px;
  }

  .testimonials__loading-text {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 14px;
    color: #7e6767;
    margin: 0;
  }

  .testimonials__marquee-wrap[data-loaded="true"] + .testimonials__loading {
    display: none;
  }

  .testimonials__marquee-wrap:not([data-loaded="true"]) .testimonials__marquee {
    display: none;
  }

  .testimonials__review-product {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 12px;
    color: #9e8080;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .testimonials__container {
      padding: 0 16px;
      gap: 32px;
    }

    .testimonials__title { font-size: 1.875rem; }
    .testimonials__subtitle { font-size: 0.875rem; }
    .testimonials__divider-line { width: 4rem; }

    .testimonials__video-card {
      width: calc((100vw - 2rem) / 1.5);
    }

    .testimonials__review-card {
      width: 280px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    /* ── Video modal ── */
    var modal  = document.getElementById('testimonials-modal');
    var player = document.getElementById('testimonials-player');

    function openModal(url, type) {
      if (!modal || !player) return;
      player.innerHTML = '';
      if (type === 'video' || (!url.includes('youtube') && !url.includes('youtu.be') && !url.includes('vimeo'))) {
        var vid = document.createElement('video');
        vid.src = url;
        vid.controls = true;
        vid.autoplay = true;
        vid.style.width = '100%';
        vid.style.height = '100%';
        player.appendChild(vid);
      } else {
        var src = url;
        if (url.includes('youtu.be/')) {
          src = 'https://www.youtube.com/embed/' + url.split('youtu.be/')[1].split('?')[0] + '?autoplay=1';
        } else if (url.includes('youtube.com/watch')) {
          var id = url.split('v=')[1];
          if (id) id = id.split('&')[0];
          src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
        } else if (url.includes('vimeo.com/')) {
          var vid_id = url.split('vimeo.com/')[1].split('?')[0];
          src = 'https://player.vimeo.com/video/' + vid_id + '?autoplay=1';
        }
        var iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.allow = 'autoplay; fullscreen';
        iframe.allowFullscreen = true;
        iframe.style.width = '100%';
        iframe.style.height = '100%';
        player.appendChild(iframe);
      }
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      if (player) player.innerHTML = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.js-video-trigger').forEach(function(el) {
      el.addEventListener('click', function() {
        var url  = el.dataset.videoUrl;
        var type = el.dataset.videoType;
        if (url) openModal(url, type);
      });
    });

    document.querySelectorAll('.js-modal-close').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });

    /* ── Judge.me review fetching via Shopify App Proxy (no CORS) ── */
    document.querySelectorAll('.testimonials[data-section-id]').forEach(function(section) {
      var minRating     = parseInt(section.dataset.minRating, 10) || 1;
      var maxReviews    = parseInt(section.dataset.maxReviews, 10) || 10;
      var productHandle = section.dataset.productHandle || '';
      var sectionId     = section.dataset.sectionId;

      var perPage = Math.min(maxReviews * 3, 100);
      var apiUrl = '/apps/judgeme/reviews?per_page=' + perPage;
      if (productHandle) apiUrl += '&product_handle=' + encodeURIComponent(productHandle);

      fetch(apiUrl, { headers: { 'Accept': 'application/json' } })
        .then(function(res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        })
        .then(function(data) {
          var allReviews = data.reviews || [];
          var filtered = [];

          for (var i = 0; i < allReviews.length; i++) {
            if (filtered.length >= maxReviews) break;
            var r = allReviews[i];

            /* Skip hidden or spam reviews */
            if (r.hidden || r.curated === 'spam') continue;

            /* Filter by minimum rating */
            if ((r.rating || 0) < minRating) continue;

            /* Filter by product handle if set */
            if (productHandle && r.product_handle !== productHandle) continue;

            var name = 'Anonymous';
            if (r.reviewer && r.reviewer.name) name = r.reviewer.name;

            filtered.push({
              name: name,
              date: r.created_at || '',
              rating: r.rating || 5,
              title: r.title || '',
              body: r.body || '',
              product: r.product_title || ''
            });
          }

          if (filtered.length === 0) {
            showMessage(sectionId, 'No reviews found matching the selected filters.');
            return;
          }

          renderReviews(filtered, sectionId);
        })
        .catch(function(err) {
          console.error('Testimonials: Judge.me API error', err);
          showMessage(sectionId, 'Could not load reviews. Please check your API token.');
        });

      function showMessage(secId, msg) {
        var loadingEl = document.getElementById('testimonials-loading-' + secId);
        if (loadingEl) loadingEl.querySelector('.testimonials__loading-text').textContent = msg;
      }
    });

    function renderReviews(reviews, sectionId) {
      var track1 = document.getElementById('testimonials-track-1-' + sectionId);
      var track2 = document.getElementById('testimonials-track-2-' + sectionId);
      if (!track1 || !track2) return;

      var html = '';
      reviews.forEach(function(review) {
        var name = review.name || 'Anonymous';
        var initial = name.charAt(0).toUpperCase();
        var rating = review.rating || 5;
        var dateStr = review.date;

        /* Convert ISO date to relative time */
        if (dateStr && dateStr.indexOf('T') !== -1) {
          var createdAt = new Date(dateStr);
          var now = new Date();
          var diffDays = Math.floor((now - createdAt) / (1000 * 60 * 60 * 24));
          if (diffDays === 0) dateStr = 'Today';
          else if (diffDays === 1) dateStr = '1 day ago';
          else if (diffDays < 30) dateStr = diffDays + ' days ago';
          else if (diffDays < 365) {
            var months = Math.floor(diffDays / 30);
            dateStr = months === 1 ? '1 month ago' : months + ' months ago';
          } else {
            var years = Math.floor(diffDays / 365);
            dateStr = years === 1 ? '1 year ago' : years + ' years ago';
          }
        }

        var stars = '';
        for (var i = 1; i <= 5; i++) {
          var fill = i <= rating ? '#f59e0b' : '#d1d5db';
          stars += '<svg viewBox="0 0 16 16" fill="' + fill + '" width="16" height="16" aria-hidden="true"><path d="M8 1.139l1.854 3.756 4.146.603-3 2.924.708 4.128L8 10.412l-3.708 1.138.708-4.128-3-2.924 4.146-.603z"/></svg>';
        }

        var displayText = review.title || review.body || '';
        if (displayText.length > 150) displayText = displayText.substring(0, 150) + '…';

        html += '<div class="testimonials__review-card">';
        html += '<div class="testimonials__judgeme-icon" aria-hidden="true">';
        html += '<svg width="22" height="22" viewBox="0 0 55 55" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="55" height="55" rx="10" fill="#1B1B1B"/><path d="M39.93 22.09l-7.19-4.15a5.55 5.55 0 00-5.55 0l-7.19 4.15a5.55 5.55 0 00-2.78 4.81v8.3a5.55 5.55 0 002.78 4.81l7.19 4.15a5.55 5.55 0 005.55 0l7.19-4.15a5.55 5.55 0 002.78-4.81v-8.3a5.55 5.55 0 00-2.78-4.81z" fill="#fff"/><path d="M30.55 28.5a3.05 3.05 0 11-6.1 0 3.05 3.05 0 016.1 0z" fill="#1B1B1B"/></svg>';
        html += '</div>';
        html += '<div class="testimonials__reviewer">';
        html += '<div class="testimonials__avatar">' + initial + '</div>';
        html += '<div class="testimonials__reviewer-info">';
        html += '<span class="testimonials__reviewer-name">' + escapeHtml(name) + '</span>';
        if (dateStr) html += '<span class="testimonials__reviewer-date">' + escapeHtml(dateStr) + '</span>';
        html += '</div></div>';
        html += '<div class="testimonials__stars" aria-label="' + rating + ' out of 5 stars">' + stars + '</div>';
        if (review.product) html += '<p class="testimonials__review-product">' + escapeHtml(review.product) + '</p>';
        if (displayText) html += '<p class="testimonials__review-text">"' + escapeHtml(displayText) + '"</p>';
        html += '</div>';
      });

      track1.innerHTML = html;
      track2.innerHTML = html;

      var wrap = document.getElementById('testimonials-reviews-' + sectionId);
      if (wrap) wrap.setAttribute('data-loaded', 'true');

      var duration = Math.max(20, reviews.length * 5);
      var marquee = wrap.querySelector('.testimonials__marquee');
      if (marquee) marquee.style.setProperty('--marquee-duration', duration + 's');
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "blocks": [
    {
      "type": "video",
      "name": "t:sections.testimonials.blocks.video.name",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.testimonials.blocks.video.video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "t:sections.testimonials.blocks.video.video_url",
          "info": "t:sections.testimonials.blocks.video.video_url_info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.video.thumbnail",
          "info": "t:sections.testimonials.blocks.video.thumbnail_info"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:sections.testimonials.blocks.video.alt"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.testimonials.title",
      "default": "Our Customer Testimonials"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.testimonials.subtitle",
      "default": "Trusted and praised for excellence"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.judgeme_header"
    },
    {
      "type": "range",
      "id": "min_rating",
      "label": "t:sections.testimonials.min_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "info": "t:sections.testimonials.min_rating_info"
    },
    {
      "type": "range",
      "id": "max_reviews",
      "label": "t:sections.testimonials.max_reviews",
      "min": 4,
      "max": 30,
      "step": 1,
      "default": 10,
      "info": "t:sections.testimonials.max_reviews_info"
    },
    {
      "type": "text",
      "id": "product_filter",
      "label": "t:sections.testimonials.product_filter",
      "info": "t:sections.testimonials.product_filter_info"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.spacing_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.testimonials.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.testimonials.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
