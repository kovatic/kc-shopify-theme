<div class="testimonials" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="testimonials__container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="testimonials__header">
      <div class="testimonials__divider" aria-hidden="true">
        <span class="testimonials__divider-line"></span>
        <span class="testimonials__divider-diamond">✦</span>
        <span class="testimonials__divider-line"></span>
      </div>
      {%- if section.settings.title != blank -%}
        <h2 class="testimonials__title section-title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="testimonials__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- assign video_blocks = section.blocks | where: 'type', 'video' -%}
    {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}

    {%- comment -%} Video cards row {%- endcomment -%}
    {%- if video_blocks.size > 0 -%}
      <div class="testimonials__videos-wrap">
        <div class="testimonials__videos">
          {%- for block in video_blocks -%}
            <div class="testimonials__video-card" {{ block.shopify_attributes }}>
              <div class="testimonials__video-thumb js-video-trigger"
                data-video-url="{{ block.settings.video.sources[0].url | default: block.settings.video_url }}"
                data-video-type="{{ block.settings.video.media_type | default: 'external' }}">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: class: 'testimonials__video-img', loading: 'lazy', alt: block.settings.alt | escape }}
                {%- elsif block.settings.video != blank -%}
                  {{ block.settings.video | image_url: width: 600 | image_tag: class: 'testimonials__video-img', loading: 'lazy', alt: block.settings.alt | escape }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'testimonials__video-img testimonials__video-img--placeholder' }}
                {%- endif -%}
                <div class="testimonials__play-btn" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
                    <path d="M8 5.14v14l11-7-11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Review cards — marquee auto-scroll {%- endcomment -%}
    {%- if review_blocks.size > 0 -%}
      <div class="testimonials__marquee-wrap">
        <div class="testimonials__marquee">
          {%- comment -%} Render twice for seamless loop {%- endcomment -%}
          {%- for pass in (1..2) -%}
            <div class="testimonials__marquee-track" aria-hidden="{% if pass == 2 %}true{% else %}false{% endif %}">
              {%- for block in review_blocks -%}
                {%- assign initials = block.settings.reviewer_name | split: ' ' | first | slice: 0 | upcase -%}
                <div class="testimonials__review-card" {% if pass == 1 %}{{ block.shopify_attributes }}{% endif %}>
                  <div class="testimonials__google-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
                      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                  </div>
                  <div class="testimonials__reviewer">
                    <div class="testimonials__avatar">{{ initials }}</div>
                    <div class="testimonials__reviewer-info">
                      <span class="testimonials__reviewer-name">{{ block.settings.reviewer_name | escape }}</span>
                      <span class="testimonials__reviewer-date">{{ block.settings.reviewer_date | escape }}</span>
                    </div>
                  </div>
                  <div class="testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                    {%- for i in (1..5) -%}
                      <svg viewBox="0 0 16 16" fill="{% if i <= block.settings.rating %}#f59e0b{% else %}#d1d5db{% endif %}" width="16" height="16" aria-hidden="true">
                        <path d="M8 1.139l1.854 3.756 4.146.603-3 2.924.708 4.128L8 10.412l-3.708 1.138.708-4.128-3-2.924 4.146-.603z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.review_text != blank -%}
                    <p class="testimonials__review-text">"{{ block.settings.review_text | escape }}"</p>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment -%} Video modal {%- endcomment -%}
<div class="testimonials__modal" id="testimonials-modal" aria-hidden="true">
  <div class="testimonials__modal-overlay js-modal-close"></div>
  <div class="testimonials__modal-box">
    <button class="testimonials__modal-close js-modal-close" aria-label="Close video">
      <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <div class="testimonials__modal-player" id="testimonials-player"></div>
  </div>
</div>

{% stylesheet %}
  .testimonials {
    background-color: var(--bg-color, #EFEEE9);
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 60px);
  }

  .testimonials__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 0 52px;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  /* ── Header ── */
  .testimonials__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .testimonials__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .testimonials__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .testimonials__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .testimonials__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 3rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .testimonials__subtitle {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Video cards ── */
  .testimonials__videos-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .testimonials__videos-wrap::-webkit-scrollbar { display: none; }

  .testimonials__videos {
    display: flex;
    gap: 20px;
    width: max-content;
  }

  .testimonials__video-card {
    width: 300px;
    flex-shrink: 0;
  }

  .testimonials__video-thumb {
    position: relative;
    aspect-ratio: 300 / 378;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    cursor: pointer;
  }

  .testimonials__video-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .testimonials__video-thumb:hover .testimonials__video-img {
    transform: scale(1.04);
  }

  .testimonials__video-img--placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .testimonials__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: background 0.2s ease;
  }

  .testimonials__video-thumb:hover .testimonials__play-btn {
    background: rgba(0,0,0,0.8);
  }

  /* ── Marquee reviews ── */
  .testimonials__marquee-wrap {
    overflow: hidden;
    width: 100%;
  }

  .testimonials__marquee {
    display: flex;
    width: max-content;
    animation: testimonials-marquee var(--marquee-duration, 40s) linear infinite;
  }

  .testimonials__marquee:hover {
    animation-play-state: paused;
  }

  @keyframes testimonials-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .testimonials__marquee-track {
    display: flex;
    gap: 12px;
    padding-right: 12px;
  }

  .testimonials__review-card {
    width: 322px;
    flex-shrink: 0;
    background: #f0e7db;
    border: 1px solid #efe2d1;
    border-radius: 6px;
    padding: 16px 15px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .testimonials__google-icon {
    position: absolute;
    top: 12px;
    right: 12px;
  }

  .testimonials__reviewer {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .testimonials__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials__reviewer-info {
    display: flex;
    flex-direction: column;
  }

  .testimonials__reviewer-name {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: #212121;
    line-height: 1.28;
  }

  .testimonials__reviewer-date {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 12px;
    color: #737373;
    line-height: 1.2;
  }

  .testimonials__stars {
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .testimonials__review-text {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 14px;
    color: #737373;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Video modal ── */
  .testimonials__modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .testimonials__modal.is-open {
    display: flex;
  }

  .testimonials__modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    cursor: pointer;
  }

  .testimonials__modal-box {
    position: relative;
    z-index: 1;
    width: 90vw;
    max-width: 860px;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
  }

  .testimonials__modal-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    background: rgba(0,0,0,0.6);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
  }

  .testimonials__modal-player {
    aspect-ratio: 9 / 16;
    max-height: 80vh;
  }

  .testimonials__modal-player video,
  .testimonials__modal-player iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .testimonials__container {
      padding: 0 16px;
      gap: 32px;
    }

    .testimonials__title { font-size: 1.875rem; }
    .testimonials__subtitle { font-size: 0.875rem; }
    .testimonials__divider-line { width: 4rem; }

    .testimonials__video-card {
      width: calc((100vw - 2rem) / 1.5);
    }

    .testimonials__review-card {
      width: 280px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var modal   = document.getElementById('testimonials-modal');
    var player  = document.getElementById('testimonials-player');

    function openModal(url, type) {
      if (!modal || !player) return;
      player.innerHTML = '';
      if (type === 'video' || (!url.includes('youtube') && !url.includes('youtu.be') && !url.includes('vimeo'))) {
        var vid = document.createElement('video');
        vid.src = url;
        vid.controls = true;
        vid.autoplay = true;
        vid.style.width = '100%';
        vid.style.height = '100%';
        player.appendChild(vid);
      } else {
        var src = url;
        if (url.includes('youtu.be/')) {
          src = 'https://www.youtube.com/embed/' + url.split('youtu.be/')[1].split('?')[0] + '?autoplay=1';
        } else if (url.includes('youtube.com/watch')) {
          var id = url.split('v=')[1];
          if (id) id = id.split('&')[0];
          src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
        } else if (url.includes('vimeo.com/')) {
          var vid_id = url.split('vimeo.com/')[1].split('?')[0];
          src = 'https://player.vimeo.com/video/' + vid_id + '?autoplay=1';
        }
        var iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.allow = 'autoplay; fullscreen';
        iframe.allowFullscreen = true;
        iframe.style.width = '100%';
        iframe.style.height = '100%';
        player.appendChild(iframe);
      }
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      if (player) player.innerHTML = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.js-video-trigger').forEach(function(el) {
      el.addEventListener('click', function() {
        var url  = el.dataset.videoUrl;
        var type = el.dataset.videoType;
        if (url) openModal(url, type);
      });
    });

    document.querySelectorAll('.js-modal-close').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });

    /* ── Adjust marquee speed based on number of cards ── */
    var track = document.querySelector('.testimonials__marquee-track');
    if (track) {
      var cards = track.querySelectorAll('.testimonials__review-card').length;
      var duration = Math.max(20, cards * 5);
      var marquee = document.querySelector('.testimonials__marquee');
      if (marquee) marquee.style.setProperty('--marquee-duration', duration + 's');
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonials",
  "blocks": [
    {
      "type": "video",
      "name": "Video testimonial",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Or paste video URL (YouTube / Vimeo)",
          "info": "Used if no video is uploaded above"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom thumbnail image",
          "info": "Optional — overrides auto-generated thumbnail"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text"
        }
      ]
    },
    {
      "type": "review",
      "name": "Google review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "reviewer_date",
          "label": "Date",
          "default": "4 days ago"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "The silk sarees from Chinnadurai are absolutely stunning. The quality is unmatched."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Customer Testimonials"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Trusted and praised for excellence"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
