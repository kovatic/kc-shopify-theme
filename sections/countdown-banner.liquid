{%- assign end_date = section.settings.end_date | default: '' -%}

<div
  class="countdown-banner full-width"
  id="countdown-banner-{{ section.id }}"
  data-end-date="{{ end_date }}"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="countdown-banner__container">
    {%- if section.settings.heading != blank -%}
      <p class="countdown-banner__heading">{{ section.settings.heading | escape }}</p>
    {%- endif -%}

    <div class="countdown-banner__timer" id="countdown-timer-{{ section.id }}" aria-live="polite">
      <div class="countdown-banner__unit">
        <span class="countdown-banner__value" data-unit="days">00</span>
        <span class="countdown-banner__label">{{ 'sections.countdown_banner.days' | t }}</span>
      </div>
      <span class="countdown-banner__separator">:</span>
      <div class="countdown-banner__unit">
        <span class="countdown-banner__value" data-unit="hours">00</span>
        <span class="countdown-banner__label">{{ 'sections.countdown_banner.hours' | t }}</span>
      </div>
      <span class="countdown-banner__separator">:</span>
      <div class="countdown-banner__unit">
        <span class="countdown-banner__value" data-unit="minutes">00</span>
        <span class="countdown-banner__label">{{ 'sections.countdown_banner.minutes' | t }}</span>
      </div>
      <span class="countdown-banner__separator">:</span>
      <div class="countdown-banner__unit">
        <span class="countdown-banner__value" data-unit="seconds">00</span>
        <span class="countdown-banner__label">{{ 'sections.countdown_banner.seconds' | t }}</span>
      </div>
    </div>

    <p class="countdown-banner__expired" id="countdown-expired-{{ section.id }}" hidden>
      {{ 'sections.countdown_banner.expired' | t }}
    </p>
  </div>
</div>

{% stylesheet %}
  .countdown-banner {
    width: 100%;
    padding-top: var(--padding-top, 20px);
    padding-bottom: var(--padding-bottom, 20px);
    background: linear-gradient(90deg, #7a0e21 0%, #b3122c 50%, #7a0e21 100%);
    border-top: 2px solid #ffd75e;
    border-bottom: 2px solid #ffd75e;
  }

  .countdown-banner__container {
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .countdown-banner__heading {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    text-align: center;
  }

  .countdown-banner__timer {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .countdown-banner__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 52px;
  }

  .countdown-banner__value {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.75rem;
    font-weight: 800;
    color: #ffd75e;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .countdown-banner__label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    color: #ffe9f1;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
  }

  .countdown-banner__separator {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffd75e;
    line-height: 1;
    padding-bottom: 14px;
  }

  .countdown-banner__expired {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffd75e;
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 768px) {
    .countdown-banner__container {
      gap: 14px;
    }

    .countdown-banner__heading {
      font-size: 1rem;
      width: 100%;
    }

    .countdown-banner__value {
      font-size: 1.4rem;
    }

    .countdown-banner__unit {
      min-width: 42px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function initCountdown(root) {
      var endDateStr = root.dataset.endDate;
      if (!endDateStr) return;

      var endDate = new Date(endDateStr).getTime();
      if (isNaN(endDate)) return;

      var id = root.id.replace('countdown-banner-', '');
      var timerEl = document.getElementById('countdown-timer-' + id);
      var expiredEl = document.getElementById('countdown-expired-' + id);
      var daysEl = root.querySelector('[data-unit="days"]');
      var hoursEl = root.querySelector('[data-unit="hours"]');
      var minutesEl = root.querySelector('[data-unit="minutes"]');
      var secondsEl = root.querySelector('[data-unit="seconds"]');

      function pad(num) {
        return String(num).padStart(2, '0');
      }

      function tick() {
        var now = Date.now();
        var diff = endDate - now;

        if (diff <= 0) {
          if (timerEl) timerEl.hidden = true;
          if (expiredEl) expiredEl.hidden = false;
          clearInterval(interval);
          return;
        }

        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        var minutes = Math.floor((diff / (1000 * 60)) % 60);
        var seconds = Math.floor((diff / 1000) % 60);

        if (daysEl) daysEl.textContent = pad(days);
        if (hoursEl) hoursEl.textContent = pad(hours);
        if (minutesEl) minutesEl.textContent = pad(minutes);
        if (secondsEl) secondsEl.textContent = pad(seconds);
      }

      tick();
      var interval = setInterval(tick, 1000);
    }

    document.querySelectorAll('.countdown-banner').forEach(initCountdown);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.countdown_banner.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.title",
      "default": "Hurry! Aadi Offer ends in:"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "t:sections.countdown_banner.end_date",
      "info": "t:sections.countdown_banner.end_date_info",
      "default": "2026-07-31T23:59:59"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:sections.countdown_banner.name"
    }
  ]
}
{% endschema %}
