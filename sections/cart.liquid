{% comment %}
  Cart page — styled to match the site theme (warm beige + dark maroon palette).
  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<div class="cart-page">
  <div class="cart-page__container">

    <div class="cart-page__header">
      <div class="cart-page__divider" aria-hidden="true">
        <span class="cart-page__divider-line"></span>
        <span class="cart-page__divider-diamond">✦</span>
        <span class="cart-page__divider-line"></span>
      </div>
      <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="cart-page__empty">
        <p class="cart-page__empty-text">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-btn">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>

    {%- else -%}
      <div class="cart-page__layout">

        {%- comment -%} ── Left: item list ── {%- endcomment -%}
        <div class="cart-page__form" id="cart-form">
          <div class="cart-page__items" id="cart-items">
            {%- for item in cart.items -%}
              {%- comment -%} Skip addon line items — rendered as sub-rows under their parent {%- endcomment -%}
              {%- assign is_addon_item = false -%}
              {%- for property in item.properties -%}
                {%- if property.first == '_linked_item' -%}
                  {%- assign is_addon_item = true -%}
                {%- endif -%}
              {%- endfor -%}
              {%- unless is_addon_item -%}

              {%- comment -%} Find paired addon by unique cart line key {%- endcomment -%}
              {%- assign paired_addon_item = nil -%}
              {%- for other in cart.items -%}
                {%- for prop in other.properties -%}
                  {%- if prop.first == '_linked_item' -%}
                    {%- if prop.last == item.key -%}
                      {%- assign paired_addon_item = other -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}

              <div class="cart-item" data-key="{{ item.key }}"{% if paired_addon_item %} data-addon-key="{{ paired_addon_item.key }}"{% endif %}>

                {%- comment -%} Product image {%- endcomment -%}
                <a href="{{ item.url }}" class="cart-item__image-link">
                  <div class="cart-item__image-wrap">
                    {%- if item.image -%}
                      {{ item.image | image_url: width: 300, height: 350, crop: 'center' | image_tag: class: 'cart-item__image', loading: 'lazy', alt: item.product.title | escape }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'cart-item__image cart-item__image--placeholder' }}
                    {%- endif -%}
                  </div>
                </a>

                {%- comment -%} Item details {%- endcomment -%}
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title | escape }}</a>

                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title | escape }}</p>
                  {%- endunless -%}

                  {%- assign has_tailoring_props = false -%}
                  {%- for property in item.properties -%}
                    {%- assign prop_key_first_char = property.first | slice: 0 -%}
                    {%- unless property.first == 'Tailoring Extras' -%}
                      {%- unless prop_key_first_char == '_' -%}
                        {%- unless property.last == blank -%}
                          {%- assign has_tailoring_props = true -%}
                        {%- endunless -%}
                      {%- endunless -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  {%- if has_tailoring_props -%}
                    <ul class="cart-item__tailoring-props">
                      {%- for property in item.properties -%}
                        {%- assign prop_key_first_char = property.first | slice: 0 -%}
                        {%- unless property.first == 'Tailoring Extras' -%}
                          {%- unless prop_key_first_char == '_' -%}
                            {%- unless property.last == blank -%}
                              <li><span class="cart-item__prop-key">{{ property.first }}:</span> {{ property.last }}</li>
                            {%- endunless -%}
                          {%- endunless -%}
                        {%- endunless -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  <p class="cart-item__price" data-line-price>{{ item.final_line_price | money }}</p>
                  {%- if item.original_line_price != item.final_line_price -%}
                    <p class="cart-item__original-price">{{ item.original_line_price | money }}</p>
                  {%- endif -%}

                  {%- if paired_addon_item -%}
                    <div class="cart-item__addon-row">
                      <span class="cart-item__addon-label">{{ paired_addon_item.product.title | escape }}</span>
                      <span class="cart-item__addon-price">{{ paired_addon_item.final_line_price | money }}</span>
                    </div>
                  {%- endif -%}

                  <div class="cart-item__qty-row">
                    <div class="cart-item__qty">
                      <button type="button" class="cart-item__qty-btn js-qty-minus" aria-label="Decrease quantity">−</button>
                      <span class="cart-item__qty-input" aria-label="{{ 'cart.update' | t }}">{{ item.quantity }}</span>
                      <button type="button" class="cart-item__qty-btn js-qty-plus" aria-label="Increase quantity">+</button>
                    </div>

                    <button type="button" class="cart-item__remove js-remove" aria-label="{{ 'cart.remove' | t }}">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        <line x1="10" y1="11" x2="10" y2="17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <line x1="14" y1="11" x2="14" y2="17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <path d="M9 6V4h6v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ 'cart.remove' | t }}
                    </button>
                  </div>
                </div>

              </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} ── Right: order summary ── {%- endcomment -%}
        <div class="cart-page__summary">
          <h2 class="cart-page__summary-title">{{ 'cart.subtotal' | t }}</h2>

          <div class="cart-page__summary-row">
            <span>{{ 'cart.subtotal' | t }}</span>
            <span id="cart-subtotal">{{ cart.total_price | money }}</span>
          </div>

          <p class="cart-page__taxes-note">{{ 'cart.taxes_note' | t }}</p>

          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="cart-page__checkout-btn">
              {{ 'cart.checkout' | t }}
            </button>
          </form>

          <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-link">
            {{ 'cart.continue_shopping' | t }}
          </a>
        </div>

      </div>
    {%- endif -%}

  </div>
</div>

<span id="cart-money-format" data-format="{{ shop.money_format | escape }}" hidden></span>

{% stylesheet %}

  /* ── Page wrapper ── */
  .cart-page {
    background-color: var(--bg-color, #EFEEE9);
    padding: 60px 80px;
    min-height: 60vh;
  }

  .cart-page__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 50px 50px;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Header ── */
  .cart-page__header {
    text-align: center;
    width: 100%;
  }

  .cart-page__divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .cart-page__divider-line {
    flex: 1;
    height: 1px;
    background-color: #c9b8a8;
  }

  .cart-page__divider-diamond {
    font-size: 0.75rem;
    color: #2e1f1f;
  }

  .cart-page__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 2rem !important;
    font-weight: 600 !important;
    color: #2e1f1f;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Empty state ── */
  .cart-page__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 0;
    text-align: center;
  }

  .cart-page__empty-text {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem !important;
    color: #7e6767;
  }

  .cart-page__continue-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .cart-page__continue-btn:hover {
    background: #4a2f2f;
  }

  /* ── Two-column layout ── */
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Form / items list ── */
  .cart-page__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid #c9b8a8;
  }

  /* ── Single cart item ── */
  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid #c9b8a8;
  }

  .cart-item__image-link {
    display: block;
    flex-shrink: 0;
  }

  .cart-item__image-wrap {
    width: 120px;
    aspect-ratio: 3 / 3.5;
    overflow: hidden;
    background-color: #e8ddd4;
  }

  .cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .cart-item__image-link:hover .cart-item__image {
    transform: scale(1.04);
  }

  .cart-item__image--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Item details ── */
  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    justify-content: flex-start;
  }

  .cart-item__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    line-height: 1.4;
  }

  .cart-item__title:hover {
    color: #2e1f1f;
  }

  .cart-item__variant {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem !important;
    color: #7e6767;
    margin: 0;
  }

  .cart-item__price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem !important;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cart-item__addon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 10px;
    background: #f5f0eb;
    border-left: 2px solid #ce0570;
    border-radius: 0 3px 3px 0;
    margin: 4px 0;
  }

  .cart-item__addon-label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: #555;
  }

  .cart-item__addon-price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: #ce0570;
    white-space: nowrap;
  }

  .cart-item__tailoring-props {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cart-item__tailoring-props li {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    color: #888;
    line-height: 1.4;
  }

  .cart-item__prop-key {
    font-weight: 600;
    color: #555;
  }

  .cart-item__original-price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem !important;
    color: #7e6767;
    text-decoration: line-through;
    margin: 0;
  }

  /* ── Qty + remove row ── */
  .cart-item__qty-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    border: 1px solid #c9b8a8;
    background: #fff;
  }

  .cart-item__qty-btn {
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: #2e1f1f;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }

  .cart-item__qty-btn:hover {
    background: #f0e7db;
  }

  .cart-item__qty-input {
    width: 2.5rem;
    height: 2rem;
    border: none;
    border-left: 1px solid #c9b8a8;
    border-right: 1px solid #c9b8a8;
    text-align: center;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: #1a1a1a;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    user-select: none;
  }

  .cart-item__remove {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: #7e6767;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.15s ease;
  }

  .cart-item__remove:hover {
    color: #2e1f1f;
  }

  /* ── Loading state on cart items ── */
  .cart-item.is-loading {
    opacity: 0.45;
    pointer-events: none;
  }

  /* ── Order summary panel ── */
  .cart-page__summary {
    background: #fff;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 2px solid #2e1f1f;
  }

  .cart-page__summary-title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: #2e1f1f;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  .cart-page__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    color: #1a1a1a;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #c9b8a8;
  }

  .cart-page__taxes-note {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem !important;
    color: #7e6767;
    margin: 0;
  }

  .cart-page__checkout-btn {
    display: block;
    width: 100%;
    padding: 0.85rem 1rem;
    background: #2e1f1f;
    color: #fff;
    border: none;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease;
    text-align: center;
    border-radius: 0;
  }

  .cart-page__checkout-btn:hover {
    background: #4a2f2f;
  }

  .cart-page__continue-link {
    display: block;
    text-align: center;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: #7e6767;
    letter-spacing: 0.04em;
    text-decoration: underline;
    text-transform: uppercase;
    transition: color 0.15s ease;
  }

  .cart-page__continue-link:hover {
    color: #2e1f1f;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .cart-page {
      padding: 20px 0 40px;
    }

    .cart-page__container {
      padding: 0;
      gap: 1rem;
    }

    .cart-page__header {
      padding: 0 16px;
    }

    .cart-page__title {
      font-size: 1.4rem !important;
    }

    .cart-page__layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .cart-page__form {
      padding: 0 16px;
    }

    .cart-item {
      grid-template-columns: 90px 1fr;
      gap: 1rem;
      padding: 1rem 0;
    }

    .cart-item__image-wrap {
      width: 90px;
    }

    .cart-page__summary {
      margin: 1.5rem 16px 0;
    }

  }

{% endstylesheet %}

{% javascript %}
  (function () {
    var moneyFormat = (document.getElementById('cart-money-format') || {}).dataset.format || '{{amount}}';

    function formatMoney(cents) {
      var value = cents / 100;
      var amount = value.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      var amountNoDecimals = Math.floor(value).toLocaleString('en-IN');
      var amountWithComma = amount.replace('.', ',');
      var amountNoDecimalsWithComma = amountNoDecimals.replace('.', ',');
      return moneyFormat
        .replace('{{amount}}', amount)
        .replace('{{amount_no_decimals}}', amountNoDecimals)
        .replace('{{amount_with_comma_separator}}', amountWithComma)
        .replace('{{amount_no_decimals_with_comma_separator}}', amountNoDecimalsWithComma);
    }

    function updateItems(updates) {
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates: updates })
      }).then(function (r) { return r.json(); });
    }

    function removeOrphanedAddons(cart) {
      var allKeys = {};
      cart.items.forEach(function(i) { allKeys[i.key] = true; });
      var orphans = {};
      cart.items.forEach(function(item) {
        var linked = (item.properties || {})['_linked_item'];
        if (linked && !allKeys[linked]) orphans[item.key] = 0;
      });
      if (!Object.keys(orphans).length) return Promise.resolve(cart);
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates: orphans })
      }).then(function(r) { return r.json(); });
    }

    function updateCart(key, quantity) {
      var itemEl = document.querySelector('.cart-item[data-key="' + key + '"]');
      if (itemEl) itemEl.classList.add('is-loading');

      var updates = {};
      updates[key] = quantity;

      /* Also zero out the addon if removing the parent */
      var addonKey = itemEl && itemEl.dataset.addonKey;
      if (quantity === 0 && addonKey) updates[addonKey] = 0;

      updateItems(updates)
        .then(function(cart) { return removeOrphanedAddons(cart); })
        .then(function (cart) {
          var subtotalEl = document.getElementById('cart-subtotal');
          if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price);

          if (quantity === 0) {
            if (itemEl) itemEl.remove();
            if (cart.item_count === 0) { location.reload(); return; }
          } else {
            if (itemEl) {
              var qtyEl = itemEl.querySelector('.cart-item__qty-input');
              if (qtyEl) qtyEl.textContent = quantity;

              var updatedItem = cart.items.find(function (i) { return i.key === key; });
              if (updatedItem) {
                var priceEl = itemEl.querySelector('[data-line-price]');
                if (priceEl) priceEl.textContent = formatMoney(updatedItem.final_line_price);
              }
              itemEl.classList.remove('is-loading');
            }
          }

          document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
        })
        .catch(function () {
          if (itemEl) itemEl.classList.remove('is-loading');
        });
    }

    document.addEventListener('click', function (e) {
      var item = e.target.closest('.cart-item');
      if (!item) return;
      var key = item.dataset.key;

      if (e.target.closest('.js-remove')) {
        updateCart(key, 0);
        return;
      }

      var qtyEl = item.querySelector('.cart-item__qty-input');
      var current = parseInt(qtyEl ? qtyEl.textContent : '1', 10) || 1;

      if (e.target.closest('.js-qty-minus')) {
        updateCart(key, Math.max(0, current - 1));
      } else if (e.target.closest('.js-qty-plus')) {
        updateCart(key, current + 1);
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
