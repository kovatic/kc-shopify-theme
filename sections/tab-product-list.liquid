<div
  class="tab-product-list"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="tab-product-list__container">

    {% comment %} Section heading {% endcomment %}
    <div class="tab-product-list__header">
      <div class="tab-product-list__divider" aria-hidden="true">
        <span class="tab-product-list__divider-line"></span>
        <span class="tab-product-list__divider-diamond">✦</span>
        <span class="tab-product-list__divider-line"></span>
      </div>
      {% if section.settings.title != blank %}
        <h2 class="tab-product-list__title section-title">{{ section.settings.title | escape }}</h2>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      {% comment %} Tab bar {% endcomment %}
      <div class="tab-product-list__tabs" role="tablist">
        {% for block in section.blocks %}
          <button
            class="tab-product-list__tab{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="tab-panel-{{ section.id }}-{{ forloop.index0 }}"
            data-tab-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label | default: block.settings.collection.title | escape }}
          </button>
        {% endfor %}
      </div>
      <div class="tab-product-list__tab-indicator-track">
        <div class="tab-product-list__tab-indicator"></div>
      </div>

      {% comment %} Tab panels {% endcomment %}
      {% for block in section.blocks %}
        <div
          class="tab-product-list__panel{% if forloop.first %} is-active{% endif %}"
          id="tab-panel-{{ section.id }}-{{ forloop.index0 }}"
          role="tabpanel"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
        >
          {%- assign col = block.settings.collection -%}
          {%- assign product_limit = section.settings.products_per_tab -%}

          {% if col != blank and col.products.size > 0 %}
            <ul class="tab-product-list__grid">
              {% for product in col.products limit: product_limit %}
                {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
                {%- assign is_available = product.available -%}
                <li class="tab-product-list__item{% unless is_available %} is-sold-out{% endunless %}" data-variant-id="{{ first_variant.id }}" data-available="{{ is_available }}" style="position: relative;">
                  <a href="{{ product.url }}" class="tab-product-list__card">
                    <div class="tab-product-list__img-wrap">
                      {% if product.featured_image %}
                        {%- assign img_alt = product.title | escape -%}
                        {{ product.featured_image | image_url: width: 600 | image_tag: class: 'tab-product-list__img', alt: img_alt, loading: 'lazy' }}
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'tab-product-list__img tab-product-list__img--placeholder' }}
                      {% endif %}

                      <div class="product-card-mobile-bar">
                        {%- if is_available -%}
                          <button type="button" class="product-card-mobile-bar__cart js-mobile-atc" aria-label="Add to cart">
                            {{- 'sections.product_list.add_to_cart' | t | upcase -}}
                          </button>
                        {%- else -%}
                          <button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>
                            OUT OF STOCK
                          </button>
                        {%- endif -%}
                        <button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="20">
                            <rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                          </svg>
                        </button>
                      </div>
                    </div>
                    <div class="tab-product-list__info">
                      <p class="tab-product-list__name">{{ product.title | escape }}</p>
                      <p class="tab-product-list__price">{{ product.price | money }}</p>
                    </div>
                  </a>

                  <xb-wishlist-button-collection xb-handle="{{ product.handle }}" xb-parent-class="tab-product-list__item"></xb-wishlist-button-collection>

                  <div class="product-card-actions">
                    <div class="product-card-actions__cart-wrap">
                      {%- if is_available -%}
                        <form method="post" action="/cart/add" class="product-card-atc-form">
                          <input type="hidden" name="id" value="{{ first_variant.id }}">
                          <input type="hidden" name="quantity" value="1">
                          <button type="submit" name="add" class="product-card-actions__btn product-card-actions__btn--cart" aria-label="Add to cart">
                            <svg class="icon-cart" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                              <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <svg class="icon-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <svg class="icon-spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/>
                            </svg>
                          </button>
                        </form>
                        <span class="product-card-tooltip">Add to cart</span>
                      {%- else -%}
                        <span class="product-card-oos-label">Out of stock</span>
                      {%- endif -%}
                    </div>
                    <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                      </svg>
                    </button>
                  </div>

                  {%- if is_available -%}
                    <form method="post" action="/cart/add" class="product-card-atc-form product-card-atc-form--mobile" style="display:none">
                      <input type="hidden" name="id" value="{{ first_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" name="add" class="product-card-atc-form--mobile-submit"></button>
                    </form>
                  {%- endif -%}
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <p class="tab-product-list__empty">{{ 'sections.tab_product_list.no_products' | t }}</p>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}

  </div>
</div>

{% stylesheet %}
  .tab-product-list {
    width: 100%;
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 80px);
  }
  .tab-product-list__container {
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    padding: 0 50px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tab-product-list__header {
    text-align: center;
    width: 100%;
    margin-bottom: 2rem;
  }

  .tab-product-list__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .tab-product-list__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .tab-product-list__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .tab-product-list__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 3rem;
    font-weight: 700;
    color: #2e1f1f;
    margin-bottom: 1rem;
    line-height: 1;
  }

  /* ── Tabs ── */
  .tab-product-list__tabs {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 0;
  }
  .tab-product-list__tab {
    background: none;
    border: none;
    padding: 0 0 14px;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    color: #000;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s ease;
    line-height: 1.5;
  }
  .tab-product-list__tab.is-active {
    font-weight: 500;
    color: #ce0570;
  }
  .tab-product-list__tab:hover {
    color: #ce0570;
  }
  .tab-product-list__tab-indicator-track {
    width: 100%;
    height: 2px;
    background: #d9d9d9;
    position: relative;
  }
  .tab-product-list__tab-indicator {
    position: absolute;
    left: 0;
    top: 0;
    height: 2px;
    background: #ce0570;
    transition: left 0.25s ease, width 0.25s ease;
  }

  /* ── Panels ── */
  .tab-product-list__panel {
    display: none;
    margin-top: 32px;
  }
  .tab-product-list__panel.is-active {
    display: block;
  }

  /* ── Product grid ── */
  .tab-product-list__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 0.75rem;
    row-gap: 2rem;
  }
  .tab-product-list__item {
    display: flex;
    flex-direction: column;
  }
  .tab-product-list__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ── Product image ── */
  .tab-product-list__img-wrap {
    position: relative;
    aspect-ratio: 3 / 5;
    overflow: hidden;
    background-color: #e8e0d5;
  }
  .tab-product-list__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tab-product-list__img-wrap:hover .tab-product-list__img {
    transform: scale(1.04);
  }
  .tab-product-list__img--placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }


  .product-card-atc-form {
    display: contents;
  }


  /* ── Bottom row — add to cart + view similar ── */
  .product-card-actions {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    gap: 8px;
    pointer-events: none;
    z-index: 1;
  }

  .product-card-actions__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.875rem;
    height: 2.875rem;
    border-radius: 50%;
    background: #fff;
    border: none;
    cursor: pointer;
    color: #2e1f1f;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease, color 0.15s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.12);
  }

  .product-card-actions__btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .product-card-actions__btn--cart    { transition-delay: 0.06s; }
  .product-card-actions__btn--similar { transition-delay: 0s; }

  .tab-product-list__card:hover .product-card-actions__btn {
    opacity: 1;
    transform: translateY(0);
  }

  /* Spinner animation */
  @keyframes product-card-spin {
    to { transform: rotate(360deg); }
  }

  /* Icon swap: cart → check → spinner */
  .product-card-actions__btn--cart .icon-check  { display: none; }
  .product-card-actions__btn--cart .icon-spinner { display: none; }

  .product-card-actions__btn--cart.is-added { background: #e50e7e; color: #fff; }
  .product-card-actions__btn--cart.is-added .icon-cart  { display: none; }
  .product-card-actions__btn--cart.is-added .icon-check { display: block; }

  .product-card-actions__btn--cart.is-loading { background: #e50e7e; color: #fff; pointer-events: none; }
  .product-card-actions__btn--cart.is-loading .icon-cart    { display: none; }
  .product-card-actions__btn--cart.is-loading .icon-check   { display: none; }
  .product-card-actions__btn--cart.is-loading .icon-spinner {
    display: block;
    animation: product-card-spin 0.7s linear infinite;
  }


  /* Cart button wrapper + tooltip */
  .product-card-actions__cart-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 4px 8px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .product-card-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: #2e1f1f;
  }

  .product-card-actions__cart-wrap:hover .product-card-tooltip { opacity: 1; }

  /* Out of stock label */
  .product-card-oos-label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(0,0,0,0.45);
    padding: 4px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* Mobile action bar — hidden on desktop */
  .product-card-mobile-bar {
    display: none;
  }

  .product-card-mobile-bar__cart.is-added {
    background: #2e1f1f;
    color: #fff;
  }

  .product-card-mobile-bar__cart--soldout {
    background: #fff;
    color: #aaa;
    cursor: not-allowed;
    font-style: italic;
  }

  .product-card-actions__btn:hover { background: #e50e7e; color: #fff; }

  /* ── Product info ── */
  .tab-product-list__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem 0 0;
  }
  .tab-product-list__name {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-foreground, #262626);
    margin: 0;
    line-height: 1.4;
  }
  .tab-product-list__price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.375rem !important;
    font-weight: 700;
    color: var(--color-foreground, #262626);
    margin: 0;
    line-height: 1.2;
  }
  .tab-product-list__empty {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem;
    color: #888;
    margin: 0;
    padding: 40px 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .tab-product-list {
      overflow-x: hidden;
    }
    .tab-product-list__container {
      padding: 0 16px;
    }
    .tab-product-list__title {
      font-size: 1.875rem;
      font-weight: 600;
    }

    .tab-product-list__divider-line {
      width: 4rem;
    }
    .tab-product-list__tabs {
      gap: 16px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }
    .tab-product-list__tabs::-webkit-scrollbar {
      display: none;
    }
    .tab-product-list__tab {
      font-size: 0.875rem;
      flex-shrink: 0;
    }
    .tab-product-list__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 0.5rem;
      row-gap: 1.5rem;
      margin: 0 -16px;
    }

    .tab-product-list__img-wrap {
      aspect-ratio: 3 / 5;
    }
    .tab-product-list__name {
      font-size: 0.875rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .tab-product-list__price {
      font-size: 1.125rem !important;
    }
    .tab-product-list__info {
      gap: 0.25rem;
      padding: 0.5rem 0.75rem 0;
    }
    .tab-product-list__wishlist {
      width: 2rem;
      height: 2rem;
      bottom: 0.75rem;
      right: 0.5rem;
    }

    /* Hide hover overlay actions on mobile */
    .product-card-actions {
      display: none;
    }

    /* Mobile action bar — overlaid at bottom of image */
    .product-card-mobile-bar {
      display: flex;
      align-items: stretch;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
    }

    .product-card-mobile-bar__cart {
      flex: 1;
      padding: 0.6rem 0.5rem;
      background: rgba(255,255,255,0.92);
      border: none;
      border-right: 1px solid #e8e0d5;
      font-family: var(--font-body-family, 'Montserrat', sans-serif);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #2e1f1f;
      cursor: pointer;
      text-align: center;
      backdrop-filter: blur(4px);
    }

    .product-card-mobile-bar__similar {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.75rem;
      flex-shrink: 0;
      background: rgba(255,255,255,0.92);
      border: none;
      color: #2e1f1f;
      cursor: pointer;
      backdrop-filter: blur(4px);
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    function initTabList(section) {
      var tabsContainer = section.querySelector('.tab-product-list__tabs');
      var tabs = section.querySelectorAll('.tab-product-list__tab');
      var panels = section.querySelectorAll('.tab-product-list__panel');
      var indicator = section.querySelector('.tab-product-list__tab-indicator');

      if (!tabs.length || !indicator) return;

      function positionIndicator(tab) {
        var containerLeft = tabsContainer.getBoundingClientRect().left;
        var tabLeft = tab.getBoundingClientRect().left;
        indicator.style.left = (tabLeft - containerLeft) + 'px';
        indicator.style.width = tab.offsetWidth + 'px';
      }

      function activateTab(index) {
        tabs.forEach(function(t, i) {
          t.classList.toggle('is-active', i === index);
          t.setAttribute('aria-selected', i === index ? 'true' : 'false');
        });
        panels.forEach(function(p, i) {
          p.classList.toggle('is-active', i === index);
          p.setAttribute('aria-hidden', i === index ? 'false' : 'true');
        });
        positionIndicator(tabs[index]);
      }

      tabs.forEach(function(tab, i) {
        tab.addEventListener('click', function() { activateTab(i); });
      });

      // Wait for layout before setting initial indicator position
      requestAnimationFrame(function() {
        positionIndicator(tabs[0]);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.tab-product-list').forEach(initTabList);
      });
    } else {
      document.querySelectorAll('.tab-product-list').forEach(initTabList);
    }

    var tabCartVariantIds = [];

    function syncTabCartState() {
      fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          tabCartVariantIds = cart.items.map(function(i) { return String(i.variant_id); });
          document.querySelectorAll('.tab-product-list__item[data-variant-id]').forEach(applyTabCardState);
        });
    }

    function applyTabCardState(card) {
      var variantId = card.dataset.variantId;
      var available = card.dataset.available === 'true';
      var inCart = tabCartVariantIds.indexOf(variantId) !== -1;

      var iconBtn = card.querySelector('.product-card-actions__btn--cart');
      var tooltip = card.querySelector('.js-cart-tooltip');
      var mobileBtn = card.querySelector('.product-card-mobile-bar__cart');

      if (!available) {
        if (mobileBtn) {
          mobileBtn.disabled = true;
          mobileBtn.textContent = 'OUT OF STOCK';
          mobileBtn.classList.add('product-card-mobile-bar__cart--soldout');
          mobileBtn.classList.remove('is-added');
        }
        return;
      }

      if (inCart) {
        if (iconBtn) { iconBtn.classList.add('is-added'); iconBtn.disabled = false; }
        if (tooltip) tooltip.textContent = 'Remove from cart';
        if (mobileBtn) {
          mobileBtn.textContent = 'ADDED TO CART';
          mobileBtn.classList.add('is-added');
          mobileBtn.classList.remove('product-card-mobile-bar__cart--soldout');
          mobileBtn.disabled = false;
        }
      } else {
        if (iconBtn) { iconBtn.classList.remove('is-added'); iconBtn.disabled = false; }
        if (tooltip) tooltip.textContent = 'Add to cart';
        if (mobileBtn) {
          mobileBtn.textContent = 'ADD TO CART';
          mobileBtn.classList.remove('is-added', 'product-card-mobile-bar__cart--soldout');
          mobileBtn.disabled = false;
        }
      }
    }

    function addToTabCart(variantId, btn) {
      btn.disabled = true;
      var drawer = document.querySelector('cart-drawer');
      var formData = new FormData();
      formData.append('id', variantId);
      formData.append('quantity', 1);
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: formData
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.id) {
          tabCartVariantIds.push(String(variantId));
          var card = document.querySelector('.tab-product-list__item[data-variant-id="' + variantId + '"]');
          if (card) applyTabCardState(card);
          return fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
            if (drawer) { drawer.renderCart(cart); drawer.open(); }
            document.dispatchEvent(new CustomEvent('cart:refresh'));
          });
        }
        btn.disabled = false;
      })
      .catch(function() { btn.disabled = false; })
      .finally(function() { btn.disabled = false; });
    }

    function removeFromTabCart(variantId, btn) {
      btn.disabled = true;
      var drawer = document.querySelector('cart-drawer');
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 0 })
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var idx = tabCartVariantIds.indexOf(String(variantId));
        if (idx !== -1) tabCartVariantIds.splice(idx, 1);
        var card = document.querySelector('.tab-product-list__item[data-variant-id="' + variantId + '"]');
        if (card) applyTabCardState(card);
        if (drawer) drawer.renderCart(cart);
        document.dispatchEvent(new CustomEvent('cart:refresh'));
      })
      .catch(function() { btn.disabled = false; });
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.tab-product-list .js-cart-toggle');
      if (!btn) return;
      e.preventDefault();
      var card = btn.closest('[data-variant-id]');
      if (!card || card.dataset.available === 'false') return;
      var variantId = card.dataset.variantId;
      var inCart = tabCartVariantIds.indexOf(variantId) !== -1;
      if (inCart) {
        removeFromTabCart(variantId, btn);
      } else {
        addToTabCart(variantId, btn);
      }
    });

    document.addEventListener('cart:refresh', syncTabCartState);

    // Mobile ATC button — submits the hidden form outside the <a>
    document.querySelectorAll('.tab-product-list__item').forEach(function(card) {
      var mobileAtcBtn = card.querySelector('.js-mobile-atc');
      if (!mobileAtcBtn) return;
      mobileAtcBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var hiddenForm = card.querySelector('.product-card-atc-form--mobile');
        if (hiddenForm) hiddenForm.querySelector('[type="submit"]').click();
      });
    });

    syncTabCartState();
  })();
{% endjavascript %}

