      cursor: pointer;
      backdrop-filter: blur(4px);
    }

    .collection-filter-drawer__panel {
      width: 100vw;
      max-width: 100vw;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    /* ── Read more ── */
    var readMoreBtn = document.getElementById('collection-read-more');
    var descEl = document.getElementById('collection-desc');
    if (readMoreBtn && descEl) {
      readMoreBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var expanded = descEl.classList.toggle('is-expanded');
        readMoreBtn.textContent = expanded ? 'Read less' : 'Read more';
        readMoreBtn.setAttribute('aria-expanded', expanded);
      });
    }

    /* ── Facet accordion ── */
    document.querySelectorAll('.facet-group__toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', !expanded);
        var body = document.getElementById(btn.getAttribute('aria-controls'));
        if (body) body.classList.toggle('is-collapsed', expanded);
      });
    });

    /* ── Price form: submit as URL params ── */
    var priceForm = document.getElementById('facet-price-form');
    if (priceForm) {
      priceForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var url = new URL(window.location.href);
        var min = document.getElementById('price-min').value;
        var max = document.getElementById('price-max').value;
        if (min) url.searchParams.set('filter.v.price.gte', min); else url.searchParams.delete('filter.v.price.gte');
        if (max) url.searchParams.set('filter.v.price.lte', max); else url.searchParams.delete('filter.v.price.lte');
        window.location.href = url.toString();
      });
    }

    /* ── Cart ── */
    var cartVariantIds = [];

    function syncCartState() {
      fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          cartVariantIds = cart.items.map(function(i) { return String(i.variant_id); });
          document.querySelectorAll('.collection-page .product-list__item[data-variant-id]').forEach(function(card) {
            var variantId = card.dataset.variantId;
            var inCart = cartVariantIds.indexOf(variantId) !== -1;
            var iconBtn = card.querySelector('.product-card-actions__btn--cart');
            var mobileBtn = card.querySelector('.product-card-mobile-bar__cart');
            if (iconBtn) iconBtn.classList.toggle('is-added', inCart);
            if (mobileBtn) {
              mobileBtn.classList.toggle('is-added', inCart);
              if (inCart) mobileBtn.textContent = 'ADDED TO CART';
              else mobileBtn.textContent = mobileBtn.dataset.label || 'ADD TO CART';
            }
          });
        });
    }

    /* ATC form submit — intercept for AJAX + spinner */
    document.addEventListener('submit', function(e) {
      var form = e.target.closest('.collection-page .product-card-atc-form:not(.product-card-atc-form--mobile)');
      if (!form) return;
      e.preventDefault();
      var btn = form.querySelector('.product-card-actions__btn--cart');
      var variantId = form.querySelector('input[name="id"]').value;
      if (!btn || btn.classList.contains('is-loading')) return;

      btn.classList.add('is-loading');
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btn.classList.remove('is-loading');
        if (data.id) {
          btn.classList.add('is-added');
          cartVariantIds.push(String(variantId));
          var mobileBtn = form.closest('.product-list__item').querySelector('.product-card-mobile-bar__cart');
          if (mobileBtn) { mobileBtn.classList.add('is-added'); mobileBtn.textContent = 'ADDED TO CART'; }
          document.dispatchEvent(new CustomEvent('cart:refresh'));
        }
      })
      .catch(function() { btn.classList.remove('is-loading'); });
    });

    /* Mobile ATC button — submits the hidden form outside the <a> */
    function bindMobileAtc(root) {
      root.querySelectorAll('.product-list__item').forEach(function(card) {
        var mobileAtcBtn = card.querySelector('.js-mobile-atc');
        if (!mobileAtcBtn || mobileAtcBtn.dataset.bound) return;
        mobileAtcBtn.dataset.bound = '1';
        mobileAtcBtn.dataset.label = mobileAtcBtn.textContent.trim();
        mobileAtcBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var hiddenForm = card.querySelector('.product-card-atc-form--mobile');
          if (hiddenForm) hiddenForm.querySelector('[type="submit"]').click();
        });
      });
    }
    bindMobileAtc(document);

    document.addEventListener('cart:refresh', syncCartState);
    syncCartState();

    // ── Load more ──
    var loadMoreWrap = document.querySelector('.collection-page__load-more');
    var loadMoreBtn = document.querySelector('.js-load-more');
    var productGrid = document.querySelector('.collection-page__grid');

    if (loadMoreBtn && productGrid) {
      var loadMoreLabel = loadMoreBtn.dataset.label || loadMoreBtn.textContent.trim();

      loadMoreBtn.addEventListener('click', function() {
        var nextUrl = loadMoreBtn.dataset.nextUrl;
        if (!nextUrl || loadMoreBtn.disabled) return;

        loadMoreBtn.disabled = true;
        loadMoreBtn.textContent = '...';

        fetch(nextUrl + '&section_id=' + loadMoreBtn.dataset.sectionId)
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');

            var newItems = doc.querySelectorAll('.product-list__item');
            newItems.forEach(function(item) {
              productGrid.appendChild(item);
            });
            bindMobileAtc(productGrid);

            var nextBtn = doc.querySelector('.js-load-more');
            if (nextBtn && nextBtn.dataset.nextUrl) {
              loadMoreBtn.dataset.nextUrl = nextBtn.dataset.nextUrl;
              loadMoreBtn.disabled = false;
              loadMoreBtn.textContent = loadMoreLabel;
            } else {
              if (loadMoreWrap) loadMoreWrap.style.display = 'none';
            }

            syncCartState();
          })
          .catch(function() {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = loadMoreLabel;
          });
      });
    }

    // ── Sort select ──
    var sortSelect = document.querySelector('.js-sort-select');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', sortSelect.value);
        window.location.href = url.toString();
      });
    }

    // ── Mobile sort drawer ──
    var sortDrawer = document.getElementById('collection-sort-drawer');
    var sortBtn = document.getElementById('collection-sort-btn');
    var closeSortBtn = document.getElementById('collection-drawer-close-sort');

    function openSortDrawer() {
      if (!sortDrawer) return;
      sortDrawer.classList.add('is-open');
      sortDrawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeSortDrawer() {
      if (!sortDrawer) return;
      sortDrawer.classList.remove('is-open');
      sortDrawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    if (sortBtn) sortBtn.addEventListener('click', openSortDrawer);
    if (closeSortBtn) closeSortBtn.addEventListener('click', closeSortDrawer);
    if (sortDrawer) sortDrawer.addEventListener('click', function(e) {
      if (e.target === sortDrawer) closeSortDrawer();
    });

    // ── Mobile filter button ──
    var mobileFilterBtn = document.getElementById('collection-filter-btn');
    if (mobileFilterBtn) mobileFilterBtn.addEventListener('click', openFilterDrawer);

    // ── Filter drawer ──
    var filterDrawer = document.getElementById('collection-filter-drawer');

    function openFilterDrawer() {
      if (!filterDrawer) return;
      filterDrawer.classList.add('is-open');
      filterDrawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      var btn = document.querySelector('.js-open-filter-drawer');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    }

    function closeFilterDrawer() {
      if (!filterDrawer) return;
      filterDrawer.classList.remove('is-open');
      filterDrawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      var btn = document.querySelector('.js-open-filter-drawer');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    }

    document.querySelectorAll('.js-open-filter-drawer').forEach(function(btn) {
      btn.addEventListener('click', openFilterDrawer);
    });

    document.querySelectorAll('.js-close-filter-drawer').forEach(function(el) {
      el.addEventListener('click', closeFilterDrawer);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { closeFilterDrawer(); closeSortDrawer(); }
    });

  })();
{% endjavascript %}

