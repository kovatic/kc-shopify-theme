{% comment %}
  Collection page — facet filter sidebar + product grid with pagination.
{% endcomment %}

{%- comment -%} ── Mobile: sticky sort/filter bar ── {%- endcomment -%}
<div class="collection-mobile-bar" id="collection-mobile-bar">
  <button class="collection-mobile-bar__btn" id="collection-sort-btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="7" y1="12" x2="17" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="11" y1="18" x2="13" y2="18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
    {{ 'collection.sort_by' | t }}
    <svg class="collection-mobile-bar__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class="collection-mobile-bar__divider"></div>
  <button class="collection-mobile-bar__btn" id="collection-filter-btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="3" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="3" y1="18" x2="9" y2="18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
    {{ 'collection.filters' | t }}
  </button>
</div>

{%- comment -%} ── Mobile: sort drawer ── {%- endcomment -%}
<div class="collection-sort-drawer" id="collection-sort-drawer" aria-hidden="true">
  <div class="collection-sort-drawer__panel">
    <div class="collection-sort-drawer__header">
      <span class="collection-sort-drawer__title">{{ 'collection.sort_by' | t }}</span>
      <button class="collection-sort-drawer__close" id="collection-drawer-close-sort" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
    <ul class="collection-sort-drawer__list">
      {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-descending,created-ascending' | split: ',' -%}
      {%- assign sort_labels = 'Featured,Best selling,Alphabetically A–Z,Alphabetically Z–A,Price low to high,Price high to low,Date new to old,Date old to new' | split: ',' -%}
      {%- for opt in sort_options -%}
        <li>
          <a class="collection-sort-drawer__option{% if collection.sort_by == opt or collection.default_sort_by == opt and collection.sort_by == blank %} is-active{% endif %}" href="{{ collection.url }}?sort_by={{ opt }}">{{ sort_labels[forloop.index0] }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

<div class="collection-page" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="collection-page__container">

    <div class="collection-page__header">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-page__desc-wrap">
          <div class="collection-page__desc" id="collection-desc">{{ collection.description | strip_html }}</div>
          <a class="collection-page__read-more" href="#" id="collection-read-more" aria-expanded="false">Read more</a>
        </div>
      {%- endif -%}
    </div>

    {% paginate collection.products by section.settings.products_per_page %}

      {%- comment -%} ── Toolbar: sort + count + filters ── {%- endcomment -%}
      <div class="collection-toolbar">
        <div class="collection-toolbar__sort">
          <span class="collection-toolbar__count">{{ collection.products_count }} {{ 'collection.products_count' | t }}</span>
          <span class="collection-toolbar__sort-divider">|</span>
          <label class="collection-toolbar__sort-label" for="collection-sort-select">{{ 'collection.sort_by' | t }}:</label>
          <div class="collection-toolbar__sort-select-wrap">
            <select id="collection-sort-select" class="collection-toolbar__sort-select js-sort-select">
              {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-descending,created-ascending' | split: ',' -%}
              {%- assign sort_labels = 'Featured,Best selling,Alphabetically A–Z,Alphabetically Z–A,Price low to high,Price high to low,Date new to old,Date old to new' | split: ',' -%}
              {%- for opt in sort_options -%}
                <option value="{{ opt }}"{% if collection.sort_by == opt or collection.default_sort_by == opt and collection.sort_by == blank %} selected{% endif %}>{{ sort_labels[forloop.index0] }}</option>
              {%- endfor -%}
            </select>
            <svg class="collection-toolbar__sort-chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true"><polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <button class="collection-toolbar__filter-btn js-open-filter-drawer" aria-controls="collection-filter-drawer" aria-expanded="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="3" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="3" y1="18" x2="9" y2="18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          {{ 'collection.filters' | t }}
        </button>
      </div>

      {%- comment -%} Active filter pills below toolbar ── {%- endcomment -%}
      {%- assign has_active = false -%}
      {%- for filter in collection.filters -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}{%- assign has_active = true -%}{%- endif -%}
        {%- else -%}
          {%- if filter.active_values.size > 0 -%}{%- assign has_active = true -%}{%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_active -%}
        <div class="facet-active">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <a class="facet-active__pill" href="{{ value.url_to_remove }}">{{ value.label }}<svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></a>
            {%- endfor -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                <a class="facet-active__pill" href="{{ filter.url_to_remove }}">{{ filter.label }}<svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} ── Full-width grid ── {%- endcomment -%}
          <div class="collection-page__grid" id="collection-grid">
            {% for product in collection.products %}
              {%- if product.tags contains 'Archived' -%}{%- continue -%}{%- endif -%}
              {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
              {%- assign is_available = product.available -%}
              <div class="product-list__item{% unless is_available %} is-sold-out{% endunless %}" data-variant-id="{{ first_variant.id }}" data-available="{{ is_available }}">
                <a class="product-list__item-link" href="{{ product.url }}">
                  <div class="product-list__image-wrapper">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 600 | image_tag: class: 'product-list__image', loading: 'lazy', alt: product.title | escape }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'product-list__image product-list__image--placeholder' }}
                    {%- endif -%}

                    <div class="product-card-actions">
                      <div class="product-card-actions__cart-wrap">
                        {%- if is_available -%}
                          <form method="post" action="/cart/add" class="product-card-atc-form">
                            <input type="hidden" name="id" value="{{ first_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" name="add" class="product-card-actions__btn product-card-actions__btn--cart" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">
                              <svg class="icon-cart" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                              <svg class="icon-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                              <svg class="icon-spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/>
                              </svg>
                            </button>
                          </form>
                          <span class="product-card-tooltip">{{ 'sections.product_list.add_to_cart' | t }}</span>
                        {%- else -%}
                          <span class="product-card-oos-label">{{ 'general.product.sold_out' | t }}</span>
                        {%- endif -%}
                      </div>
                      <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/>
                          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                          <path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                      </button>
                    </div>

                    <div class="product-card-mobile-bar">
                      {%- if is_available -%}
                        <button type="button" class="product-card-mobile-bar__cart js-mobile-atc" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">
                          {{- 'sections.product_list.add_to_cart' | t | upcase -}}
                        </button>
                      {%- else -%}
                        <button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>
                          {{ 'general.product.sold_out' | t | upcase }}
                        </button>
                      {%- endif -%}
                      <button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="20">
                          <rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                          <rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                          <rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                          <rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                        </svg>
                      </button>
                    </div>
                  </div>

                  <div class="product-list__info">
                    <span class="product-list__name">{{ product.title | escape }}</span>
                    <span class="product-list__price">{{ product.price_min | money }}</span>
                  </div>
                </a>

                {%- if is_available -%}
                  <form method="post" action="/cart/add" class="product-card-atc-form product-card-atc-form--mobile" style="display:none">
                    <input type="hidden" name="id" value="{{ first_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" name="add" class="product-card-atc-form--mobile-submit"></button>
                  </form>
                {%- endif -%}

                <xb-wishlist-button-collection xb-handle="{{ product.handle }}" xb-parent-class="product-list__item"></xb-wishlist-button-collection>
              </div>
            {% endfor %}
          </div>

          {%- if paginate.next -%}
            <div class="collection-page__load-more">
              <button class="collection-page__load-more-btn js-load-more" data-next-url="{{ paginate.next.url }}" data-section-id="{{ section.id }}" data-label="{{ 'collection.load_more' | t }}">
                {{ 'collection.load_more' | t }}
              </button>
            </div>
          {%- endif -%}

      {%- comment -%} ── Filter drawer (desktop + mobile) ── {%- endcomment -%}
      <div class="collection-filter-drawer" id="collection-filter-drawer" aria-hidden="true">
        <div class="collection-filter-drawer__overlay js-close-filter-drawer"></div>
        <div class="collection-filter-drawer__panel">
          <div class="collection-filter-drawer__header">
            <span class="collection-filter-drawer__title">{{ 'collection.filters' | t }}</span>
            <button class="collection-filter-drawer__close js-close-filter-drawer" aria-label="Close">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
          </div>
          <div class="collection-filter-drawer__body">

            {%- comment -%} Search & Discovery filters {%- endcomment -%}
            {%- for filter in collection.filters -%}
              <div class="facet-group">
                <button class="facet-group__toggle" aria-expanded="true" aria-controls="drawer-facet-{{ filter.param_name | handleize }}">
                  {{ filter.label }}
                  <svg class="facet-group__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true"><polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="facet-group__body" id="drawer-facet-{{ filter.param_name | handleize }}">
                  {%- case filter.type -%}
                    {%- when 'list' -%}
                      <ul class="facet-list">
                        {%- for value in filter.values -%}
                          <li class="facet-list__item">
                            <a class="facet-list__link{% if value.active %} is-active{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}"
                               href="{{ value.url_to_add | default: value.url_to_remove }}">
                              <span class="facet-list__check"></span>{{ value.label }}<span class="facet-list__count">({{ value.count }})</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- when 'price_range' -%}
                      <form class="facet-price-form" id="facet-price-form">
                        {%- assign min_val = filter.min_value.value | default: '' -%}
                        {%- assign max_val = filter.max_value.value | default: '' -%}
                        {%- for f in collection.filters -%}
                          {%- if f.type == 'list' -%}
                            {%- for v in f.active_values -%}
                              <input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                        <div class="facet-price-form__fields">
                          <div class="facet-price-form__field">
                            <label class="facet-price-form__label" for="price-min">From</label>
                            <div class="facet-price-form__input-wrap">
                              <span class="facet-price-form__currency">{{ cart.currency.symbol }}</span>
                              <input class="facet-price-form__input" type="number" id="price-min" name="{{ filter.min_value.param_name }}" min="0" placeholder="0" value="{% if min_val != blank %}{{ min_val | money_without_currency | remove: ',' }}{% endif %}">
                            </div>
                          </div>
                          <div class="facet-price-form__field">
                            <label class="facet-price-form__label" for="price-max">To</label>
                            <div class="facet-price-form__input-wrap">
                              <span class="facet-price-form__currency">{{ cart.currency.symbol }}</span>
                              <input class="facet-price-form__input" type="number" id="price-max" name="{{ filter.max_value.param_name }}" min="0" placeholder="Any" value="{% if max_val != blank %}{{ max_val | money_without_currency | remove: ',' }}{% endif %}">
                            </div>
                          </div>
                        </div>
                        <button class="facet-price-form__btn" type="submit">Apply</button>
                      </form>
                  {%- endcase -%}
                </div>
              </div>
            {%- endfor -%}

            {%- if collection.all_tags.size > 0 -%}
              <div class="facet-group">
                <button class="facet-group__toggle" aria-expanded="true" aria-controls="drawer-facet-tags">
                  {{ 'collection.filters' | t }}
                  <svg class="facet-group__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true"><polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="facet-group__body" id="drawer-facet-tags">
                  <ul class="facet-list">
                    {%- for tag in collection.all_tags -%}
                      <li class="facet-list__item">
                        <a class="facet-list__link{% if current_tags contains tag %} is-active{% endif %}" href="{{ tag | link_to_tag: tag | split: 'href="' | last | split: '"' | first }}">
                          <span class="facet-list__check"></span>{{ tag }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}

          </div>
        </div>
      </div>

    {% endpaginate %}
  </div>
</div>

{% stylesheet %}
  .collection-page {
    padding-top: var(--padding-top, 40px);
    padding-bottom: var(--padding-bottom, 60px);
  }

  .collection-page__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  /* ── Header ── */
  .collection-page__header {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .collection-page__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 14px !important;
    font-weight: 600;
    color: #000;
    margin: 0;
    line-height: 1.2;
  }

  .collection-page__desc-wrap {
    position: relative;
  }

  .collection-page__desc {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 12px !important;
    font-weight: 400;
    color: #42464b;
    line-height: 1.714;
    margin: 0 0 4px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .collection-page__desc.is-expanded {
    display: block;
    overflow: visible;
  }

  .collection-page__read-more {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 12px;
    font-weight: 500;
    color: #ce0570;
    text-decoration: none;
  }

  .collection-page__read-more:hover { text-decoration: underline; }

  /* ── Toolbar ── */
  .collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0 1rem;
    border-bottom: 1px solid #e8e0d5;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .collection-toolbar__sort {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .collection-toolbar__sort-divider {
    color: #ccc;
    font-size: 0.8rem;
    padding: 0 0.25rem;
  }

  .collection-toolbar__sort-label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 500;
    color: #666;
    white-space: nowrap;
  }

  .collection-toolbar__sort-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .collection-toolbar__sort-select {
    appearance: none;
    background: none;
    border: none;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    color: #2e1f1f;
    padding-right: 1.2rem;
    cursor: pointer;
    outline: none;
  }

  .collection-toolbar__sort-chevron {
    position: absolute;
    right: 0;
    width: 14px;
    height: 14px;
    pointer-events: none;
    color: #2e1f1f;
  }

  .collection-toolbar__count {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    color: #888;
    flex: 1;
    text-align: center;
  }

  .collection-toolbar__filter-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid #2e1f1f;
    padding: 0.4rem 0.85rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: #2e1f1f;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .collection-toolbar__filter-btn:hover {
    background: #2e1f1f;
    color: #fff;
  }

  /* ── Filter drawer (all screen sizes) ── */
  .collection-filter-drawer {
    position: fixed;
    inset: 0;
    z-index: 500;
    pointer-events: none;
  }

  .collection-filter-drawer.is-open {
    pointer-events: auto;
  }

  .collection-filter-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    opacity: 0;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }

  .collection-filter-drawer.is-open .collection-filter-drawer__overlay {
    opacity: 1;
  }

  .collection-filter-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 340px;
    max-width: 90vw;
    background: #faf8f5;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow: hidden;
  }

  .collection-filter-drawer.is-open .collection-filter-drawer__panel {
    transform: translateX(0);
  }

  .collection-filter-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #e0dfd9;
    flex-shrink: 0;
  }

  .collection-filter-drawer__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    font-weight: 700;
    color: #2e1f1f;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .collection-filter-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: #2e1f1f;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .collection-filter-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 1.25rem 2rem;
  }

  .facet-group {
    border-bottom: 1px solid #e8e0d5;
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .facet-active {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .facet-active__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    background: #2e1f1f;
    color: #fff;
    font-size: 0.72rem;
    border-radius: 2rem;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .facet-active__pill:hover {
    background: #5a3a2a;
  }

  .facet-list__count {
    color: #999;
    font-size: 0.75em;
  }

  .facet-list__link.is-disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  .facet-group__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0.5rem 0;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    color: #2e1f1f;
    cursor: pointer;
    text-align: left;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .facet-group__chevron {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .facet-group__toggle[aria-expanded="false"] .facet-group__chevron {
    transform: rotate(-90deg);
  }

  .facet-group__body {
    overflow: hidden;
  }

  .facet-group__body.is-collapsed {
    display: none;
  }

  .facet-list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .facet-list__link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 400;
    color: #42464b;
    text-decoration: none;
    padding: 2px 0;
  }

  .facet-list__link:hover { color: #2e1f1f; }
  .facet-list__link.is-active { color: #e50e7e; font-weight: 600; }

  .facet-list__check {
    display: inline-flex;
    width: 14px;
    height: 14px;
    border: 1.5px solid #ccc;
    border-radius: 3px;
    flex-shrink: 0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .facet-list__link.is-active .facet-list__check {
    background: #e50e7e;
    border-color: #e50e7e;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='1 4 4 7 9 1' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 10px;
  }

  /* Price filter */
  .facet-price-form {
    padding: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .facet-price-form__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .facet-price-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .facet-price-form__label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.7rem;
    font-weight: 500;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .facet-price-form__input-wrap {
    display: flex;
    align-items: center;
    border: 1px solid #e0dfd9;
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }

  .facet-price-form__currency {
    padding: 0 6px;
    font-size: 0.75rem;
    color: #888;
    border-right: 1px solid #e0dfd9;
    line-height: 2rem;
  }

  .facet-price-form__input {
    border: none;
    outline: none;
    padding: 0 6px;
    width: 100%;
    font-size: 0.8rem;
    height: 2rem;
    background: transparent;
    color: #2e1f1f;
    -moz-appearance: textfield;
  }

  .facet-price-form__input::-webkit-outer-spin-button,
  .facet-price-form__input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .facet-price-form__btn {
    background: #2e1f1f;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    align-self: flex-start;
    transition: background 0.15s ease;
  }

  .facet-price-form__btn:hover { background: #e50e7e; }

  /* ── Product grid ── */
  .collection-page__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 0.75rem;
    row-gap: 2rem;
  }

  /* ── Product card ── */
  .product-list__item {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .product-list__item-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-list__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 5;
    background-color: #e8e0d5;
  }

  .product-list__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-list__image--placeholder { width: 100%; height: 100%; display: block; }

  .product-list__item-link:hover .product-list__image { transform: scale(1.04); }


  /* Action buttons */
  .product-card-actions {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    flex-direction: row;
    gap: 8px;
    pointer-events: none;
  }

  .product-card-actions__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.875rem;
    height: 2.875rem;
    border-radius: 50%;
    background: #fff;
    border: none;
    cursor: pointer;
    color: #2e1f1f;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease, color 0.15s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.12);
  }

  .product-card-actions__btn svg { width: 20px; height: 20px; flex-shrink: 0; }
  .product-card-actions__btn--cart { transition-delay: 0.06s; }
  .product-card-actions__btn--similar { transition-delay: 0s; }
  .product-list__item-link:hover .product-card-actions__btn { opacity: 1; transform: translateY(0); }
  .product-card-actions__btn:hover { background: #e50e7e; color: #fff; }

  .product-card-actions__btn--cart .icon-check { display: none; }
  .product-card-actions__btn--cart.is-added { background: #e50e7e; color: #fff; }
  .product-card-actions__btn--cart.is-added .icon-cart { display: none; }
  .product-card-actions__btn--cart.is-added .icon-check { display: block; }

  .product-card-actions__cart-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 4px 8px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .product-card-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: #2e1f1f;
  }

  .product-card-actions__cart-wrap:hover .product-card-tooltip { opacity: 1; }

  .product-card-oos-label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(0,0,0,0.45);
    padding: 4px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .product-card-mobile-bar { display: none; }
  .product-card-mobile-bar__cart.is-added { background: #2e1f1f; color: #fff; }
  .product-card-mobile-bar__cart--soldout { background: rgba(255,255,255,0.92); color: #aaa; cursor: not-allowed; font-style: italic; }

  /* Product info */
  .product-list__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem 0 0;
  }

  .product-list__name {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-foreground, #262626);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-list__price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-foreground, #262626);
    line-height: 1.2;
  }

  /* Load more */
  .collection-page__load-more {
    display: flex;
    justify-content: center;
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  .collection-page__load-more-btn {
    padding: 0.75rem 3rem;
    border: 1.5px solid #2e1f1f;
    background: transparent;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: #2e1f1f;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .collection-page__load-more-btn:hover:not(:disabled) {
    background: #2e1f1f;
    color: #fff;
  }

  .collection-page__load-more-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Mobile sticky bar ── */
  .collection-mobile-bar { display: none; }

  /* ── Mobile sort drawer ── */
  .collection-sort-drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 500;
    pointer-events: none;
  }
  .collection-sort-drawer.is-open {
    pointer-events: auto;
  }
  .collection-sort-drawer__panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #faf8f5;
    border-radius: 16px 16px 0 0;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    overflow: hidden;
  }
  .collection-sort-drawer.is-open .collection-sort-drawer__panel {
    transform: translateY(0);
  }
  .collection-sort-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #e0dfd9;
  }
  .collection-sort-drawer__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    font-weight: 700;
    color: #2e1f1f;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .collection-sort-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: #2e1f1f;
    display: flex;
    align-items: center;
    padding: 4px;
  }
  .collection-sort-drawer__list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 1.5rem;
  }
  .collection-sort-drawer__option {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 400;
    color: #2e1f1f;
    text-decoration: none;
  }
  .collection-sort-drawer__option.is-active {
    font-weight: 700;
    color: #e50e7e;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .collection-page { overflow-x: hidden; }
    .collection-page__container { padding: 0 1rem 64px; }

    .collection-toolbar { display: none; }

    .collection-mobile-bar {
      display: flex;
      align-items: stretch;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 200;
      background: #EFEEE9;
      box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
      height: 48px;
    }
    .collection-mobile-bar__btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: none;
      border: none;
      font-family: var(--font-body-family, 'Montserrat', sans-serif);
      font-size: 0.9rem;
      font-weight: 600;
      color: #2e1f1f;
      cursor: pointer;
      letter-spacing: 0.02em;
    }
    .collection-mobile-bar__divider {
      width: 1px;
      background: #d8cec4;
      margin: 12px 0;
    }
    .collection-mobile-bar__chevron { opacity: 0.6; }

    .collection-sort-drawer { display: block; }

    .collection-page__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 0.5rem;
      row-gap: 1.5rem;
      margin: 0 -1rem;
      width: calc(100% + 2rem);
    }

    .product-list__image-wrapper { aspect-ratio: 3 / 5; }
    .product-list__name { font-size: 0.875rem; -webkit-line-clamp: 1; }
    .product-list__price { font-size: 1rem; }
    .product-list__info { gap: 0.25rem; padding: 0.5rem 0.75rem 0; }
    .product-card-actions { display: none; }

    .product-card-mobile-bar {
      display: flex;
      align-items: stretch;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
    }

    .product-card-mobile-bar__cart {
      flex: 1;
      padding: 0.6rem 0.5rem;
      background: rgba(255,255,255,0.92);
      border: none;
      border-right: 1px solid #e8e0d5;
      font-family: var(--font-body-family, 'Montserrat', sans-serif);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #2e1f1f;
      cursor: pointer;
      text-align: center;
      backdrop-filter: blur(4px);
    }

    .product-card-mobile-bar__similar {
      display: flex;
      align-items: center;
      justify-content: center;
