<div
  class="offer-editorial full-width"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="offer-editorial__container">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="offer-editorial__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="offer-editorial__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="offer-editorial__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="offer-editorial__rows">
        {% content_for 'blocks' %}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .offer-editorial {
    width: 100%;
    padding-top: var(--padding-top, 80px);
    padding-bottom: var(--padding-bottom, 80px);
    background-color: #faf7f3;
  }

  .offer-editorial__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 52px;
  }

  .offer-editorial__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    margin-bottom: 24px;
  }

  .offer-editorial__heading {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 2.75rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0;
    line-height: 1.15;
  }

  .offer-editorial__subheading {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
  }

  .offer-editorial__rows {
    display: flex;
    flex-direction: column;
  }

  .offer-editorial__rows > * + * {
    border-top: 1px solid #e8ddd0;
  }

  @media screen and (max-width: 900px) {
    .offer-editorial__container {
      padding: 0 20px;
    }

    .offer-editorial__heading {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.offer_editorial.name",
  "blocks": [{ "type": "offer-row" }],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.title",
      "default": "Aadi Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subtitle",
      "default": "K. Chinnadurai Thaan Super — 10% to 50% off"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:sections.offer_editorial.name",
      "blocks": [{ "type": "offer-row" }]
    }
  ]
}
{% endschema %}
