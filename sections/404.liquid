<div class="not-found">
  <div class="not-found__inner">
    <p class="not-found__code">{{ '404.title' | t }}</p>
    <h1 class="not-found__heading">{{ '404.heading' | t }}</h1>
    <p class="not-found__message">{{ '404.not_found' | t }}</p>
    <div class="not-found__actions">
      <a href="{{ routes.root_url }}" class="not-found__btn not-found__btn--primary">
        {{ '404.go_home' | t }}
      </a>
      <a href="{{ routes.all_products_collection_url }}" class="not-found__btn not-found__btn--secondary">
        {{ '404.back_to_shopping' | t }}
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 4rem var(--page-margin, 1.5rem);
    text-align: center;
  }

  .not-found__inner {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .not-found__code {
    font-size: 7rem !important;
    font-weight: 800 !important;
    line-height: 1 !important;
    color: var(--color-primary, #ce0570);
    letter-spacing: -0.04em;
  }

  .not-found__heading {
    font-size: 2rem !important;
    font-weight: 700 !important;
    color: var(--color-foreground, #2e1f1f);
    margin: 0;
  }

  .not-found__message {
    font-size: 1rem !important;
    color: var(--color-secondary-text, #7e6767);
    max-width: 380px;
    line-height: 1.6;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .not-found__btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: var(--style-border-radius-inputs, 4px);
    font-size: 0.95rem !important;
    font-weight: 600 !important;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .not-found__btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .not-found__btn--primary {
    background-color: var(--color-primary, #ce0570);
    color: #fff;
  }

  .not-found__btn--secondary {
    background-color: transparent;
    color: var(--color-foreground, #2e1f1f);
    border: 2px solid var(--color-foreground, #2e1f1f);
  }

  @media (max-width: 600px) {
    .not-found__code {
      font-size: 5rem !important;
    }

    .not-found__heading {
      font-size: 1.5rem !important;
    }

    .not-found__btn {
      width: 100%;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "settings": []
}
{% endschema %}
