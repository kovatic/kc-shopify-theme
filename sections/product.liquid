{% comment %}
  Product page section with 2-column layout on desktop, single column on mobile.
  Mobile: swipe carousel + sticky ATC bar. Desktop: 2x2 image grid + info panel.
{% endcomment %}

{%- assign current_variant = product.selected_variant -%}
{%- unless current_variant -%}
  {%- assign lowest_price = nil -%}
  {%- for v in product.variants -%}
    {%- if v.available -%}
      {%- if lowest_price == nil -%}
        {%- assign current_variant = v -%}
        {%- assign lowest_price = v.price -%}
      {%- elsif v.price < lowest_price -%}
        {%- assign current_variant = v -%}
        {%- assign lowest_price = v.price -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  {%- unless current_variant -%}
    {%- assign current_variant = product.variants | first -%}
  {%- endunless -%}
{%- endunless -%}

<div class="product-page">

  {%- comment -%} Desktop breadcrumb (hidden on mobile) {%- endcomment -%}
  <div class="product-page__breadcrumb product-page__breadcrumb--desktop">
    <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
    <span class="product-page__breadcrumb-sep">/</span>
    <span>{{ product.title | truncate: 40 }}</span>
  </div>

  <div class="product-page__layout">

    {%- comment -%} LEFT: image gallery {%- endcomment -%}
    <div class="product-page__gallery">

      {%- comment -%} Desktop: 2x2 grid {%- endcomment -%}
      <div class="product-page__images-grid" id="zoom-grid-{{ section.id }}">
        {%- for image in product.images -%}
          <div class="product-page__image-item js-zoom-item js-lb-open" data-zoom-src="{{ image | image_url: width: 1800 }}" data-lb-index="{{ forloop.index0 }}">
            {{ image | image_url: width: 600 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
          </div>
        {%- else -%}
          <div class="product-page__image-item product-page__image-item--placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {%- endfor -%}
      </div>
      <div class="zoom-result" id="zoom-result-{{ section.id }}" aria-hidden="true"></div>

      {%- comment -%} Mobile: horizontal swipe carousel {%- endcomment -%}
      <div class="product-page__carousel" id="product-carousel">
        <div class="product-page__carousel-track" id="carousel-track">
          {%- for image in product.images -%}
            <div class="product-page__carousel-slide js-lb-open" data-zoom-src="{{ image | image_url: width: 1800 }}" data-lb-index="{{ forloop.index0 }}">
              {{ image | image_url: width: 800 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
            </div>
          {%- else -%}
            <div class="product-page__carousel-slide">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endfor -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-page__dots" id="carousel-dots">
            {%- for image in product.images -%}
              <button class="product-page__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to image {{ forloop.index }}"></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} RIGHT: product info {%- endcomment -%}
    <div class="product-page__info">
      <div class="product-page__info-inner">

        {%- comment -%} Mobile: prev/next nav {%- endcomment -%}
        <div class="product-page__nav product-page__nav--mobile">
          {%- if collection -%}
            {%- if collection.previous_product -%}
              <a href="{{ collection.previous_product }}" class="product-page__nav-btn">← {{ 'sections.product.previous' | t }}</a>
            {%- else -%}
              <span class="product-page__nav-btn product-page__nav-btn--disabled">← {{ 'sections.product.previous' | t }}</span>
            {%- endif -%}
            {%- if collection.next_product -%}
              <a href="{{ collection.next_product }}" class="product-page__nav-btn">{{ 'sections.product.next' | t }} →</a>
            {%- else -%}
              <span class="product-page__nav-btn product-page__nav-btn--disabled">{{ 'sections.product.next' | t }} →</span>
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- comment -%} Mobile breadcrumb {%- endcomment -%}
        <div class="product-page__breadcrumb product-page__breadcrumb--mobile">
          <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
          <span class="product-page__breadcrumb-sep">/</span>
          <span>{{ product.title | truncate: 30 }}</span>
        </div>

        <h1 class="product-page__title">{{ product.title }}</h1>

        {%- if product.collections.first != blank -%}
          <a href="{{ product.collections.first.url }}" class="product-page__vendor">{{ product.collections.first.title }}</a>
        {%- endif -%}


<div class="product-page__price-row">
  <span class="product-page__price" id="product-price-display">

      {%- comment -%} 2. Current Active Sale Price (Rendered in Bold Red/Orange) {%- endcomment -%}
    <span class="product-page__price-current{% if current_variant.compare_at_price > current_variant.price %} is-on-sale{% endif %}">{{ current_variant.price | money }}</span>
    
    {%- comment -%} 1. Compare-at Original Base Price (Struck out in gray-blue) {%- endcomment -%}
    <span class="product-page__price-compare" {% unless current_variant.compare_at_price > current_variant.price %}style="display: none;"{% endunless %}>
      {{ current_variant.compare_at_price | money }}
    </span>

    {%- comment -%} 3. Percentage Discount Badge Layout Container {%- endcomment -%}
    <span class="product-page__price-discount-badge" {% unless current_variant.compare_at_price > current_variant.price %}style="display: none;"{% endunless %}>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        {%- assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
        -{{ savings }}%
      {%- endif -%}
    </span>
  </span>
</div>

        {%- comment -%} Stock alert {%- endcomment -%}
          {%- assign inv = current_variant.inventory_quantity -%}
          {%- assign inv_policy = current_variant.inventory_management -%}
          {%- if current_variant.available and inv_policy == 'shopify' -%}
            {%- if inv <= 3 -%}
              <div class="product-page__stock-alert product-page__stock-alert--critical" id="stock-alert">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {{ 'product.stock.critical' | t: count: inv }}
              </div>
            {%- elsif inv <= 10 -%}
              <div class="product-page__stock-alert product-page__stock-alert--low" id="stock-alert">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 9v4M12 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {{ 'product.stock.low' | t: count: inv }}
              </div>
            {%- endif -%}
          {%- elsif current_variant.available == false -%}
            <div class="product-page__stock-alert product-page__stock-alert--sold-out" id="stock-alert" style="display:none"></div>
          {%- else -%}
            <div class="product-page__stock-alert" id="stock-alert" style="display:none"></div>
          {%- endif -%}

        {%- comment -%} Variant selector + ATC (desktop inline, mobile hidden — shown in sticky bar) {%- endcomment -%}
        <div>
          <input type="hidden" id="variant-id-input" value="{{ current_variant.id }}">
          {%- if product.variants.size > 1 -%}
            <div class="product-page__variants">
              {%- for option in product.options_with_values -%}
                {%- assign option_index = forloop.index0 -%}
                {%- assign current_option_value = current_variant.options[option_index] -%}
                <div class="product-page__option">
                  <label class="product-page__option-label">{{ option.name }}</label>
                  <div class="product-page__option-values">
                    {%- for value in option.values -%}
                      <button type="button" class="product-page__option-btn{% if current_option_value == value %} is-selected{% endif %}" data-option-index="{{ option_index }}" data-value="{{ value }}">{{ value }}</button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Stitching button (only for tailoring-enabled products) {%- endcomment -%}
          {%- if product.metafields.custom.is_customisable.value == true -%}
            <button type="button" class="product-page__stitching-btn js-tailoring-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/>
                <line x1="20" y1="4" x2="8.12" y2="15.88"/>
                <line x1="14.47" y1="14.48" x2="20" y2="20"/>
                <line x1="8.12" y1="8.12" x2="12" y2="12"/>
              </svg>
              <span class="product-page__stitching-btn-text">
                <span class="product-page__stitching-btn-title">{{ 'tailoring.stitching_btn' | t }}</span>
                <span class="product-page__stitching-btn-sub">Add tailoring</span>
              </span>
              <span class="product-page__stitching-btn-badge">Customise</span>
            </button>
          {%- endif -%}

          

          {%- comment -%} ATC + Wishlist + Share row + buy now {%- endcomment -%}
          <div class="product-page__action-row">
            <div class="product-page__buy-buttons-group product-page__atc-btn--desktop">
              <button
                type="button"
                class="product-page__atc-btn product-page__atc-btn--desktop js-atc-btn"
                data-variant-input="variant-id-input"
                {%- unless current_variant.available -%}disabled{%- endunless -%}
              >
                {%- if current_variant.available -%}
                  {{ 'sections.product_list.add_to_cart' | t }}
                {%- else -%}
                  {{ 'general.product.sold_out' | t }}
                {%- endif -%}
              </button>

              <button
                type="button"
                class="product-page__bin-btn product-page__bin-btn--desktop js-bin-btn"
                {%- unless current_variant.available -%}disabled{%- endunless -%}
              >
               <span class="btn-text">Buy Now</span>
              <span class="btn-loader"></span>
              </button>
            </div>

            <xb-wishlist-button xb-handle="{{ product.handle }}" class="product-page__wishlist-icon-btn"></xb-wishlist-button>

            <div class="product-page__share-dropdown">
              <button type="button" class="product-page__share-icon-btn" aria-label="Share">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              </button>
              <div class="product-page__share-menu">
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg> Facebook
                </a>
                <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg> X
                </a>
                <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 600 }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg> Pinterest
                </a>
                <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ shop.url }}{{ product.url | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg> WhatsApp
                </a>
                <button type="button" class="product-page__share-menu-item js-copy-link" data-url="{{ shop.url }}{{ product.url }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Copy link
                </button>
              </div>
            </div>
          </div>
        </div>
        <div class="product-page__trust-signals">
            <div class="trust-signal-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="trust-signal-icon"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
              <span class="trust-signal-text">Easy 3 Days Return & Exchange</span>
            </div>
            <div class="trust-signal-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="trust-signal-icon"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><path d="M6 14h.01M10 14h.01M14 14h.01"/></svg>
              <span class="trust-signal-text">Cash on Delivery Available</span>
            </div>
            <div class="trust-signal-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="trust-signal-icon"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="trust-signal-text">100% Secure Transaction</span>
            </div>
            <div class="trust-signal-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="trust-signal-icon"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span class="trust-signal-text">Quick Chat & Call Support</span>
            </div>
          </div>
        {%- comment -%} Pincode checker — hidden until Shiprocket proxy is configured {%- endcomment -%}
