{% comment %}
  Product page section with 2-column layout on desktop, single column on mobile.
  Mobile: swipe carousel + sticky ATC bar. Desktop: 2x2 image grid + info panel.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="product-page">

  {%- comment -%} Desktop breadcrumb (hidden on mobile) {%- endcomment -%}
  <div class="product-page__breadcrumb product-page__breadcrumb--desktop">
    <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
    <span class="product-page__breadcrumb-sep">/</span>
    <span>{{ product.title | truncate: 40 }}</span>
  </div>

  <div class="product-page__layout">

    {%- comment -%} LEFT: image gallery {%- endcomment -%}
    <div class="product-page__gallery">

      {%- comment -%} Desktop: 2x2 grid {%- endcomment -%}
      <div class="product-page__images-grid" id="zoom-grid-{{ section.id }}">
        {%- for image in product.images limit: 4 -%}
          <div class="product-page__image-item js-zoom-item js-lb-open" data-zoom-src="{{ image | image_url: width: 1800 }}" data-lb-index="{{ forloop.index0 }}">
            {{ image | image_url: width: 600 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
          </div>
        {%- else -%}
          <div class="product-page__image-item product-page__image-item--placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {%- endfor -%}
      </div>
      <div class="zoom-result" id="zoom-result-{{ section.id }}" aria-hidden="true"></div>

      {%- comment -%} Mobile: horizontal swipe carousel {%- endcomment -%}
      <div class="product-page__carousel" id="product-carousel">
        <div class="product-page__carousel-track" id="carousel-track">
          {%- for image in product.images limit: 4 -%}
            <div class="product-page__carousel-slide js-lb-open" data-zoom-src="{{ image | image_url: width: 1800 }}" data-lb-index="{{ forloop.index0 }}">
              {{ image | image_url: width: 800 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}
            </div>
          {%- else -%}
            <div class="product-page__carousel-slide">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endfor -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-page__dots" id="carousel-dots">
            {%- for image in product.images limit: 4 -%}
              <button class="product-page__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to image {{ forloop.index }}"></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} RIGHT: product info {%- endcomment -%}
    <div class="product-page__info">
      <div class="product-page__info-inner">

        {%- comment -%} Mobile: prev/next nav {%- endcomment -%}
        <div class="product-page__nav product-page__nav--mobile">
          {%- if collection -%}
            {%- if collection.previous_product -%}
              <a href="{{ collection.previous_product }}" class="product-page__nav-btn">← {{ 'sections.product.previous' | t }}</a>
            {%- else -%}
              <span class="product-page__nav-btn product-page__nav-btn--disabled">← {{ 'sections.product.previous' | t }}</span>
            {%- endif -%}
            {%- if collection.next_product -%}
              <a href="{{ collection.next_product }}" class="product-page__nav-btn">{{ 'sections.product.next' | t }} →</a>
            {%- else -%}
              <span class="product-page__nav-btn product-page__nav-btn--disabled">{{ 'sections.product.next' | t }} →</span>
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- comment -%} Mobile breadcrumb {%- endcomment -%}
        <div class="product-page__breadcrumb product-page__breadcrumb--mobile">
          <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
          <span class="product-page__breadcrumb-sep">/</span>
          <span>{{ product.title | truncate: 30 }}</span>
        </div>

        <h1 class="product-page__title">{{ product.title }}</h1>

        {%- if product.vendor != blank -%}
          <a href="{{ product.vendor | url_for_vendor }}" class="product-page__vendor">{{ product.vendor }}</a>
        {%- endif -%}

        <!-- Start of Judge.me code -->
        <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
          {{ product.metafields.judgeme.badge }}
        </div>
        <!-- End of Judge.me code -->

        <div class="product-page__price-row">
          <span class="product-page__price">
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="product-page__price-compare">{{ current_variant.compare_at_price | money }}</span>
            {%- endif -%}
            {{ current_variant.price | money }}
          </span>
        </div>

        {%- comment -%} Variant selector + ATC (desktop inline, mobile hidden — shown in sticky bar) {%- endcomment -%}
        <div>
          <input type="hidden" id="variant-id-input" value="{{ current_variant.id }}">
          {%- if product.variants.size > 1 -%}
            <div class="product-page__variants">
              {%- for option in product.options_with_values -%}
                {%- assign option_index = forloop.index0 -%}
                <div class="product-page__option">
                  <label class="product-page__option-label">{{ option.name }}</label>
                  <div class="product-page__option-values">
                    {%- for value in option.values -%}
                      <button type="button" class="product-page__option-btn{% if option.selected_value == value %} is-selected{% endif %}" data-option-index="{{ option_index }}" data-value="{{ value }}">{{ value }}</button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} ATC + Wishlist + Share row {%- endcomment -%}
          <div class="product-page__action-row">
            <button
              type="button"
              class="product-page__atc-btn product-page__atc-btn--desktop js-atc-btn"
              data-variant-input="variant-id-input"
              {%- unless current_variant.available -%}disabled{%- endunless -%}
            >
              {%- if current_variant.available -%}
                {{ 'sections.product_list.add_to_cart' | t }}
              {%- else -%}
                {{ 'general.product.sold_out' | t }}
              {%- endif -%}
            </button>

            <xb-wishlist-button xb-handle="{{ product.handle }}" class="product-page__wishlist-icon-btn"></xb-wishlist-button>

            <div class="product-page__share-dropdown">
              <button type="button" class="product-page__share-icon-btn" aria-label="Share">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              </button>
              <div class="product-page__share-menu">
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg> Facebook
                </a>
                <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg> X
                </a>
                <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 600 }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg> Pinterest
                </a>
                <a href="mailto:?subject={{ product.title | url_encode }}&body={{ shop.url }}{{ product.url }}" class="product-page__share-menu-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg> Email
                </a>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} Pincode checker — hidden until Shiprocket proxy is configured {%- endcomment -%}
        <div class="product-page__pincode-wrap" style="display:none">
          <p class="product-page__pincode-label">{{ 'sections.product.pincode_label' | t }}</p>
          <div class="product-page__pincode">
            <input
              type="text"
              class="product-page__pincode-input"
              id="pincode-input-{{ section.id }}"
              placeholder="{{ 'sections.product.pincode_placeholder' | t }}"
              maxlength="6"
              inputmode="numeric"
              autocomplete="postal-code"
              aria-label="{{ 'sections.product.pincode_placeholder' | t }}"
              aria-describedby="pincode-result-{{ section.id }}"
            >
            <button type="button" class="product-page__pincode-btn" id="pincode-btn-{{ section.id }}">
              <span class="pincode-btn__label">{{ 'sections.product.pincode_check' | t }}</span>
              <svg class="pincode-btn__spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="14" height="14">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/>
              </svg>
            </button>
          </div>
          <div class="product-page__pincode-result" id="pincode-result-{{ section.id }}" aria-live="polite"></div>
        </div>

        {%- comment -%} Accordions {%- endcomment -%}
        <div class="product-page__accordions">
          {%- if product.description != blank -%}
            <details class="product-page__accordion">
              <summary class="product-page__accordion-header">
                {{ 'sections.product.description' | t }}
                <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="product-page__accordion-body">{{ product.description }}</div>
            </details>
          {%- endif -%}
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.product_details' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body">
              {%- if product.metafields.custom.product_details != blank -%}
                {{ product.metafields.custom.product_details }}
              {%- else -%}
                <p>{{ product.title }}</p>
              {%- endif -%}
            </div>
          </details>
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.delivery' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body"><p>{{ 'sections.product.delivery_info' | t }}</p></div>
          </details>
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.returns' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body"><p>{{ 'sections.product.returns_info' | t }}</p></div>
          </details>
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.mrp' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body"><p>{{ current_variant.price | money }}</p></div>
          </details>
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.manufacturer' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body">
              <p>{{ product.vendor | default: shop.name }}</p>
            </div>
          </details>
          <details class="product-page__accordion">
            <summary class="product-page__accordion-header">
              {{ 'sections.product.contact' | t }}
              <svg class="product-page__accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-page__accordion-body"><p><a href="/pages/contact">{{ 'sections.product.contact_us' | t }}</a></p></div>
          </details>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%} Judge.me review widget {%- endcomment -%}
  <div class="product-page__reviews">
    <!-- Start of Judge.me code -->
    {%- assign has_legacy = false -%}
    {%- if product.metafields.judgeme.widget.size > 20 -%}
      {%- assign has_legacy = true -%}
    {%- endif -%}
    <div style="clear:both"></div>
    <div
      id="judgeme_product_reviews"
      class="jdgm-widget jdgm-review-widget"
      data-product-title="{{ product.title | escape }}"
      data-id="{{ product.id }}"
      data-product-id="{{ product.id }}"
      data-widget="review"
      data-auto-install="false"
      data-shop-reviews-count="{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}"
      data-entry-point="review_widget.js"
      data-entry-key="review-widget/main.js"
    >
      {%- if has_legacy -%}
        <div class="jdgm-legacy-widget-content" style="display:none;">{{ product.metafields.judgeme.widget }}</div>
      {%- endif -%}
    </div>
    {%- if product.metafields.judgeme.review_widget_data -%}
      <script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>
    {%- endif -%}
    <!-- End of Judge.me code -->
  </div>

</div>

{%- comment -%} Mobile sticky ATC bar {%- endcomment -%}
<div class="product-page__sticky-atc" id="sticky-atc">
  <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id-input-mobile">
  <button
    type="button"
    class="product-page__atc-btn js-atc-btn"
    data-variant-input="variant-id-input-mobile"
    {%- unless current_variant.available -%}disabled{%- endunless -%}
  >
    {%- if current_variant.available -%}
      {{ 'sections.product_list.add_to_cart' | t }}
    {%- else -%}
      {{ 'general.product.sold_out' | t }}
    {%- endif -%}
  </button>

  <xb-wishlist-button xb-handle="{{ product.handle }}" class="product-page__sticky-wishlist"></xb-wishlist-button>

  <div class="product-page__share-dropdown product-page__share-dropdown--mobile">
    <button type="button" class="product-page__share-icon-btn" aria-label="Share">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
    </button>
    <div class="product-page__share-menu">
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg> Facebook
      </a>
      <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg> X
      </a>
      <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 600 }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" class="product-page__share-menu-item">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg> Pinterest
      </a>
      <a href="mailto:?subject={{ product.title | url_encode }}&body={{ shop.url }}{{ product.url }}" class="product-page__share-menu-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg> Email
      </a>
    </div>
  </div>
</div>

{%- comment -%} Lightbox — placed outside .product-page so it doesn't affect layout {%- endcomment -%}
<div class="lb-overlay" id="lb-overlay-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb-close" id="lb-close-{{ section.id }}" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="24" height="24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="lb-nav lb-nav--prev" id="lb-prev-{{ section.id }}" aria-label="Previous image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="28" height="28"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <div class="lb-stage" id="lb-stage-{{ section.id }}">
    <img class="lb-img" id="lb-img-{{ section.id }}" src="" alt="">
  </div>
  <button class="lb-nav lb-nav--next" id="lb-next-{{ section.id }}" aria-label="Next image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="28" height="28"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="lb-controls">
    <button class="lb-ctrl-btn" id="lb-zoom-in-{{ section.id }}" aria-label="Zoom in">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button class="lb-ctrl-btn" id="lb-zoom-out-{{ section.id }}" aria-label="Zoom out">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button class="lb-ctrl-btn" id="lb-zoom-reset-{{ section.id }}" aria-label="Reset zoom">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M3.51 15a9 9 0 1 0 .49-3"/><polyline points="3 7 3 15 11 15"/></svg>
    </button>
  </div>
  <div class="lb-counter" id="lb-counter-{{ section.id }}"></div>
</div>

<script id="product-json-{{ section.id }}" type="application/json">
  {{ product | json }}
</script>

<script>
(function() {
  function debounce(fn, ms) {
    var t;
    return function() {
      var args = arguments;
      clearTimeout(t);
      t = setTimeout(function() { fn.apply(null, args); }, ms);
    };
  }

  function throttleRaf(fn) {
    var rafId = null;
    return function() {
      var args = arguments;
      if (rafId) return;
      rafId = requestAnimationFrame(function() { rafId = null; fn.apply(null, args); });
    };
  }

  function init() {
  var page = document.querySelector('.product-page');
  if (!page) return;

  var productEl = document.getElementById('product-json-{{ section.id }}');
  var product = productEl ? JSON.parse(productEl.textContent) : null;
  if (!product) return;

  // ── Variant option buttons ───────────────────────────────────
  var optionBtns    = page.querySelectorAll('.product-page__option-btn');
  var variantInputs = document.querySelectorAll('#variant-id-input, #variant-id-input-mobile');
  var atcBtns       = document.querySelectorAll('.js-atc-btn');
  var priceEl       = page.querySelector('.product-page__price');

  function getSelectedOptions() {
    var groups = {};
    optionBtns.forEach(function(btn) {
      if (btn.classList.contains('is-selected')) {
        groups[btn.getAttribute('data-option-index')] = btn.getAttribute('data-value');
      }
    });
    var opts = [];
    for (var i = 0; i < product.options.length; i++) {
      opts.push(groups[String(i)] || '');
    }
    return opts;
  }

  function findVariant(opts) {
    return product.variants.find(function(v) {
      return opts.every(function(opt, i) {
        return v['option' + (i + 1)] === opt;
      });
    });
  }

  function updateVariant(variant) {
    if (!variant) return;
    // Update hidden id inputs in both forms
    variantInputs.forEach(function(input) { input.value = variant.id; });
    // Update URL without reload
    if (history.replaceState) {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      history.replaceState({}, '', url.toString());
    }
    // Update price using Shopify money format
    if (priceEl && window.Shopify && Shopify.formatMoney) {
      var html = '';
      if (variant.compare_at_price > variant.price) {
        html += '<span class="product-page__price-compare">' + Shopify.formatMoney(variant.compare_at_price) + '</span> ';
      }
      html += Shopify.formatMoney(variant.price);
      priceEl.innerHTML = html;
    }
    // Update ATC buttons availability
    var available = variant.available;
    var addLabel  = '{{ "sections.product_list.add_to_cart" | t }}';
    var soldLabel = '{{ "general.product.sold_out" | t }}';
    atcBtns.forEach(function(btn) {
      btn.disabled    = !available;
      btn.textContent = available ? addLabel : soldLabel;
    });
  }

  // ── AJAX Add to Cart (batched) ────────────────────────────────
  var atcPending = 0;
  var atcTimer   = null;

  function flushAtc(variantId) {
    var qty = atcPending;
    atcPending = 0;
    atcBtns.forEach(function(b) { b.classList.add('is-loading'); b.disabled = true; });
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function() { return fetch('/cart.js').then(function(r) { return r.json(); }); })
    .then(function(cart) {
      var drawer = document.querySelector('cart-drawer');
      if (drawer) { drawer.renderCart(cart); drawer.open(); }
    })
    .catch(function(err) { console.error('Cart error:', err); })
    .finally(function() {
      atcBtns.forEach(function(b) { b.classList.remove('is-loading'); b.disabled = false; });
    });
  }

  atcBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = document.getElementById('variant-id-input').value;
      if (!variantId) return;
      atcPending++;
      clearTimeout(atcTimer);
      atcTimer = setTimeout(function() { flushAtc(variantId); }, 400);
    });
  });

  optionBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = btn.getAttribute('data-option-index');
      optionBtns.forEach(function(b) {
        if (b.getAttribute('data-option-index') === idx) b.classList.remove('is-selected');
      });
      btn.classList.add('is-selected');
      var variant = findVariant(getSelectedOptions());
      if (variant) updateVariant(variant);
    });
  });

  // ── Share dropdown ───────────────────────────────────────────
  page.querySelectorAll('.product-page__share-dropdown').forEach(function(dropdown) {
    var btn = dropdown.querySelector('.product-page__share-icon-btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('is-open');
    });
  });
  document.addEventListener('click', function() {
    page.querySelectorAll('.product-page__share-dropdown').forEach(function(d) {
      d.classList.remove('is-open');
    });
  });

  // ── Pincode checker ──────────────────────────────────────────
  var pincodeInput  = document.getElementById('pincode-input-{{ section.id }}');
  var pincodeBtn    = document.getElementById('pincode-btn-{{ section.id }}');
  var pincodeResult = document.getElementById('pincode-result-{{ section.id }}');

  function setPincodeResult(type, msg) {
    if (!pincodeResult) return;
    pincodeResult.className = 'product-page__pincode-result is-' + type;
    pincodeResult.textContent = msg;
  }

  function checkPincode() {
    var pin = pincodeInput.value.trim();
    if (!/^\d{6}$/.test(pin)) {
      pincodeInput.classList.add('is-invalid');
      setPincodeResult('error', '{{ "sections.product.pincode_invalid" | t | escape }}');
      return;
    }
    pincodeInput.classList.remove('is-invalid');
    pincodeResult.className = 'product-page__pincode-result';
    pincodeResult.textContent = '';
    pincodeBtn.classList.add('is-loading');
    fetch('https://api.postalpincode.in/pincode/' + pin)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        pincodeBtn.classList.remove('is-loading');
        var record = data && data[0];
        if (!record || record.Status === 'Error' || !record.PostOffice || !record.PostOffice.length) {
          setPincodeResult('error', '{{ "sections.product.pincode_not_serviceable" | t | escape }}');
          return;
        }
        var po = record.PostOffice[0];
        setPincodeResult('success', '{{ "sections.product.pincode_deliverable" | t | escape }}'.replace('__area__', po.Name + ', ' + po.District + ', ' + po.State));
      })
      .catch(function() {
        pincodeBtn.classList.remove('is-loading');
        setPincodeResult('warning', '{{ "sections.product.pincode_api_error" | t | escape }}');
      });
  }

  if (pincodeBtn) pincodeBtn.addEventListener('click', checkPincode);
  if (pincodeInput) {
    pincodeInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') checkPincode(); });
    pincodeInput.addEventListener('input', debounce(function() {
      pincodeInput.value = pincodeInput.value.replace(/\D/g, '');
      pincodeInput.classList.remove('is-invalid');
    }, 150));
  }

  // ── Image zoom (desktop) ─────────────────────────────────────
  var zoomResult = document.getElementById('zoom-result-{{ section.id }}');
  var zoomItems  = document.querySelectorAll('#zoom-grid-{{ section.id }} .js-zoom-item');
  var resultSize = 380;

  if (zoomResult && zoomItems.length) {
    function positionPanel(item) {
      var rect = item.getBoundingClientRect();
      var top  = rect.top;
      var left = rect.right + 12;
      if (left + resultSize > window.innerWidth - 8) left = rect.left - resultSize - 12;
      if (top + resultSize > window.innerHeight - 8) top = window.innerHeight - resultSize - 8;
      zoomResult.style.top  = top + 'px';
      zoomResult.style.left = left + 'px';
    }

    zoomItems.forEach(function(item) {
      var zoomSrc = item.getAttribute('data-zoom-src');
      var preloaded = false;

      item.addEventListener('mouseenter', function() {
        if (window.innerWidth < 992) return;
        if (!preloaded) { preloaded = true; (new Image()).src = zoomSrc; }
        zoomResult.style.backgroundImage = 'url(' + zoomSrc + ')';
        zoomResult.classList.add('is-visible');
        positionPanel(item);
      });
      item.addEventListener('mouseleave', function() {
        zoomResult.classList.remove('is-visible');
      });
      item.addEventListener('mousemove', throttleRaf(function(e) {
        if (window.innerWidth < 992) return;
        var rect = item.getBoundingClientRect();
        var x = Math.max(0, Math.min(rect.width,  e.clientX - rect.left));
        var y = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
        positionPanel(item);
        var factor = 3;
        zoomResult.style.backgroundSize     = (rect.width * factor) + 'px ' + (rect.height * factor) + 'px';
        zoomResult.style.backgroundPosition = '-' + (x * factor - resultSize / 2) + 'px -' + (y * factor - resultSize / 2) + 'px';
      }));
    });
  }

  // ── Mobile carousel dots ─────────────────────────────────────
  var track = document.getElementById('carousel-track');
  var dots  = page.querySelectorAll('.product-page__dot');
  if (track && dots.length) {
    track.addEventListener('scroll', throttleRaf(function() {
      var idx = Math.round(track.scrollLeft / track.offsetWidth);
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
    }), { passive: true });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        track.scrollTo({ left: parseInt(dot.getAttribute('data-index')) * track.offsetWidth, behavior: 'smooth' });
      });
    });
  }

  // ── Lightbox ─────────────────────────────────────────────────
  var overlay   = document.getElementById('lb-overlay-{{ section.id }}');
  var lbImg     = document.getElementById('lb-img-{{ section.id }}');
  var lbClose   = document.getElementById('lb-close-{{ section.id }}');
  var lbPrev    = document.getElementById('lb-prev-{{ section.id }}');
  var lbNext    = document.getElementById('lb-next-{{ section.id }}');
  var lbZoomIn  = document.getElementById('lb-zoom-in-{{ section.id }}');
  var lbZoomOut = document.getElementById('lb-zoom-out-{{ section.id }}');
  var lbReset   = document.getElementById('lb-zoom-reset-{{ section.id }}');
  var lbCounter = document.getElementById('lb-counter-{{ section.id }}');

  if (overlay && lbImg) {
    var lbSrcs = [];
    var lbIndex = 0;
    var lbScale = 1, lbMin = 1, lbMax = 4, lbStep = 0.4;
    var lbTx = 0, lbTy = 0;

    function lbTransform(animate) {
      lbImg.style.transition = animate ? 'transform 0.2s ease' : 'none';
      lbImg.style.transform  = 'translate(' + lbTx + 'px,' + lbTy + 'px) scale(' + lbScale + ')';
      lbImg.classList.toggle('is-zoomed', lbScale > 1);
    }
    function lbClamp() {
      var mx = Math.max(0, (lbImg.offsetWidth  * lbScale - overlay.offsetWidth)  / 2);
      var my = Math.max(0, (lbImg.offsetHeight * lbScale - overlay.offsetHeight) / 2);
      lbTx = Math.max(-mx, Math.min(mx, lbTx));
      lbTy = Math.max(-my, Math.min(my, lbTy));
    }
    function lbReset2() { lbScale = 1; lbTx = 0; lbTy = 0; lbTransform(true); }
    function lbLoad(idx) {
      lbIndex = idx;
      lbScale = 1; lbTx = 0; lbTy = 0;
      lbImg.style.transform = 'none';
      lbImg.classList.remove('is-zoomed');
      lbImg.src = lbSrcs[idx];
      if (lbCounter) lbCounter.textContent = (idx + 1) + ' / ' + lbSrcs.length;
      if (lbPrev) lbPrev.disabled = idx === 0;
      if (lbNext) lbNext.disabled = idx === lbSrcs.length - 1;
    }
    function lbOpen(idx) {
      lbSrcs = [];
      document.querySelectorAll('#zoom-grid-{{ section.id }} .js-zoom-item').forEach(function(el) {
        lbSrcs.push(el.getAttribute('data-zoom-src'));
      });
      if (!lbSrcs.length) return;
      lbLoad(idx);
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function lbClose2() {
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
      lbReset2();
    }

    document.addEventListener('click', function(e) {
      var opener = e.target.closest('.js-lb-open');
      if (opener) { e.preventDefault(); lbOpen(parseInt(opener.getAttribute('data-lb-index') || '0')); }
    });
    lbClose.addEventListener('click', lbClose2);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) lbClose2(); });
    if (lbPrev) lbPrev.addEventListener('click', debounce(function() { if (lbIndex > 0) lbLoad(lbIndex - 1); }, 150));
    if (lbNext) lbNext.addEventListener('click', debounce(function() { if (lbIndex < lbSrcs.length - 1) lbLoad(lbIndex + 1); }, 150));
    if (lbZoomIn)  lbZoomIn.addEventListener('click',  debounce(function() { lbScale = Math.min(lbMax, lbScale + lbStep); lbClamp(); lbTransform(true); }, 100));
    if (lbZoomOut) lbZoomOut.addEventListener('click', debounce(function() { lbScale = Math.max(lbMin, lbScale - lbStep); if (lbScale === 1) { lbTx = 0; lbTy = 0; } lbClamp(); lbTransform(true); }, 100));
    if (lbReset)   lbReset.addEventListener('click', debounce(lbReset2, 150));

    overlay.addEventListener('wheel', throttleRaf(function(e) {
      e.preventDefault();
      lbScale = Math.max(lbMin, Math.min(lbMax, lbScale + (e.deltaY < 0 ? lbStep : -lbStep)));
      if (lbScale === 1) { lbTx = 0; lbTy = 0; }
      lbClamp(); lbTransform(false);
    }), { passive: false });

    var lbDrag = { on: false, x: 0, y: 0, tx: 0, ty: 0 };
    lbImg.addEventListener('mousedown', function(e) {
      if (lbScale <= 1) return;
      e.preventDefault();
      lbDrag.on = true; lbDrag.x = e.clientX; lbDrag.y = e.clientY; lbDrag.tx = lbTx; lbDrag.ty = lbTy;
      lbImg.classList.add('is-dragging');
    });
    window.addEventListener('mousemove', throttleRaf(function(e) {
      if (!lbDrag.on) return;
      lbTx = lbDrag.tx + (e.clientX - lbDrag.x);
      lbTy = lbDrag.ty + (e.clientY - lbDrag.y);
      lbClamp(); lbTransform(false);
    }));
    window.addEventListener('mouseup', function() {
      if (!lbDrag.on) return;
      lbDrag.on = false; lbImg.classList.remove('is-dragging');
    });

    var lbTouch = { d: 0, on: false, x: 0, y: 0, tx: 0, ty: 0 };
    overlay.addEventListener('touchstart', function(e) {
      if (e.touches.length === 2) {
        lbTouch.d = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      } else if (e.touches.length === 1 && lbScale > 1) {
        lbTouch.on = true; lbTouch.x = e.touches[0].clientX; lbTouch.y = e.touches[0].clientY; lbTouch.tx = lbTx; lbTouch.ty = lbTy;
      }
    }, { passive: true });
    overlay.addEventListener('touchmove', function(e) {
      if (e.touches.length === 2) {
        e.preventDefault();
        var d = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
        lbScale = Math.max(lbMin, Math.min(lbMax, lbScale * (d / lbTouch.d))); lbTouch.d = d;
        lbClamp(); lbTransform(false);
      } else if (e.touches.length === 1 && lbTouch.on) {
        lbTx = lbTouch.tx + (e.touches[0].clientX - lbTouch.x);
        lbTy = lbTouch.ty + (e.touches[0].clientY - lbTouch.y);
        lbClamp(); lbTransform(false);
      }
    }, { passive: false });
    overlay.addEventListener('touchend', function() { lbTouch.on = false; });

    document.addEventListener('keydown', function(e) {
      if (!overlay.classList.contains('is-open')) return;
      if (e.key === 'Escape') lbClose2();
      if (e.key === 'ArrowLeft'  && lbIndex > 0)               lbLoad(lbIndex - 1);
      if (e.key === 'ArrowRight' && lbIndex < lbSrcs.length - 1) lbLoad(lbIndex + 1);
      if (e.key === '+' && lbZoomIn)  lbZoomIn.click();
      if (e.key === '-' && lbZoomOut) lbZoomOut.click();
    });
  }

} // end init()

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% stylesheet %}
  .product-page {
    padding: 48px 48px;
    background-color: #efeee9;
    font-family: 'Montserrat', sans-serif;
    min-width: 0;
    overflow-anchor: none;
  }

  /* Breadcrumb */
  .product-page__breadcrumb {
    font-size: 0.8rem;
    color: #777;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .product-page__breadcrumb a { color: #777; text-decoration: none; }
  .product-page__breadcrumb a:hover { color: #d7116a; }
  .product-page__breadcrumb-sep { color: #bbb; }
  .product-page__breadcrumb--mobile { display: none; }


  /* Layout */
  .product-page__layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 96px;
    align-items: start;
    min-width: 0;
  }
  .product-page__gallery { min-width: 0; position: relative; }
  .product-page__info { min-width: 0; }

  /* Desktop: 2x2 grid */
  .product-page__images-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .product-page__image-item {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border-radius: 6px;
    background-color: #f5f2ed;
  }
  .product-page__image-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-page__image-item--placeholder svg { width: 100%; height: 100%; }

  /* Zoom */
  .js-zoom-item { cursor: crosshair; }

  /* Zoom result panel — fixed to viewport so nothing clips it */
  .zoom-result {
    display: none;
    position: fixed;
    width: 380px;
    height: 380px;
    border: 1px solid #e0d8cf;
    border-radius: 6px;
    background-repeat: no-repeat;
    background-color: #f5f2ed;
    box-shadow: 0 8px 32px rgba(0,0,0,0.14);
    z-index: 9999;
    pointer-events: none;
    overflow: hidden;
  }
  .zoom-result.is-visible { display: block; }

  /* Mobile carousel — hidden on desktop */
  .product-page__carousel { display: none; }

  /* Info panel */
  .product-page__info-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Mobile nav — hidden on desktop */
  .product-page__nav--mobile { display: none; }

  .product-page__title {
    font-size: 1.4rem !important;
    font-weight: 700 !important;
    color: #202020;
    line-height: 1.3;
  }
  .product-page__vendor {
    font-size: 0.85rem;
    color: #666;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .product-page__vendor:hover { color: #d7116a; }

  .product-page__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .product-page__price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #202020;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .product-page__price-compare {
    font-size: 1rem;
    font-weight: 400;
    color: #999;
    text-decoration: line-through;
  }

  /* Action row: ATC + Wishlist + Share */
.product-page__action-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .product-page__atc-btn--desktop {
    flex: 1;
  }
  .product-page__wishlist-icon-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1.5px solid #ddd;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .product-page__wishlist-icon-btn:hover {
    border-color: #d7116a;
  }

  /* Share dropdown */
  .product-page__share-dropdown {
    position: relative;
    flex-shrink: 0;
  }
  .product-page__share-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1.5px solid #ddd;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    color: #444;
    transition: border-color 0.2s, color 0.2s;
  }
  .product-page__share-icon-btn:hover {
    border-color: #d7116a;
    color: #d7116a;
  }
  .product-page__share-menu {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    min-width: 160px;
    z-index: 10;
    overflow: hidden;
  }
  .product-page__share-dropdown.is-open .product-page__share-menu {
    display: block;
  }
  .product-page__share-menu-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    font-size: 0.85rem;
    color: #333;
    text-decoration: none;
    transition: background 0.15s;
  }
  .product-page__share-menu-item:hover {
    background: #f5f2ed;
    color: #d7116a;
  }

  /* Variants */
  .product-page__variants { display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px; }
  .product-page__option-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 6px;
  }
  .product-page__option-values { display: flex; flex-wrap: wrap; gap: 8px; }
  .product-page__option-btn {
    padding: 6px 14px;
    border: 1.5px solid #ccc;
    border-radius: 4px;
    background: #fff;
    font-size: 0.85rem;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.2s, background 0.2s;
  }
  .product-page__option-btn:hover,
  .product-page__option-btn.is-selected {
    border-color: #d7116a;
    background: #d7116a;
    color: #fff;
  }

  /* ATC button */
  .product-page__atc-btn {
    width: 100%;
    padding: 14px 20px;
    background-color: #d7116a;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: background-color 0.2s;
  }
  .product-page__atc-btn:hover { background-color: #b80d58; }
  .product-page__atc-btn:disabled { background-color: #ccc; cursor: not-allowed; }

  .product-page__atc-btn.is-loading {
    background-color: #b80d58;
    cursor: wait;
    pointer-events: none;
    position: relative;
    color: transparent;
  }
  .product-page__atc-btn.is-loading::after {
    content: '';
    position: absolute;
    inset: 50% 50%;
    width: 18px;
    height: 18px;
    margin: -9px 0 0 -9px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: atc-spin 0.6s linear infinite;
  }
  @keyframes atc-spin {
    to { transform: rotate(360deg); }
  }

  /* Wishlist button */
  .product-page__wishlist-btn {
    display: block;
    width: 100%;
  }

  /* Pincode */
  .product-page__pincode-label {
    font-size: 0.82rem;
    color: #444;
    margin-bottom: 6px;
  }
  .product-page__pincode {
    display: flex;
    border: 1.5px solid #afafaf;
    border-radius: 4px;
    overflow: hidden;
  }
  .product-page__pincode-input {
    flex: 1;
    padding: 10px 14px;
    border: none;
    outline: none;
    font-size: 0.9rem;
    font-family: inherit;
    background: #fff;
  }
  .product-page__pincode-btn {
    padding: 10px 18px;
    background: transparent;
    color: #202020;
    border: none;
    border-left: 1.5px solid #afafaf;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    text-decoration: underline;
    transition: color 0.2s;
  }
  .product-page__pincode-btn:hover { color: #d7116a; }

  .product-page__pincode-btn.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .product-page__pincode-btn.is-loading .pincode-btn__label { display: none; }
  .pincode-btn__spinner { display: none; }
  .product-page__pincode-btn.is-loading .pincode-btn__spinner {
    display: inline-block;
    animation: pincode-spin 0.7s linear infinite;
  }

  @keyframes pincode-spin { to { transform: rotate(360deg); } }

  .product-page__pincode-result {
    margin-top: 8px;
    font-size: 0.8rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    min-height: 1.2em;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .product-page__pincode-result:empty { display: none; }

  .product-page__pincode-result.is-success { color: #1a7a3c; }
  .product-page__pincode-result.is-error   { color: #c0392b; }
  .product-page__pincode-result.is-warning { color: #b8620a; }

  .product-page__pincode-input.is-invalid {
    border-color: #c0392b;
    outline: none;
  }

  /* Reviews */
  .product-page__reviews {
    max-width: 1900px;
    margin: 0 auto;
    padding: 48px 80px 60px;
  }

  @media screen and (max-width: 767px) {
    .product-page__reviews {
      padding: 32px 16px 48px;
    }
  }

  /* Accordions */
  .product-page__accordions { border-top: 1px solid rgba(32,32,32,0.12); }
  .product-page__accordion { border-bottom: 1px solid rgba(32,32,32,0.12); }
  .product-page__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    font-size: 1rem;
    font-weight: 500;
    color: #202020;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .product-page__accordion-header::-webkit-details-marker { display: none; }
  .product-page__accordion-icon { transition: transform 0.2s; flex-shrink: 0; color: #666; }
  .product-page__accordion[open] .product-page__accordion-icon { transform: rotate(180deg); }
  .product-page__accordion-body {
    padding: 0 0 16px;
    font-size: 0.95rem;
    color: #444;
    line-height: 1.6;
  }
  .product-page__accordion-body a { color: #d7116a; text-decoration: underline; }

  /* Sticky mobile ATC — hidden on desktop */
  .product-page__sticky-atc { display: none; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .product-page {
      padding: 0 0 80px;
      background-color: #fff;
      margin-top: -32px;
    }

    /* Hide desktop elements */
    .product-page__breadcrumb--desktop { display: none; }
    .product-page__images-grid { display: none; }
    .product-page__atc-btn--desktop { display: none; }

    /* Layout: single column */
    .product-page__layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Carousel */
    .product-page__carousel {
      display: block;
      position: relative;
      width: 100%;
      overflow: hidden;
    }
    .product-page__carousel-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .product-page__carousel-track::-webkit-scrollbar { display: none; }
    .product-page__carousel-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
      aspect-ratio: 3 / 4;
    }
    .product-page__carousel-slide img,
    .product-page__carousel-slide svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Dot indicators */
    .product-page__dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 12px 0 4px;
    }
    .product-page__dot {
      width: 18px;
      height: 2px;
      border-radius: 9999px;
      border: none;
      background: #202020;
      opacity: 0.3;
      cursor: pointer;
      padding: 0;
      transition: opacity 0.2s, background 0.2s;
    }
    .product-page__dot.is-active {
      background: #800000;
      opacity: 1;
    }

    /* Info panel */
    .product-page__info { padding: 0; }
    .product-page__info-inner {
      padding: 20px 20px 0;
      gap: 12px;
      background-color: #fff;
    }

    /* Mobile nav */
    .product-page__nav--mobile {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .product-page__nav-btn {
      font-size: 0.85rem;
      font-weight: 500;
      color: #202020;
      text-decoration: none;
    }
    .product-page__nav-btn--disabled {
      opacity: 0.3;
      cursor: default;
    }

    /* Mobile breadcrumb */
    .product-page__breadcrumb--mobile {
      display: flex;
      margin-bottom: 0;
    }

    .product-page__title { font-size: 1.1rem !important; }

    .product-page__pincode-wrap { margin-top: 4px; }

    /* Sticky ATC bar */
    .product-page__sticky-atc {
      display: flex;
      align-items: center;
      gap: 8px;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: #fff;
      padding: 12px 16px;
      box-shadow: 0 -2px 12px rgba(0,0,0,0.1);
      z-index: 50;
    }
    .product-page__sticky-atc .product-page__atc-btn {
      flex: 1;
      border-radius: 4px;
    }
    .product-page__sticky-wishlist {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border: 1.5px solid #ddd;
      border-radius: 4px;
      background: #fff;
    }
    .product-page__share-dropdown--mobile {
      flex-shrink: 0;
    }
    .product-page__share-dropdown--mobile .product-page__share-menu {
      bottom: calc(100% + 8px);
      right: 0;
    }
  }
  /* Clickable image hint */
  .js-lb-open { cursor: zoom-in; }

  /* Lightbox overlay */
  .lb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 99999;
    align-items: center;
    justify-content: center;
  }
  .lb-overlay.is-open { display: flex; }

  /* Stage — clips the image during pan */
  .lb-stage {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb-img {
    display: block;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    transform-origin: center center;
    transition: transform 0.15s ease;
    user-select: none;
    -webkit-user-drag: none;
  }
  .lb-img.is-dragging { transition: none; cursor: grabbing; }
  .lb-img.is-zoomed   { cursor: grab; }

  /* Close */
  .lb-close {
    position: fixed;
    top: 20px;
    right: 20px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.15s;
  }
  .lb-close:hover { background: rgba(255,255,255,0.22); }

  /* Prev / Next */
  .lb-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.15s;
  }
  .lb-nav:hover { background: rgba(255,255,255,0.22); }
  .lb-nav--prev { left: 16px; }
  .lb-nav--next { right: 16px; }
  .lb-nav:disabled { opacity: 0.25; pointer-events: none; }

  /* Zoom controls */
  .lb-controls {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  .lb-ctrl-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }
  .lb-ctrl-btn:hover { background: rgba(255,255,255,0.25); }

  /* Counter */
  .lb-counter {
    position: fixed;
    bottom: 28px;
    right: 20px;
    color: rgba(255,255,255,0.6);
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    z-index: 2;
  }

{% endstylesheet %}


