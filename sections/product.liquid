  .product-page__price-tailoring-note {
    font-size: 0.75rem;
    font-weight: 500;
    color: #ce0570;
    letter-spacing: 0.02em;
  }

  /* Action row: ATC + Wishlist + Share */
.product-page__action-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .product-page__atc-btn--desktop {
    flex: 1;
  }

  /* Stitching button */
  .product-page__stitching-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    min-height: 56px;
    margin-bottom: 10px;
    padding: 0 16px;
    background: linear-gradient(135deg, #fdf6ee 0%, #f9ede0 100%);
    color: var(--color-primary, #2e1f1f);
    border: 1.5px solid #d4a97a;
    border-radius: 8px;
    font-family: 'Montserrat', sans-serif;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    text-align: left;
    position: relative;
    overflow: hidden;
  }
  .product-page__stitching-btn:hover {
    border-color: #ce0570;
    box-shadow: 0 2px 12px rgba(206,5,112,0.15);
    background: linear-gradient(135deg, #fff5fb 0%, #fde8f4 100%);
  }
  .product-page__stitching-btn svg {
    flex-shrink: 0;
    color: #ce0570;
  }
  .product-page__stitching-btn-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .product-page__stitching-btn-title {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #2e1f1f;
    line-height: 1.2;
  }
  .product-page__stitching-btn-sub {
    font-size: 0.7rem;
    font-weight: 400;
    color: #888;
    letter-spacing: 0.02em;
  }
  .product-page__stitching-btn-badge {
    flex-shrink: 0;
    background: #ce0570;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 20px;
