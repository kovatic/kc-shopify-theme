  }
  .product-page__wishlist-icon-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1.5px solid #ddd;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .product-page__wishlist-icon-btn:hover {
    border-color: #d7116a;
  }

  /* Share dropdown */
  .product-page__share-dropdown {
    position: relative;
    flex-shrink: 0;
  }
  .product-page__share-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1.5px solid #ddd;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    color: #444;
    transition: border-color 0.2s, color 0.2s;
  }
  .product-page__share-icon-btn:hover {
    border-color: #d7116a;
    color: #d7116a;
  }
  .product-page__share-menu {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    min-width: 160px;
    z-index: 200;
    overflow: hidden;
