    </form>
  {%- else -%}
    <span class="product-card__inline-oos">OOS</span>
  {%- endif -%}
</div>
                      </div>
                    </a>
                    {%- if is_available -%}
                      <form method="post" action="/cart/add" class="product-card-atc-form product-card-atc-form--mobile" style="display:none">
                        <input type="hidden" name="id" value="{{ fv.id }}">
