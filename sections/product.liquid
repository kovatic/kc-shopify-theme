{%- comment -%} Lightbox — placed outside .product-page so it doesn't affect layout {%- endcomment -%}
<div class="lb-overlay" id="lb-overlay-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb-close" id="lb-close-{{ section.id }}" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="24" height="24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="lb-nav lb-nav--prev" id="lb-prev-{{ section.id }}" aria-label="Previous image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="28" height="28"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <div class="lb-stage" id="lb-stage-{{ section.id }}">
    <img class="lb-img" id="lb-img-{{ section.id }}" src="" alt="">
  </div>
  <button class="lb-nav lb-nav--next" id="lb-next-{{ section.id }}" aria-label="Next image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="28" height="28"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="lb-controls">
    <button class="lb-ctrl-btn" id="lb-zoom-in-{{ section.id }}" aria-label="Zoom in">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button class="lb-ctrl-btn" id="lb-zoom-out-{{ section.id }}" aria-label="Zoom out">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button class="lb-ctrl-btn" id="lb-zoom-reset-{{ section.id }}" aria-label="Reset zoom">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M3.51 15a9 9 0 1 0 .49-3"/><polyline points="3 7 3 15 11 15"/></svg>
    </button>
  </div>
  <div class="lb-counter" id="lb-counter-{{ section.id }}"></div>
</div>

{%- comment -%} ── More from this category ───────────────────────────── {%- endcomment -%}
{%- assign current_collection = product.collections.first -%}
{%- if current_collection != blank -%}
  {%- assign shown = 0 -%}
  {%- for p in current_collection.products -%}{%- unless p.id == product.id -%}{%- assign shown = shown | plus: 1 -%}{%- endunless -%}{%- endfor -%}
  {%- if shown > 0 -%}
    <div class="pp-row product-list product-list-desktop--wrap product-list-mobile--wrap" style="--padding-top:48px;--padding-bottom:32px;">
      <div class="product-list__container">
        <div class="product-list__header">
          <div class="product-list__divider" aria-hidden="true">
            <span class="product-list__divider-line"></span>
            <span class="product-list__divider-diamond">✦</span>
            <span class="product-list__divider-line"></span>
          </div>
          <h2 class="product-list__title section-title">{{ 'sections.product.more_from_category' | t: category: current_collection.title }}</h2>
        </div>
        <div class="product-list__scroll-wrapper">
          <div class="product-list__grid" id="pp-cat-grid-{{ section.id }}">
            {%- assign cat_shown = 0 -%}
            {%- for p in current_collection.products -%}
              {%- unless p.id == product.id -%}
                {%- if cat_shown < 4 -%}
                  {%- assign cat_shown = cat_shown | plus: 1 -%}
                  {%- assign fv = p.first_available_variant | default: p.variants.first -%}
                  {%- assign is_available = p.available -%}
                  <div class="product-list__item{% unless is_available %} is-sold-out{% endunless %}" data-variant-id="{{ fv.id }}" data-available="{{ is_available }}">
                    <a class="product-list__item-link" href="{{ p.url }}">
                      <div class="product-list__image-wrapper">
                        {%- if p.featured_image -%}
                          {{ p.featured_image | image_url: width: 600 | image_tag: class: 'product-list__image', loading: 'lazy', alt: p.title | escape }}
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'product-list__image product-list__image--placeholder' }}
                        {%- endif -%}
                        <div class="product-card-actions">
                          <div class="product-card-actions__cart-wrap">
                            {%- if is_available -%}
                              <form method="post" action="/cart/add" class="product-card-atc-form">
                                <input type="hidden" name="id" value="{{ fv.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" name="add" class="product-card-actions__btn product-card-actions__btn--cart" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">
                                  <svg class="icon-cart" viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                  <svg class="icon-check" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                  <svg class="icon-spinner" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/></svg>
                                </button>
                              </form>
                              <span class="product-card-tooltip">{{ 'sections.product_list.add_to_cart' | t }}</span>
                            {%- else -%}
                              <span class="product-card-oos-label">{{ 'general.product.sold_out' | t }}</span>
                            {%- endif -%}
                          </div>
                          <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                            <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                          </button>
                        </div>
                        <div class="product-card-mobile-bar">
                          {%- if is_available -%}
                            <button type="button" class="product-card-mobile-bar__cart js-mobile-atc" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">{{- 'sections.product_list.add_to_cart' | t | upcase -}}</button>
                          {%- else -%}
                            <button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>{{ 'general.product.sold_out' | t | upcase }}</button>
                          {%- endif -%}
                          <button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">
                            <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/></svg>
                          </button>
                        </div>
                      </div>
