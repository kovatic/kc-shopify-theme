<script>
(function() {
  function debounce(fn, ms) {
    var t;
    return function() {
      var args = arguments;
      clearTimeout(t);
      t = setTimeout(function() { fn.apply(null, args); }, ms);
    };
  }
  
  var binBtns = document.querySelectorAll('.js-bin-btn');

  function throttleRaf(fn) {
    var rafId = null;
    return function() {
      var args = arguments;
      if (rafId) return;
      rafId = requestAnimationFrame(function() { rafId = null; fn.apply(null, args); });
    };
  }

  function init() {
  var page = document.querySelector('.product-page');
  if (!page) return;

  var productEl = document.getElementById('product-json-{{ section.id }}');
  var product = productEl ? JSON.parse(productEl.textContent) : null;
  var invEl = document.getElementById('product-inventory-{{ section.id }}');
  var inventoryMap = invEl ? JSON.parse(invEl.textContent) : {};
  if (!product) return;

  // ── Variant option buttons ───────────────────────────────────
  var optionBtns    = page.querySelectorAll('.product-page__option-btn');
  var variantInputs = document.querySelectorAll('#variant-id-input, #variant-id-input-mobile');
  var atcBtns       = document.querySelectorAll('.js-atc-btn');
  var binBtns       = document.querySelectorAll('.js-bin-btn');
  var priceEl       = page.querySelector('.product-page__price');

  function formatMoney(cents) {
    var fmt = window.shopMoneyFormat || 'Rs. {{amount}}';
    var val = cents / 100;
    var amt   = val.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    var amtNd = Math.floor(val).toLocaleString('en-IN');
    return fmt
      .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/, amtNd)
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, amt)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/, amtNd)
      .replace(/\{\{\s*amount\s*\}\}/, amt);
  }

  function getSelectedOptions() {
    var groups = {};
    optionBtns.forEach(function(btn) {
      if (btn.classList.contains('is-selected')) {
        groups[btn.getAttribute('data-option-index')] = btn.getAttribute('data-value');
      }
    });
    var opts = [];
    for (var i = 0; i < product.options.length; i++) {
      opts.push(groups[String(i)] || '');
    }
    return opts;
  }

  function findVariant(opts) {
    return product.variants.find(function(v) {
      return opts.every(function(opt, i) {
        return v['option' + (i + 1)] === opt;
      });
    });
  }

  var tailoringExtraRupees = 0;

  function renderPrice(variant) {
    if (!priceEl || !variant) return;
    
    var displayPrice = variant.price + Math.round(tailoringExtraRupees * 100);
    var comparePrice = variant.compare_at_price;
    var html = '';

   if (comparePrice && comparePrice > displayPrice) {
      html += '<span class="product-page__price-current is-on-sale">' + formatMoney(displayPrice) + '</span>';
    } else {
      html += '<span class="product-page__price-current">' + formatMoney(displayPrice) + '</span>';
    }

    
    // 1. Rebuild Original Strike Price Slant Element dynamically on variant change
    if (comparePrice && comparePrice > displayPrice) {
      html += '<span class="product-page__price-compare">' + formatMoney(comparePrice) + '</span> ';
    }
    
    // 2. Append Current Live Sale Price    
    // 3. Re-calculate and append the percentage discount badge on variant change
    if (comparePrice && comparePrice > displayPrice) {
      var savingsPercent = Math.round(((comparePrice - variant.price) / comparePrice) * 100);
      html += ' <span class="product-page__price-discount-badge">-' + savingsPercent + '%</span>';
    }
    
    // 4. Preserve Tailoring context warnings if custom options are engaged
    if (tailoringExtraRupees > 0) {
      html += '<div class="product-page__price-tailoring-note">{{ "tailoring.price_includes_stitching" | t }}</div>';
    }
    
    priceEl.innerHTML = html;
  }

  function updateVariant(variant) {
    if (!variant) return;
    // Update hidden id inputs in both forms
    variantInputs.forEach(function(input) { input.value = variant.id; });
    // Update URL without reload
    if (history.replaceState) {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      history.replaceState({}, '', url.toString());
    }
    renderPrice(variant);
    // Update ATC buttons availability
    var available = variant.available;
    var addLabel  = '{{ "sections.product_list.add_to_cart" | t }}';
    var soldLabel = '{{ "general.product.sold_out" | t }}';
    atcBtns.forEach(function(btn) {
      btn.disabled    = !available;
      btn.textContent = available ? addLabel : soldLabel;
    });
    // Update stock alert
    var stockAlert = document.getElementById('stock-alert');
    if (stockAlert) {
      var invData = inventoryMap[String(variant.id)] || {};
      var inv     = invData.qty;
      var managed = !!invData.managed;
      var criticalTpl = '{{ "product.stock.critical" | t: count: "__N__" }}';
      var lowTpl      = '{{ "product.stock.low" | t: count: "__N__" }}';
      stockAlert.className = 'product-page__stock-alert';
      stockAlert.innerHTML = '';
      stockAlert.removeAttribute('style');
      if (available && managed && typeof inv === 'number' && inv > 0 && inv <= 3) {
        stockAlert.classList.add('product-page__stock-alert--critical');
        stockAlert.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> ' + criticalTpl.replace('__N__', inv);
      } else if (available && managed && typeof inv === 'number' && inv > 0 && inv <= 10) {
        stockAlert.classList.add('product-page__stock-alert--low');
        stockAlert.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 9v4M12 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> ' + lowTpl.replace('__N__', inv);
      } else {
        stockAlert.style.display = 'none';
      }
    }
  }

  document.addEventListener('tailoring:total-change', function(e) {
    tailoringExtraRupees = e.detail.rupees;
    var opts = getSelectedOptions();
    var variant = findVariant(opts);
    if (!variant) {
      /* fall back to the currently selected variant id */
      var currentId = parseInt(document.getElementById('variant-id-input').value, 10);
      variant = product.variants.find(function(v) { return v.id === currentId; });
    }
    renderPrice(variant);
  });

  // ── AJAX Add to Cart (batched) ────────────────────────────────
  var atcPending = 0;
  var atcTimer   = null;

  function flushAtc(variantId) {
    var qty = atcPending;
    atcPending = 0;
    atcBtns.forEach(function(b) { b.classList.add('is-loading'); b.disabled = true; });
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function() { return fetch('/cart.js').then(function(r) { return r.json(); }); })
    .then(function(cart) {
      var drawer = document.querySelector('cart-drawer');
      if (drawer) { drawer.renderCart(cart); drawer.open(); }
    })
    .catch(function(err) { console.error('Cart error:', err); })
    .finally(function() {
      atcBtns.forEach(function(b) { b.classList.remove('is-loading'); b.disabled = false; });
    });
  }

  atcBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = document.getElementById('variant-id-input').value;
      if (!variantId) return;
      atcPending++;
      clearTimeout(atcTimer);
      atcTimer = setTimeout(function() { flushAtc(variantId); }, 400);
    });
  });

  // ── Direct Buy It Now execution ────────────────────────────
  binBtns.forEach(function(btn) {
  btn.addEventListener('click', function() {
    var isMobile = btn.closest('#sticky-atc') !== null;
    var inputId = isMobile ? 'variant-id-input-mobile' : 'variant-id-input';
    var variantId = document.getElementById(inputId).value;

    if (!variantId) return;

    btn.classList.add('is-loading');
    binBtns.forEach(function(b) { b.disabled = true; });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        id: parseInt(variantId),
        quantity: 1
      })
    })
    .then(function() {
      window.location.href = '/checkout';
    })
    .catch(function(err) {
      console.error('Checkout error:', err);

      // Remove loader if error
      btn.classList.remove('is-loading');
      binBtns.forEach(function(b) { b.disabled = false; });
    });
  });
});

window.addEventListener('pageshow', function(event) {
  document.querySelectorAll('.js-bin-btn').forEach(function(btn) {
    btn.classList.remove('is-loading');
    btn.disabled = false;
  });
});
  optionBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = btn.getAttribute('data-option-index');
      optionBtns.forEach(function(b) {
        if (b.getAttribute('data-option-index') === idx) b.classList.remove('is-selected');
      });
      btn.classList.add('is-selected');
      var variant = findVariant(getSelectedOptions());
      if (variant) updateVariant(variant);
    });
  });

  // ── Share dropdown ───────────────────────────────────────────
  document.querySelectorAll('.product-page__share-dropdown').forEach(function(dropdown) {
    var btn = dropdown.querySelector('.product-page__share-icon-btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('is-open');
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('.product-page__share-dropdown').forEach(function(d) {
      d.classList.remove('is-open');
    });
  });

  // ── Copy link ──────────────────────────────────────────────
  document.querySelectorAll('.js-copy-link').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var url = btn.dataset.url;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function() {
          var orig = btn.innerHTML;
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.innerHTML = orig; }, 2000);
        });
      }
    });
  });

  // ── Pincode checker ──────────────────────────────────────────
  var pincodeInput  = document.getElementById('pincode-input-{{ section.id }}');
  var pincodeBtn    = document.getElementById('pincode-btn-{{ section.id }}');
  var pincodeResult = document.getElementById('pincode-result-{{ section.id }}');

  function setPincodeResult(type, msg) {
    if (!pincodeResult) return;
    pincodeResult.className = 'product-page__pincode-result is-' + type;
    pincodeResult.textContent = msg;
  }

  function checkPincode() {
    var pin = pincodeInput.value.trim();
    if (!/^\d{6}$/.test(pin)) {
      pincodeInput.classList.add('is-invalid');
      setPincodeResult('error', '{{ "sections.product.pincode_invalid" | t | escape }}');
      return;
    }
    pincodeInput.classList.remove('is-invalid');
    pincodeResult.className = 'product-page__pincode-result';
    pincodeResult.textContent = '';
    pincodeBtn.classList.add('is-loading');
    fetch('https://api.postalpincode.in/pincode/' + pin)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        pincodeBtn.classList.remove('is-loading');
        var record = data && data[0];
        if (!record || record.Status === 'Error' || !record.PostOffice || !record.PostOffice.length) {
          setPincodeResult('error', '{{ "sections.product.pincode_not_serviceable" | t | escape }}');
          return;
        }
        var po = record.PostOffice[0];
        setPincodeResult('success', '{{ "sections.product.pincode_deliverable" | t | escape }}'.replace('__area__', po.Name + ', ' + po.District + ', ' + po.State));
      })
      .catch(function() {
        pincodeBtn.classList.remove('is-loading');
        setPincodeResult('warning', '{{ "sections.product.pincode_api_error" | t | escape }}');
      });
  }

  if (pincodeBtn) pincodeBtn.addEventListener('click', checkPincode);
  if (pincodeInput) {
    pincodeInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') checkPincode(); });
    pincodeInput.addEventListener('input', debounce(function() {
      pincodeInput.value = pincodeInput.value.replace(/\D/g, '');
      pincodeInput.classList.remove('is-invalid');
    }, 150));
  }

  // ── Image zoom (desktop) ─────────────────────────────────────
  var zoomResult = document.getElementById('zoom-result-{{ section.id }}');
  var zoomItems  = document.querySelectorAll('#zoom-grid-{{ section.id }} .js-zoom-item');
  var resultSize = 380;

  if (zoomResult && zoomItems.length) {
    function positionPanel(item) {
      var rect = item.getBoundingClientRect();
      var top  = rect.top;
      var left = rect.right + 12;
      if (left + resultSize > window.innerWidth - 8) left = rect.left - resultSize - 12;
      if (top + resultSize > window.innerHeight - 8) top = window.innerHeight - resultSize - 8;
      zoomResult.style.top  = top + 'px';
      zoomResult.style.left = left + 'px';
    }

    zoomItems.forEach(function(item) {
      var zoomSrc = item.getAttribute('data-zoom-src');
      var preloaded = false;

      item.addEventListener('mouseenter', function() {
        if (window.innerWidth < 992) return;
        if (!preloaded) { preloaded = true; (new Image()).src = zoomSrc; }
        zoomResult.style.backgroundImage = 'url(' + zoomSrc + ')';
        zoomResult.classList.add('is-visible');
        positionPanel(item);
      });
      item.addEventListener('mouseleave', function() {
        zoomResult.classList.remove('is-visible');
      });
      item.addEventListener('mousemove', throttleRaf(function(e) {
        if (window.innerWidth < 992) return;
        var rect = item.getBoundingClientRect();
        var x = Math.max(0, Math.min(rect.width,  e.clientX - rect.left));
        var y = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
        positionPanel(item);
        var factor = 3;
        zoomResult.style.backgroundSize     = (rect.width * factor) + 'px ' + (rect.height * factor) + 'px';
        zoomResult.style.backgroundPosition = '-' + (x * factor - resultSize / 2) + 'px -' + (y * factor - resultSize / 2) + 'px';
      }));
    });
  }

  // ── Mobile carousel dots ─────────────────────────────────────
  var track = document.getElementById('carousel-track');
  var dots  = page.querySelectorAll('.product-page__dot');
  if (track && dots.length) {
    track.addEventListener('scroll', throttleRaf(function() {
      var idx = Math.round(track.scrollLeft / track.offsetWidth);
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === idx); });
    }), { passive: true });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        track.scrollTo({ left: parseInt(dot.getAttribute('data-index')) * track.offsetWidth, behavior: 'smooth' });
      });
    });
  }

  // ── Lightbox ─────────────────────────────────────────────────
  var overlay   = document.getElementById('lb-overlay-{{ section.id }}');
  var lbImg     = document.getElementById('lb-img-{{ section.id }}');
  var lbClose   = document.getElementById('lb-close-{{ section.id }}');
  var lbPrev    = document.getElementById('lb-prev-{{ section.id }}');
  var lbNext    = document.getElementById('lb-next-{{ section.id }}');
  var lbZoomIn  = document.getElementById('lb-zoom-in-{{ section.id }}');
  var lbZoomOut = document.getElementById('lb-zoom-out-{{ section.id }}');
  var lbReset   = document.getElementById('lb-zoom-reset-{{ section.id }}');
  var lbCounter = document.getElementById('lb-counter-{{ section.id }}');

  if (overlay && lbImg) {
    var lbSrcs = [];
    var lbIndex = 0;
    var lbScale = 1, lbMin = 1, lbMax = 4, lbStep = 0.4;
    var lbTx = 0, lbTy = 0;

    function lbTransform(animate) {
      lbImg.style.transition = animate ? 'transform 0.2s ease' : 'none';
      lbImg.style.transform  = 'translate(' + lbTx + 'px,' + lbTy + 'px) scale(' + lbScale + ')';
      lbImg.classList.toggle('is-zoomed', lbScale > 1);
    }
    function lbClamp() {
      var mx = Math.max(0, (lbImg.offsetWidth  * lbScale - overlay.offsetWidth)  / 2);
      var my = Math.max(0, (lbImg.offsetHeight * lbScale - overlay.offsetHeight) / 2);
      lbTx = Math.max(-mx, Math.min(mx, lbTx));
      lbTy = Math.max(-my, Math.min(my, lbTy));
    }
    function lbReset2() { lbScale = 1; lbTx = 0; lbTy = 0; lbTransform(true); }
    function lbLoad(idx) {
      lbIndex = idx;
      lbScale = 1; lbTx = 0; lbTy = 0;
      lbImg.style.transform = 'none';
      lbImg.classList.remove('is-zoomed');
      lbImg.src = lbSrcs[idx];
      if (lbCounter) lbCounter.textContent = (idx + 1) + ' / ' + lbSrcs.length;
      if (lbPrev) lbPrev.disabled = idx === 0;
      if (lbNext) lbNext.disabled = idx === lbSrcs.length - 1;
    }
    function lbOpen(idx) {
      lbSrcs = [];
      document.querySelectorAll('#zoom-grid-{{ section.id }} .js-zoom-item').forEach(function(el) {
        lbSrcs.push(el.getAttribute('data-zoom-src'));
      });
      if (!lbSrcs.length) return;
      lbLoad(idx);
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function lbClose2() {
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
      lbReset2();
    }

    document.addEventListener('click', function(e) {
      var opener = e.target.closest('.js-lb-open');
      if (opener) { e.preventDefault(); lbOpen(parseInt(opener.getAttribute('data-lb-index') || '0')); }
    });
    lbClose.addEventListener('click', lbClose2);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) lbClose2(); });
    if (lbPrev) lbPrev.addEventListener('click', debounce(function() { if (lbIndex > 0) lbLoad(lbIndex - 1); }, 150));
    if (lbNext) lbNext.addEventListener('click', debounce(function() { if (lbIndex < lbSrcs.length - 1) lbLoad(lbIndex + 1); }, 150));
    if (lbZoomIn)  lbZoomIn.addEventListener('click',  debounce(function() { lbScale = Math.min(lbMax, lbScale + lbStep); lbClamp(); lbTransform(true); }, 100));
    if (lbZoomOut) lbZoomOut.addEventListener('click', debounce(function() { lbScale = Math.max(lbMin, lbScale - lbStep); if (lbScale === 1) { lbTx = 0; lbTy = 0; } lbClamp(); lbTransform(true); }, 100));
    if (lbReset)   lbReset.addEventListener('click', debounce(lbReset2, 150));

    overlay.addEventListener('wheel', throttleRaf(function(e) {
      e.preventDefault();
      lbScale = Math.max(lbMin, Math.min(lbMax, lbScale + (e.deltaY < 0 ? lbStep : -lbStep)));
      if (lbScale === 1) { lbTx = 0; lbTy = 0; }
      lbClamp(); lbTransform(false);
    }), { passive: false });

    var lbDrag = { on: false, x: 0, y: 0, tx: 0, ty: 0 };
    lbImg.addEventListener('mousedown', function(e) {
      if (lbScale <= 1) return;
      e.preventDefault();
      lbDrag.on = true; lbDrag.x = e.clientX; lbDrag.y = e.clientY; lbDrag.tx = lbTx; lbDrag.ty = lbTy;
      lbImg.classList.add('is-dragging');
    });
    window.addEventListener('mousemove', throttleRaf(function(e) {
      if (!lbDrag.on) return;
      lbTx = lbDrag.tx + (e.clientX - lbDrag.x);
      lbTy = lbDrag.ty + (e.clientY - lbDrag.y);
      lbClamp(); lbTransform(false);
    }));
    window.addEventListener('mouseup', function() {
      if (!lbDrag.on) return;
      lbDrag.on = false; lbImg.classList.remove('is-dragging');
    });

    var lbTouch = { d: 0, on: false, x: 0, y: 0, tx: 0, ty: 0 };
    overlay.addEventListener('touchstart', function(e) {
      if (e.touches.length === 2) {
        lbTouch.d = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      } else if (e.touches.length === 1 && lbScale > 1) {
        lbTouch.on = true; lbTouch.x = e.touches[0].clientX; lbTouch.y = e.touches[0].clientY; lbTouch.tx = lbTx; lbTouch.ty = lbTy;
      }
    }, { passive: true });
    overlay.addEventListener('touchmove', function(e) {
      if (e.touches.length === 2) {
        e.preventDefault();
        var d = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
        lbScale = Math.max(lbMin, Math.min(lbMax, lbScale * (d / lbTouch.d))); lbTouch.d = d;
        lbClamp(); lbTransform(false);
      } else if (e.touches.length === 1 && lbTouch.on) {
        lbTx = lbTouch.tx + (e.touches[0].clientX - lbTouch.x);
        lbTy = lbTouch.ty + (e.touches[0].clientY - lbTouch.y);
        lbClamp(); lbTransform(false);
      }
    }, { passive: false });
    overlay.addEventListener('touchend', function() { lbTouch.on = false; });

    document.addEventListener('keydown', function(e) {
      if (!overlay.classList.contains('is-open')) return;
      if (e.key === 'Escape') lbClose2();
      if (e.key === 'ArrowLeft'  && lbIndex > 0)               lbLoad(lbIndex - 1);
      if (e.key === 'ArrowRight' && lbIndex < lbSrcs.length - 1) lbLoad(lbIndex + 1);
      if (e.key === '+' && lbZoomIn)  lbZoomIn.click();
      if (e.key === '-' && lbZoomOut) lbZoomOut.click();
    });
  }

  // ── Shared helpers ───────────────────────────────────────────
  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function formatMoney(cents) {
    var fmt = window.shopMoneyFormat || 'Rs. {{amount}}';
    var val = cents / 100;
    var amt   = val.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    var amtNd = Math.floor(val).toLocaleString('en-IN');
    return fmt
      .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/, amtNd)
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, amt)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/, amtNd)
      .replace(/\{\{\s*amount\s*\}\}/, amt);
  }
  var soldOutLabel = '{{ "general.product.sold_out" | t | escape }}';
  var atcLabel     = '{{ "sections.product_list.add_to_cart" | t | escape }}';

  function buildCard(p) {
    var fv       = p.variants && p.variants[0];
    var varId    = fv ? fv.id : '';
    var available = p.available;
    var imgSrc   = p.images && p.images[0]
      ? (p.images[0].src.indexOf('cdn.shopify') !== -1
          ? p.images[0].src  // already a sized CDN URL (recently viewed)
          : p.images[0].src.replace(/(\.\w+)(\?|$)/, '_600x$1$2'))
      : '';
    var img = imgSrc
      ? '<img class="product-list__image" src="' + imgSrc + '" alt="' + escHtml(p.title) + '" loading="lazy">'
      : '<div class="product-list__image product-list__image--placeholder"></div>';

    var cartBtn = available
      ? '<form method="post" action="/cart/add" class="product-card-atc-form">'
        + '<input type="hidden" name="id" value="' + varId + '">'
        + '<input type="hidden" name="quantity" value="1">'
        + '<button type="submit" name="add" class="product-card-actions__btn product-card-actions__btn--cart" aria-label="' + atcLabel + '">'
        + '<svg class="icon-cart" viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>'
        + '<svg class="icon-check" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>'
        + '<svg class="icon-spinner" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/></svg>'
        + '</button></form>'
        + '<span class="product-card-tooltip">' + atcLabel + '</span>'
      : '<span class="product-card-oos-label">' + soldOutLabel + '</span>';

    var mobileBar = available
      ? '<button type="button" class="product-card-mobile-bar__cart js-mobile-atc">' + atcLabel.toUpperCase() + '</button>'
      : '<button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>' + soldOutLabel.toUpperCase() + '</button>';

    var hiddenForm = available
      ? '<form method="post" action="/cart/add" class="product-card-atc-form product-card-atc-form--mobile" style="display:none">'
        + '<input type="hidden" name="id" value="' + varId + '">'
        + '<input type="hidden" name="quantity" value="1">'
        + '<button type="submit" name="add" class="product-card-atc-form--mobile-submit"></button>'
        + '</form>'
      : '';
    var inlineActionHtml = '';
  if (available) {
    inlineActionHtml = '<div class="product-card__inline-form-container">'
      + '<button type="button" class="product-card__inline-atc-btn js-grid-inline-atc-trigger" data-variant-id="' + varId + '">'
      + '<span class="inline-atc-btn__text">'
      + '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" style="display: inline-block; vertical-align: middle; margin-right: 2px;"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round"/><path d="M16 10a4 4 0 01-8 0" stroke-linecap="round" stroke-linejoin="round"/></svg> '
      + 'Add</span>'
      + '<svg class="inline-atc-btn__spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none; width:14px; height:14px; color:#ffffff;"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="24 48"/></svg>'
      + '</button></div>';
  } else {
    inlineActionHtml = '<span class="product-card__inline-oos">OOS</span>';
  }
    var priceHtml = '';
    var priceVal = p.price || p.price_min || (fv ? fv.price : 0);
    var compareVal = p.compare_at_price || p.compare_at_price_min || (fv ? fv.compare_at_price : 0);
    if (compareVal && compareVal > priceVal) {
      // Both prices rendered side-by-side on a single row layout
      priceHtml = '<div class="product-grid__price-meta-row" style="display: flex !important; align-items: center !important; gap: 8px !important; flex-wrap: nowrap !important;">'
        + '<span class="product-page__price-current grid is-on-sale">' + formatMoney(priceVal) + '</span>'
        + '<span class="product-page__price-compare">' + formatMoney(compareVal) + '</span>'
        + '</div>';
    } else {
      // Normal price fallback configuration if no markdown exists
      priceHtml = '<div class="product-grid__price-meta-row">'
        + '<span class="product-page__price-current grid">' + formatMoney(priceVal) + '</span>'
        + '</div>';
    }
    return '<div class="product-list__item' + (available ? '' : ' is-sold-out') + '" data-variant-id="' + varId + '" data-available="' + available + '">'
      + '<a class="product-list__item-link" href="' + p.url + '">'
      + '<div class="product-list__image-wrapper">'
      + img
      + '<div class="product-card-actions">'
      + '<div class="product-card-actions__cart-wrap">' + cartBtn + '</div>'
      + '<button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">'
      + '<svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>'
      + '</button></div>'
      + '<div class="product-card-mobile-bar">' + mobileBar
      + '<button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">'
      + '<svg viewBox="0 0 24 24" fill="none" width="20" height="20"><rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/></svg>'
      + '</button></div>'
      + '</div>'
      + '<div class="product-list__info">'
      + '<span class="product-list__name">' + escHtml(p.title) + '</span>'
      + '<div class="product-card__price-atc-wrapper">'
      // + '<span class="product-list__price">' + formatMoney(p.price_min || (fv ? fv.price : 0)) + '</span>'
      + priceHtml
      + inlineActionHtml
      + '</div>'
      + '</div></a>'
      + hiddenForm
      + '</div>';
  }
  // Handle click animations for elements generated dynamically by JavaScript loops
  document.addEventListener('submit', function(e) {
    var form = e.target.closest('.product-card__inline-form');
    if (form) {
      var btn = form.querySelector('.js-inline-atc-submit');
      if (btn) {
        btn.classList.add('is-loading');
        // Fallback safety timeout if side drawer tracking event drops out
        setTimeout(function() {
          btn.classList.remove('is-loading');
        }, 1200);
      }
    }
  });
  // ── 🆕 Dynamic Inline ATC Click Handler ────────────────────────────
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.js-grid-inline-atc-trigger');
    if (!btn) return;
    
    e.preventDefault();
    e.stopPropagation();
    
    var variantId = btn.getAttribute('data-variant-id');
    if (!variantId) return;

    // Turn on your loading spinner animation
    btn.classList.add('is-loading');

    // Send the product data asynchronously to your Shopify Cart database
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() { return fetch('/cart.js').then(function(r) { return r.json(); }); })
    .then(function(cart) {
      // Trigger and open your side slide popup cart drawer layout framework
      var drawer = document.querySelector('cart-drawer');
      if (drawer) { 
        drawer.renderCart(cart); 
        drawer.open(); 
      }
      
      // Update the button appearance to "Added" state if your theme handles it
      btn.classList.remove('is-loading');
    })
    .catch(function(err) { 
      console.error('Dynamic Grid ATC submit error:', err); 
      btn.classList.remove('is-loading');
    });
  });
  // ── You may also like (Shopify recommendations API) ──────────
  var recoSection = document.getElementById('pp-recommendations-{{ section.id }}');
  var recoTrack   = document.getElementById('pp-recommendations-track-{{ section.id }}');
  if (recoSection && recoTrack) {
    fetch('/recommendations/products.json?product_id={{ product.id }}&limit=4&intent=related')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var products = data && data.products;
        if (!products || !products.length) return;
        recoTrack.innerHTML = products.slice(0, 4).map(buildCard).join('');
        recoSection.style.display = '';
      })
      .catch(function() {});
  }

  // ── Recently viewed ──────────────────────────────────────────
  var rvSection = document.getElementById('pp-recently-viewed-{{ section.id }}');
  var rvTrack   = document.getElementById('pp-recently-viewed-track-{{ section.id }}');

  var RV_KEY = 'pp_recently_viewed';
  var RV_MAX = 10;
  var currentHandle = '{{ product.handle }}';
  // var currentEntry  = {
  //   handle:    currentHandle,
  //   title:     '{{ product.title | escape }}',
  //   url:       '{{ product.url }}',
  //   available: {{ product.available }},
  //   variants:  [{ id: {{ current_variant.id }}, price: {{ current_variant.price }} }],
  //   images:    [{ src: '{{ product.featured_image | image_url: width: 600 }}' }]
  // };
  var currentEntry  = {
    handle:    currentHandle,
    title:     '{{ product.title | escape }}',
    url:       '{{ product.url }}',
    available: {{ product.available }},
    price:     {{ current_variant.price }},
    price_min: {{ product.price_min | default: current_variant.price }},
    compare_at_price: {{ current_variant.compare_at_price | default: 0 }},
    compare_at_price_min: {{ product.compare_at_price_min | default: 0 }},
    variants:  [{ 
      id: {{ current_variant.id }}, 
      price: {{ current_variant.price }},
      compare_at_price: {{ current_variant.compare_at_price | default: 0 }} 
    }],
    images:    [{ src: '{{ product.featured_image | image_url: width: 600 }}' }]
  };

  var rvList = [];
  try { rvList = JSON.parse(localStorage.getItem(RV_KEY) || '[]'); } catch(e) {}
  rvList = rvList.filter(function(p) { return p.handle !== currentHandle; });
  rvList.unshift(currentEntry);
  if (rvList.length > RV_MAX) rvList = rvList.slice(0, RV_MAX);
  try { localStorage.setItem(RV_KEY, JSON.stringify(rvList)); } catch(e) {}

  if (rvSection && rvTrack) {
    var toShow = rvList.filter(function(p) { return p.handle !== currentHandle; }).slice(0, 4);
    if (toShow.length) {
      rvTrack.innerHTML = toShow.map(buildCard).join('');
      rvSection.style.display = '';
    }
  }

} // end init()

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* ── Tailoring modal trigger ── */
  document.querySelectorAll('.js-tailoring-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (window.openTailoringModal) window.openTailoringModal();
    });
  });
})();
document.addEventListener('DOMContentLoaded', function() {
  var pinField     = document.getElementById('kc-pincode-field');
  var submitBtn    = document.getElementById('kc-pincode-submit-btn');
  var btnText      = submitBtn.querySelector('.btn-text-label');
  var btnSpinner   = submitBtn.querySelector('.btn-spinner-icon');
  var resPanel     = document.getElementById('kc-pincode-response-panel');
  var errPanel     = document.getElementById('kc-pincode-error-panel');
  var errText      = document.getElementById('kc-error-message-text');
  var regSlot      = document.getElementById('date-regular-slot');
  var custSlot     = document.getElementById('date-custom-slot');
  var inputBoxWrap = document.querySelector('.premium-pincode-input-box');

  function calculateTargetDates() {
    var today = new Date();
    
    function addCalendarDays(baseDate, daysToAdd) {
      var tmpDate = new Date(baseDate.getTime());
      tmpDate.setDate(tmpDate.getDate() + daysToAdd);
      return tmpDate;
    }
    if (regSlot) {
      var regularDeliveryDate = addCalendarDays(today, 6);
      regSlot.textContent = regularDeliveryDate.toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short' });
    }

    if (custSlot) {
      var customDeliveryDate = addCalendarDays(today, 12);
      custSlot.textContent = customDeliveryDate.toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short' });
    }
  }

  function triggerRevealPanel() {
    resPanel.style.display = 'block';
    setTimeout(function() {
      resPanel.classList.add('reveal-slide');
    }, 15);
  }

  function showSuccessLayout(savedPin) {
    errPanel.style.display = 'none';
    pinField.value = savedPin;
    inputBoxWrap.classList.add('is-verified');
    submitBtn.classList.add('is-active-change');
    btnText.textContent = 'Change';
    calculateTargetDates();
    triggerRevealPanel();
  }

  function clearCachedSession() {
    localStorage.removeItem('kc_customer_pincode');
    pinField.value = '';
    inputBoxWrap.classList.remove('is-verified');
    submitBtn.classList.remove('is-active-change');
    btnText.textContent = 'Check';
    resPanel.classList.remove('reveal-slide');
    setTimeout(function() {
      resPanel.style.display = 'none';
    }, 450);
    pinField.focus();
  }

  var cachedPincode = localStorage.getItem('kc_customer_pincode');
  if (cachedPincode && /^\d{6}$/.test(cachedPincode)) {
    showSuccessLayout(cachedPincode);
  }

  function processValidation() {
    if (btnText.textContent === 'Change') {
      clearCachedSession();
      return;
    }

    var rawInput = pinField.value.trim();

    if (!/^\d{6}$/.test(rawInput)) {
      resPanel.classList.remove('reveal-slide');
      resPanel.style.display = 'none';
      errText.textContent = 'Please enter a valid 6-digit numeric PIN code.';
      errPanel.style.display = 'flex';
      pinField.focus();
      return;
    }

    errPanel.style.display = 'none';
    btnText.style.display = 'none';
    btnSpinner.style.display = 'inline-block';
    submitBtn.style.pointerEvents = 'none';

    fetch('https://api.postalpincode.in/pincode/' + rawInput)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btnSpinner.style.display = 'none';
        btnText.style.display = 'inline-block';
        submitBtn.style.pointerEvents = 'auto';

        var record = data && data[0];
        if (!record || record.Status === 'Error' || !record.PostOffice || !record.PostOffice.length) {
          resPanel.classList.remove('reveal-slide');
          resPanel.style.display = 'none';
          errText.textContent = 'This PIN code is not serviceable inside India.';
          errPanel.style.display = 'flex';
          return;
        }

        localStorage.setItem('kc_customer_pincode', rawInput);
        showSuccessLayout(rawInput);
      })
      .catch(function() {
        btnSpinner.style.display = 'none';
        btnText.style.display = 'inline-block';
        submitBtn.style.pointerEvents = 'auto';
        resPanel.classList.remove('reveal-slide');
        resPanel.style.display = 'none';
        errText.textContent = 'Postal validation service is temporarily unreachable.';
        errPanel.style.display = 'flex';
      });
  }

  submitBtn.addEventListener('click', processValidation);
  pinField.addEventListener('keydown', function(e) { if (e.key === 'Enter') processValidation(); });
  pinField.addEventListener('input', function() {
    pinField.value = pinField.value.replace(/\D/g, '');
    errPanel.style.display = 'none';
  });
});
</script>

{% stylesheet %}
  .product-page {
    padding: 48px 48px;
    background-color: #efeee9;
    font-family: 'Montserrat', sans-serif;
    min-width: 0;
    overflow-anchor: none;
  }

  /* Breadcrumb */
  .product-page__breadcrumb {
    font-size: 0.8rem;
    color: #777;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .product-page__breadcrumb a { color: #777; text-decoration: none; }
  .product-page__breadcrumb a:hover { color: #d7116a; }
  .product-page__breadcrumb-sep { color: #bbb; }
  .product-page__breadcrumb--mobile { display: none; }


  /* Layout */
  .product-page__layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 96px;
    align-items: start;
    min-width: 0;
  }
  .product-page__gallery { min-width: 0; position: relative; }
  /* .product-page__info {
    min-width: 0;
    align-self: start;
    position: sticky;
    top: 160px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    scrollbar-width: none;
  } */
   .product-page__info {
  min-width: 0;
  align-self: start;
  position: relative !important;
  top: 0 !important;
  max-height: none !important;
  overflow-y: visible !important;
}
  .product-page__info::-webkit-scrollbar { display: none; }

  /* Desktop: 2x2 grid */
  .product-page__images-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .product-page__image-item {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border-radius: 6px;
    background-color: #f5f2ed;
  }
  .product-page__image-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-page__image-item--placeholder svg { width: 100%; height: 100%; }

  /* Zoom */
  .js-zoom-item { cursor: crosshair; }

  /* Zoom result panel — fixed to viewport so nothing clips it */
  .zoom-result {
    display: none;
    position: fixed;
    width: 380px;
    height: 380px;
    border: 1px solid #e0d8cf;
    border-radius: 6px;
    background-repeat: no-repeat;
    background-color: #f5f2ed;
    box-shadow: 0 8px 32px rgba(0,0,0,0.14);
    z-index: 9999;
    pointer-events: none;
    overflow: hidden;
  }
  .zoom-result.is-visible { display: block; }

  /* Mobile carousel — hidden on desktop */
  .product-page__carousel { display: none; }

  /* Info panel */
  .product-page__info-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Mobile nav — hidden on desktop */
  .product-page__nav--mobile { display: none; }

  .product-page__title {
