<div
  class="stores"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="stores__container">

    <div class="stores__header">
      <div class="stores__divider" aria-hidden="true">
        <span class="stores__divider-line"></span>
        <span class="stores__divider-diamond">✦</span>
        <span class="stores__divider-line"></span>
      </div>
      {%- if section.settings.title != blank -%}
        <h2 class="stores__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="stores__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="stores__panels">

        {%- for block in section.blocks -%}
          <div
            class="stores__panel{% if forloop.first %} is-active{% endif %}"
            tabindex="0"
            role="button"
            aria-label="{{ block.settings.store_name | escape }}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%} Background image {%- endcomment -%}
            <div class="stores__panel-media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1400 | image_tag:
                  class: 'stores__panel-image',
                  loading: forloop.first | default: 'lazy',
                  alt: block.settings.store_name | escape
                }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'stores__panel-image stores__panel-image--placeholder' }}
              {%- endif -%}
            </div>

            <div class="stores__panel-gradient" aria-hidden="true"></div>

            {%- comment -%} Collapsed label (always visible) {%- endcomment -%}
            <div class="stores__panel-collapsed">
              {%- if block.settings.store_type != blank -%}
                <span class="stores__panel-type">{{ block.settings.store_type | upcase | escape }}</span>
              {%- endif -%}
              {%- if block.settings.store_name != blank -%}
                <span class="stores__panel-name-sm">{{ block.settings.store_name | escape }}</span>
              {%- endif -%}
            </div>

            {%- comment -%} Expanded info (visible when active) {%- endcomment -%}
            <div class="stores__panel-expanded">
              {%- if block.settings.store_type != blank -%}
                <span class="stores__panel-type-lg">{{ block.settings.store_type | upcase | escape }}</span>
              {%- endif -%}
              {%- if block.settings.store_name != blank -%}
                <h3 class="stores__panel-name-lg">{{ block.settings.store_name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <p class="stores__panel-address">{{ block.settings.address | escape }}</p>
              {%- endif -%}
              <div class="stores__panel-actions">
                {%- if block.settings.phone != blank -%}
                  <a class="stores__action-btn stores__action-btn--gold" href="tel:{{ block.settings.phone | remove: ' ' }}">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M11 8.5a1 1 0 0 1-.21.63 1.7 1.7 0 0 1-.44.47C9.93 9.87 9.5 10 9 10c-.63 0-1.3-.15-2-.46s-1.4-.75-2.1-1.33A15.1 15.1 0 0 1 3 6.1C2.42 5.4 1.97 4.7 1.66 4S1.2 2.63 1.2 2c0-.47.1-.9.3-1.27.2-.38.5-.72.9-1.01.48-.33.99-.5 1.47-.47.18 0 .37.04.53.12.17.08.32.2.44.38L5.9 2.2c.12.17.2.33.27.48.06.15.1.28.1.4 0 .16-.05.31-.14.46a2.2 2.2 0 0 1-.37.45l-.5.52a.33.33 0 0 0-.1.25c0 .06.01.11.03.16l.06.14c.12.22.32.5.6.84.29.34.6.68.93 1.01.33.33.65.63.97.9.34.27.62.46.85.56l.14.05c.04.01.09.02.14.02a.35.35 0 0 0 .26-.11l.5-.51c.14-.14.28-.24.41-.3.14-.07.27-.1.41-.1.12 0 .25.02.39.08.14.05.28.13.43.24l2.06 1.47c.18.12.3.27.37.44.07.17.1.35.1.55Z" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                    {{ 'sections.stores.call' | t }}
                  </a>
                {%- endif -%}
                {%- if block.settings.map_url != blank -%}
                  <a class="stores__action-btn stores__action-btn--outline" href="{{ block.settings.map_url }}" target="_blank" rel="noopener">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M6 1C4.067 1 2.5 2.567 2.5 4.5C2.5 7.5 6 11 6 11C6 11 9.5 7.5 9.5 4.5C9.5 2.567 7.933 1 6 1Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="6" cy="4.5" r="1.25" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                    {{ 'sections.stores.map' | t }}
                  </a>
                {%- endif -%}
              </div>
            </div>

          </div>
        {%- endfor -%}

      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .stores {
    background-color: #f1eee9;
    width: 100%;
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 60px);
  }

  .stores__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 52px;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  /* Header */
  .stores__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .stores__divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 4px;
  }

  .stores__divider-line {
    display: block;
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, rgba(198,146,57,0) 0%, #c69239 50%, rgba(198,146,57,0) 100%);
  }

  .stores__divider-diamond {
    color: #c69239;
    font-size: 18px;
    line-height: 1;
  }

  .stores__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 48px;
    font-weight: 700;
    color: #2e1f1f;
    text-align: center;
    margin: 0;
    line-height: 1;
  }

  .stores__subtitle {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 18px;
    font-weight: 400;
    color: #7e6767;
    text-align: center;
    margin: 0;
    line-height: 1.55;
  }

  /* Panels row */
  .stores__panels {
    display: flex;
    height: 616px;
    gap: 0;
    overflow: hidden;
    border-radius: 4px;
  }

  /* Each panel */
  .stores__panel {
    position: relative;
    flex: 1;
    overflow: hidden;
    cursor: pointer;
    outline: none;
    transition: flex 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Expanded state — hovered or first by default */
  .stores__panel.is-active,
  .stores__panels:hover .stores__panel:hover {
    flex: 4;
  }

  /* When any panel is hovered, collapse the default active */
  .stores__panels:hover .stores__panel.is-active:not(:hover) {
    flex: 1;
  }

  /* Image */
  .stores__panel-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .stores__panel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.55s ease, transform 0.55s ease;
  }

  .stores__panel-image--placeholder {
    width: 100%;
    height: 100%;
    display: block;
    filter: grayscale(100%);
  }

  .stores__panel.is-active .stores__panel-image,
  .stores__panels:hover .stores__panel:hover .stores__panel-image {
    filter: grayscale(0%);
    transform: scale(1.03);
  }

  .stores__panels:hover .stores__panel.is-active:not(:hover) .stores__panel-image {
    filter: grayscale(100%);
    transform: scale(1);
  }

  /* Gradient overlay */
  .stores__panel-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(44,36,33,0.82) 0%, rgba(44,36,33,0.1) 55%, rgba(44,36,33,0) 100%);
    pointer-events: none;
  }

  /* Collapsed info — always visible at bottom */
  .stores__panel-collapsed {
    position: absolute;
    bottom: 20px;
    left: 16px;
    right: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .stores__panel.is-active .stores__panel-collapsed,
  .stores__panels:hover .stores__panel:hover .stores__panel-collapsed {
    opacity: 0;
    pointer-events: none;
  }

  .stores__panels:hover .stores__panel.is-active:not(:hover) .stores__panel-collapsed {
    opacity: 1;
    pointer-events: auto;
  }

  .stores__panel-type {
    font-family: var(--font-body-family, 'Lato', sans-serif);
    font-size: 9px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 1.5px;
    line-height: 1.5;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stores__panel-name-sm {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Expanded info — visible only when active */
  .stores__panel-expanded {
    position: absolute;
    bottom: 30px;
    left: 30px;
    right: 30px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.35s ease 0.15s, transform 0.35s ease 0.15s;
  }

  .stores__panel.is-active .stores__panel-expanded,
  .stores__panels:hover .stores__panel:hover .stores__panel-expanded {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .stores__panels:hover .stores__panel.is-active:not(:hover) .stores__panel-expanded {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  .stores__panel-type-lg {
    font-family: var(--font-body-family, 'Lato', sans-serif);
    font-size: 10px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 2px;
    line-height: 1.5;
    display: block;
  }

  .stores__panel-name-lg {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 36px;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 1;
    white-space: nowrap;
  }

  .stores__panel-address {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 12px;
    font-weight: 400;
    color: rgba(255,255,255,0.8);
    margin: 0;
    line-height: 1.4;
  }

  .stores__panel-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .stores__action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    font-family: var(--font-body-family, 'Lato', sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .stores__action-btn--gold {
    background: linear-gradient(135deg, #d99d26 0%, #dbb870 100%);
    color: #1f1414;
  }

  .stores__action-btn--outline {
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(255,255,255,0.35);
  }

  .stores__action-btn:hover {
    opacity: 0.82;
  }

  /* Mobile: vertical stack, tap to expand */
  @media screen and (max-width: 768px) {
    .stores__container {
      padding: 0 20px;
      gap: 32px;
    }

    .stores__title {
      font-size: 30px;
    }

    .stores__subtitle {
      font-size: 15px;
    }

    .stores__divider-line {
      width: 60px;
    }

    .stores__panels {
      flex-direction: column;
      height: auto;
    }

    .stores__panel {
      height: 80px;
      flex: none;
      transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .stores__panel.is-active {
      height: 380px;
      flex: none;
    }

    .stores__panels:hover .stores__panel:hover {
      height: 380px;
    }

    .stores__panels:hover .stores__panel.is-active:not(:hover) {
      height: 80px;
    }

    .stores__panel-name-lg {
      font-size: 28px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    /* Touch support: tap to set is-active on mobile */
    var panels = document.querySelectorAll('.stores__panel');
    panels.forEach(function (panel) {
      panel.addEventListener('click', function () {
        var siblings = panel.closest('.stores__panels').querySelectorAll('.stores__panel');
        siblings.forEach(function (s) { s.classList.remove('is-active'); });
        panel.classList.add('is-active');
      });
      panel.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          panel.click();
        }
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.stores.name",
  "blocks": [
    {
      "type": "store",
      "name": "t:sections.stores.blocks.store.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "store_type",
          "label": "t:sections.stores.store_type",
          "default": "Flagship Store"
        },
        {
          "type": "text",
          "id": "store_name",
          "label": "t:labels.title",
          "default": "Store Name"
        },
        {
          "type": "text",
          "id": "address",
          "label": "t:sections.stores.address",
          "default": "Store address"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "t:sections.stores.phone"
        },
        {
          "type": "url",
          "id": "map_url",
          "label": "t:sections.stores.map_url"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Visit Our Stores"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:labels.subtitle",
      "default": "4 locations across Tamil Nadu & Chennai"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.stores.name",
      "blocks": [
        { "type": "store" },
        { "type": "store" },
        { "type": "store" },
        { "type": "store" }
      ]
    }
  ]
}
{% endschema %}
