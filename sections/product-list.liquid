<div class="product-list product-list-desktop--{{ section.settings.layout_type_desktop }} product-list-mobile--{{ section.settings.layout_type_mobile }}" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="product-list__container">

    <div class="product-list__header">
      <div class="product-list__divider" aria-hidden="true">
        <span class="product-list__divider-line"></span>
        <span class="product-list__divider-diamond">✦</span>
        <span class="product-list__divider-line"></span>
      </div>

      {%- if section.settings.title != blank -%}
        <h2 class="product-list__title section-title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="product-list__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    <div class="product-list__scroll-wrapper">
      <div class="product-list__grid" id="product-list-grid-{{ section.id }}">
        {%- for product in section.settings.collection.products limit: section.settings.products_count -%}
          {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
          {%- assign is_available = product.available -%}
          <div class="product-list__item{% unless is_available %} is-sold-out{% endunless %}" data-variant-id="{{ first_variant.id }}" data-available="{{ is_available }}">
            <a class="product-list__item-link" href="{{ product.url }}">
              <div class="product-list__image-wrapper">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600, height: 700, crop: 'center' | image_tag: class: 'product-list__image', loading: 'lazy', alt: product.title | escape }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-list__image product-list__image--placeholder' }}
                {%- endif -%}
              </div>
              <div class="product-list__info">
                <span class="product-list__name">{{ product.title | escape }}</span>
                <span class="product-list__price">{{ product.price | money }}</span>
              </div>
            </a>

            <div class="product-card-actions">
              <div class="product-card-actions__cart-wrap">
                {%- if is_available -%}
                  <form method="post" action="/cart/add" class="product-card-atc-form">
                    <input type="hidden" name="id" value="{{ first_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" name="add" class="product-card-actions__btn product-card-actions__btn--cart" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">
                      <svg class="icon-cart" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <svg class="icon-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <svg class="icon-spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/>
                      </svg>
                    </button>
                  </form>
                  <span class="product-card-tooltip">{{ 'sections.product_list.add_to_cart' | t }}</span>
                {%- else -%}
                  <span class="product-card-oos-label">Out of stock</span>
                {%- endif -%}
              </div>
              <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/>
                  <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  <path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                </svg>
              </button>
            </div>

            <div class="product-card-mobile-bar">
              {%- if is_available -%}
                <form method="post" action="/cart/add" class="product-card-atc-form product-card-atc-form--mobile">
                  <input type="hidden" name="id" value="{{ first_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" name="add" class="product-card-mobile-bar__cart">
                    <span class="mobile-bar-label">{{- 'sections.product_list.add_to_cart' | t | upcase -}}</span>
                    <svg class="icon-spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="16" height="16">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="28 56"/>
                    </svg>
                  </button>
                </form>
              {%- else -%}
                <button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>
                  OUT OF STOCK
                </button>
              {%- endif -%}
              <button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="20">
                  <rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                  <rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                  <rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                  <rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                </svg>
              </button>
            </div>

            <xb-wishlist-button-collection xb-handle="{{ product.handle }}" xb-parent-class="product-list__item"></xb-wishlist-button-collection>
          </div>
        {%- else -%}
          {%- for i in (1..section.settings.products_count) -%}
            <div class="product-list__item">
              <a class="product-list__item-link" href="#">
                <div class="product-list__image-wrapper">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'product-list__image product-list__image--placeholder' }}
                  <div class="product-card-actions" aria-label="Product actions">
                    <button class="product-card-actions__btn product-card-actions__btn--cart" type="button" aria-label="{{ 'sections.product_list.add_to_cart' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>Add to cart</span>
                    </button>
                    <button class="product-card-actions__btn product-card-actions__btn--wishlist" type="button" aria-label="{{ 'sections.product_list.add_to_wishlist_generic' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>Wishlist</span>
                    </button>
                    <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        <path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                      </svg>
                      <span>View similar</span>
                    </button>
                  </div>
                </div>
                <div class="product-list__info">
                  <span class="product-list__name">{{ 'sections.product_list.product_placeholder' | t }}</span>
                  <span class="product-list__price">—</span>
                </div>
              </a>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="product-list__scroll-indicator" id="product-list-indicator-{{ section.id }}" aria-hidden="true">
      {%- assign product_count = section.settings.collection.products.count | default: section.settings.products_count -%}
      {%- if product_count > section.settings.products_count -%}
        {%- assign product_count = section.settings.products_count -%}
      {%- endif -%}
      {%- for i in (1..product_count) -%}
        <span class="product-list__scroll-bar{% if forloop.first %} is-active{% endif %}"></span>
      {%- endfor -%}
    </div>

    {%- if section.settings.view_all_url != blank -%}
      <div class="product-list__footer">
        <a class="product-list__view-all" href="{{ section.settings.view_all_url }}">
          {{- 'sections.product_list.view_all' | t -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .product-list {
    background-color: var(--bg-color);
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .product-list__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 0 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* Header */
  .product-list__header {
    text-align: center;
    width: 100%;
  }

  .product-list__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .product-list__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .product-list__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .product-list__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 3rem;
    font-weight: 700;
    color: #2e1f1f;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .product-list__subtitle {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
    line-height: 1.6;
  }

  /* Grid */
  .product-list__scroll-wrapper {
    width: 100%;
  }

  /* Wrap layout — desktop */
  .product-list-desktop--wrap .product-list__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 0.75rem;
    row-gap: 2rem;
    width: 100%;
  }

  /* Scroll layout — desktop */
  .product-list-desktop--scroll .product-list__scroll-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .product-list-desktop--scroll .product-list__scroll-wrapper::-webkit-scrollbar {
    display: none;
  }

  .product-list-desktop--scroll .product-list__grid {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem;
    width: max-content;
    padding: 0 3rem;
  }

  .product-list-desktop--scroll .product-list__item {
    width: 20rem;
    flex-shrink: 0;
  }

  .product-list__item {
    position: relative;
  }

  .product-list__item-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-list__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 5;
    background-color: #e8e0d5;
  }

  .product-list__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom !important;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-list__image--placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .product-list__image-wrapper:hover .product-list__image {
    transform: scale(1.04);
  }


  .product-card-atc-form {
    display: contents;
  }

  .product-card-atc-form--mobile {
    flex: 1;
    display: flex;
  }

  .product-card-atc-form--mobile .product-card-mobile-bar__cart {
    flex: 1;
  }

  /* ── Bottom row — add to cart + view similar ── */
  .product-card-actions {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    gap: 8px;
    pointer-events: none;
    z-index: 1;
  }

  .product-card-actions__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.875rem;
    height: 2.875rem;
    border-radius: 50%;
    background: #fff;
    border: none;
    cursor: pointer;
    color: #2e1f1f;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease, color 0.15s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.12);
  }

  .product-card-actions__btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .product-card-actions__btn--cart    { transition-delay: 0.06s; }
  .product-card-actions__btn--similar { transition-delay: 0s; }

  .product-list__image-wrapper:hover .product-card-actions__btn {
    opacity: 1;
    transform: translateY(0);
  }

  .product-card-actions__btn:hover { background: #e50e7e; color: #fff; }
  /* Spinner animation */
  @keyframes product-card-spin {
    to { transform: rotate(360deg); }
  }

  /* Icon swap: cart → check → spinner */
  .product-card-actions__btn--cart .icon-check  { display: none; }
  .product-card-actions__btn--cart .icon-spinner { display: none; }

  .product-card-actions__btn--cart.is-added { background: #e50e7e; color: #fff; }
  .product-card-actions__btn--cart.is-added .icon-cart  { display: none; }
  .product-card-actions__btn--cart.is-added .icon-check { display: block; }

  .product-card-actions__btn--cart.is-loading { background: #e50e7e; color: #fff; pointer-events: none; }
  .product-card-actions__btn--cart.is-loading .icon-cart    { display: none; }
  .product-card-actions__btn--cart.is-loading .icon-check   { display: none; }
  .product-card-actions__btn--cart.is-loading .icon-spinner {
    display: block;
    animation: product-card-spin 0.7s linear infinite;
  }

  /* Mobile bar spinner */
  .product-card-mobile-bar__cart .icon-spinner { display: none; }
  .product-card-mobile-bar__cart.is-loading .mobile-bar-label { visibility: hidden; }
  .product-card-mobile-bar__cart.is-loading .icon-spinner {
    display: block;
    position: absolute;
    animation: product-card-spin 0.7s linear infinite;
  }
  .product-card-mobile-bar__cart { position: relative; display: flex; align-items: center; justify-content: center; }

  /* Cart button wrapper + tooltip */
  .product-card-actions__cart-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 4px 8px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .product-card-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: #2e1f1f;
  }

  .product-card-actions__cart-wrap:hover .product-card-tooltip { opacity: 1; }

  /* Out of stock label (replaces cart button) */
  .product-card-oos-label {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(0,0,0,0.45);
    padding: 4px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* ── Mobile action bar — always visible below image on mobile ── */
  .product-card-mobile-bar {
    display: none;
  }

  .product-card-mobile-bar__cart.is-added {
    background: #2e1f1f;
    color: #fff;
    pointer-events: none;
  }

  .product-card-mobile-bar__cart--soldout {
    background: #fff;
    color: #aaa;
    cursor: not-allowed;
    font-style: italic;
  }

  /* Product info */
  .product-list__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem 0 0;
  }

  .product-list__name {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-foreground, #262626);
    line-height: 1.4;
  }

  .product-list__price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-foreground, #262626);
    line-height: 1.2;
  }

  /* View all link */
  .product-list__footer {
    display: flex;
    justify-content: center;
  }

  .product-list__view-all {
    font-family: var(--font-body-family, 'Poppins', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    border-bottom: 1px solid var(--color-primary);
    padding-bottom: 0.1rem;
    transition: opacity 0.2s ease;
  }

  .product-list__view-all:hover {
    opacity: 0.75;
  }

  /* Scroll indicator — hidden by default */
  .product-list__scroll-indicator {
    display: none;
  }

  .product-list-desktop--scroll .product-list__scroll-indicator {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 3rem;
    width: 100%;
  }

  .product-list__scroll-bar {
    flex: 1;
    height: 3px;
    background: rgba(184, 168, 168, 0.2);
    transition: background 0.2s ease;
  }

  .product-list__scroll-bar.is-active {
    background: var(--color-primary);
  }

  /* Mobile & Tablet */
  @media screen and (max-width: 768px) {
    .product-list {
      overflow-x: hidden;
    }

    .product-list__container {
      gap: 1.25rem;
      padding: 0px;
    }

    .product-list__title {
      font-size: 1.875rem;
      font-weight: 600;
    }

    .product-list__subtitle {
      font-size: 0.875rem;
    }

    .product-list__divider-line {
      width: 2rem;
    }

    .product-list__divider-diamond {
      font-size: 0.7rem;
    }

    .product-list__name {
      font-size: 0.875rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-list__price {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--color-foreground, #262626);
    }

    .product-list__info {
      gap: 0.25rem;
      padding: 0.5rem 0.75rem 0;
    }

    .product-list__wishlist-btn {
      width: 2rem;
      height: 2rem;
      bottom: 0.75rem;
      right: 0.5rem;
    }


    /* Hide hover overlay actions on mobile */
    .product-card-actions {
      display: none;
    }

    /* Mobile action bar — overlaid at bottom of image */
    .product-card-mobile-bar {
      display: flex;
      align-items: stretch;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
    }

    .product-card-mobile-bar__cart {
      flex: 1;
      padding: 0.6rem 0.5rem;
      background: rgba(255,255,255,0.92);
      border: none;
      border-right: 1px solid #e8e0d5;
      font-family: var(--font-body-family, 'Montserrat', sans-serif);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #2e1f1f;
      cursor: pointer;
      text-align: center;
      backdrop-filter: blur(4px);
    }

    .product-card-mobile-bar__similar {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.75rem;
      flex-shrink: 0;
      background: rgba(255,255,255,0.92);
      border: none;
      color: #2e1f1f;
      cursor: pointer;
      backdrop-filter: blur(4px);
    }

    /* Horizontal scroll layout — mobile */
    .product-list-mobile--scroll .product-list__scroll-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .product-list-mobile--scroll .product-list__scroll-wrapper::-webkit-scrollbar {
      display: none;
    }

    .product-list-mobile--scroll .product-list__grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 0.5rem;
      width: max-content;
      padding: 0 1rem;
    }

    .product-list-mobile--scroll .product-list__item {
      width: calc((100vw - 2.5rem) / 1.5);
      flex-shrink: 0;
    }


    .product-list-mobile--scroll .product-list__scroll-indicator {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0 1rem;
      width: 100%;
    }

    /* Wrap layout — mobile */
    .product-list-mobile--wrap .product-list__image-wrapper {
      aspect-ratio: 3 / 5;
    }

    .product-list-mobile--wrap .product-list__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: 0.5rem;
      row-gap: 1.5rem;
      width: 100%;
      padding: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    function initScrollIndicator(sectionId) {
      var grid = document.getElementById('product-list-grid-' + sectionId);
      var indicator = document.getElementById('product-list-indicator-' + sectionId);
      if (!grid || !indicator) return;

      var bars = indicator.querySelectorAll('.product-list__scroll-bar');
      if (!bars.length) return;

      function updateIndicator() {
        var scrollLeft = grid.parentElement.scrollLeft;
        var scrollWidth = grid.parentElement.scrollWidth - grid.parentElement.clientWidth;
        var progress = scrollWidth > 0 ? scrollLeft / scrollWidth : 0;
        var activeIndex = Math.round(progress * (bars.length - 1));

        bars.forEach(function(bar, i) {
          bar.classList.toggle('is-active', i === activeIndex);
        });
      }

      grid.parentElement.addEventListener('scroll', updateIndicator, { passive: true });
      updateIndicator();
    }

    document.querySelectorAll('.product-list').forEach(function(section) {
      var id = section.querySelector('[id^="product-list-grid-"]');
      if (!id) return;
      var sectionId = id.id.replace('product-list-grid-', '');
      initScrollIndicator(sectionId);
    });

    var cartVariantIds = [];

    function syncCartState() {
      fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          cartVariantIds = cart.items.map(function(i) { return String(i.variant_id); });
          document.querySelectorAll('.product-list__item[data-variant-id]').forEach(function(card) {
            var variantId = card.dataset.variantId;
            var inCart = cartVariantIds.indexOf(variantId) !== -1;
            var iconBtn = card.querySelector('.product-card-actions__btn--cart');
            var mobileBtn = card.querySelector('.product-card-mobile-bar__cart');
            if (iconBtn) iconBtn.classList.toggle('is-added', inCart);
            if (mobileBtn) {
              mobileBtn.classList.toggle('is-added', inCart);
              if (inCart) mobileBtn.textContent = 'ADDED TO CART';
              else mobileBtn.textContent = 'ADD TO CART';
            }
          });
        });
    }

    document.addEventListener('cart:refresh', syncCartState);

    syncCartState();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.product_list.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:labels.subtitle",
      "default": "Discover what's new this season."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "select",
      "id": "layout_type_desktop",
      "label": "t:sections.product_list.layout_type_desktop",
      "options": [
        { "value": "scroll", "label": "t:options.layout_type.scroll" },
        { "value": "wrap", "label": "t:options.layout_type.wrap" }
      ],
      "default": "wrap"
    },
    {
      "type": "select",
      "id": "layout_type_mobile",
      "label": "t:sections.product_list.layout_type_mobile",
      "options": [
        { "value": "scroll", "label": "t:options.layout_type.scroll" },
        { "value": "wrap", "label": "t:options.layout_type.wrap" }
      ],
      "default": "scroll"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:sections.product_list.products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "t:sections.product_list.view_all_url"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_list.name"
    }
  ]
}
{% endschema %}
