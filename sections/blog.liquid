{% comment %}
  Blog listing page — card grid with pagination.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

<div class="blog-listing" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">

  {%- comment -%} Page header {%- endcomment -%}
  <div class="blog-listing__header">
    <div class="blog-listing__ornament" aria-hidden="true">
      <span class="blog-listing__ornament-line"></span>
      <span class="blog-listing__ornament-diamond">✦</span>
      <span class="blog-listing__ornament-line"></span>
    </div>
    <h1 class="blog-listing__title">{{ blog.title }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="blog-listing__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Article grid {%- endcomment -%}
  {%- paginate blog.articles by section.settings.articles_per_page -%}
    {%- if blog.articles_count == 0 -%}
      <p class="blog-listing__empty">{{ 'blog.listing.empty' | t }}</p>
    {%- else -%}
      <ul class="blog-listing__grid" role="list">
        {%- for article in blog.articles -%}
          <li class="blog-card">
            <a class="blog-card__image-link" href="{{ article.url }}" tabindex="-1" aria-hidden="true">
              {%- if article.image -%}
                {%- assign card_alt = article.title | escape -%}
                {{ article.image | image_url: width: 800 | image_tag:
                  class: 'blog-card__image',
                  loading: 'lazy',
                  alt: card_alt,
                  widths: '400,600,800'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'blog-card__image blog-card__image--placeholder' }}
              {%- endif -%}
            </a>

            <div class="blog-card__body">
              {%- if article.tags.size > 0 -%}
                <span class="blog-card__tag">{{ article.tags | first | capitalize }}</span>
              {%- endif -%}

              <h2 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title | escape }}</a>
              </h2>

              {%- if article.excerpt != blank -%}
                <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 110 }}</p>
              {%- elsif article.content != blank -%}
                <p class="blog-card__excerpt">{{ article.content | strip_html | truncate: 110 }}</p>
              {%- endif -%}

              <div class="blog-card__footer">
                <time class="blog-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{- article.published_at | date: '%b %d, %Y' -}}
                </time>
                <a class="blog-card__read-more" href="{{ article.url }}" aria-label="{{ 'blog.listing.read_more' | t }}: {{ article.title | escape }}">
                  {{ 'blog.listing.read_more' | t }}
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      <div class="blog-listing__pagination">
        {{- paginate | default_pagination -}}
      </div>
    {%- endif -%}
  {%- endpaginate -%}

</div>

{% stylesheet %}
  .blog-listing {
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 80px);
    width: 100%;
    max-width: var(--max-page-width, 1280px);
    margin-inline: auto;
    padding-inline: 24px;
    box-sizing: border-box;
  }

  /* ── Header ── */
  .blog-listing__header {
    text-align: center;
    margin-bottom: 52px;
  }

  .blog-listing__ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .blog-listing__ornament-line {
    display: block;
    width: 100px;
    height: 1px;
    background: linear-gradient(90deg, rgba(198,146,57,0) 0%, #c69239 50%, rgba(198,146,57,0) 100%);
  }

  .blog-listing__ornament-diamond {
    color: #c69239;
    font-size: 16px;
    line-height: 1;
  }

  .blog-listing__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 36px !important;
    font-weight: 700 !important;
    color: #2e1f1f;
    margin: 0 0 12px !important;
    line-height: 1.15 !important;
  }

  .blog-listing__subheading {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem !important;
    font-weight: 400 !important;
    color: #1a1a1a;
    max-width: 500px;
    margin-inline: auto;
    line-height: 1.65;
  }

  .blog-listing__empty {
    text-align: center;
    color: var(--color-secondary-text, #7a6e5e);
    padding: 80px 0;
    font-size: 1rem;
  }

  /* ── Grid ── */
  .blog-listing__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }

  @media (max-width: 960px) {
    .blog-listing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .blog-listing__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  /* ── Card ── */
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-background, #fff);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(46, 31, 31, 0.07);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .blog-card:hover {
    box-shadow: 0 10px 36px rgba(46, 31, 31, 0.13);
    transform: translateY(-4px);
  }

  .blog-card__image-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #f0ebe6;
    flex-shrink: 0;
  }

  .blog-card__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .blog-card:hover .blog-card__image {
    transform: scale(1.05);
  }

  .blog-card__image--placeholder {
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 20px 22px 22px;
    gap: 8px;
  }

  .blog-card__tag {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #c69239;
  }

  .blog-card__title {
    margin: 0 !important;
    line-height: 1.4 !important;
    font-size: 1.2rem !important;
    font-weight: 600 !important;
    font-family: var(--font-heading-family, 'Playfair Display', serif);
  }

  .blog-card__title a {
    color: #2e1f1f;
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-card__title a:hover {
    color: var(--color-primary, #c3134e);
  }

  .blog-card__excerpt {
    color: #1a1a1a;
    line-height: 1.6;
    flex: 1;
    font-size: 0.875rem !important;
    font-weight: 400 !important;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
    padding-top: 12px;
    border-top: 1px solid rgba(46, 31, 31, 0.08);
  }

  .blog-card__date {
    font-size: 0.78rem;
    color: #1a1a1a;
    font-style: italic;
  }

  .blog-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary, #c3134e);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .blog-card__read-more:hover {
    gap: 9px;
  }

  /* ── Pagination ── */
  .blog-listing__pagination {
    margin-top: 60px;
    display: flex;
    justify-content: center;
  }

  .blog-listing__pagination .pagination {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .blog-listing__pagination .pagination a,
  .blog-listing__pagination .pagination span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(46, 31, 31, 0.15);
    color: #2e1f1f;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .blog-listing__pagination .pagination a:hover {
    background: var(--color-primary, #c3134e);
    color: #fff;
    border-color: var(--color-primary, #c3134e);
  }

  .blog-listing__pagination .pagination .current span {
    background: var(--color-primary, #c3134e);
    color: #fff;
    border-color: var(--color-primary, #c3134e);
  }

  @media (max-width: 580px) {
    .blog-listing {
      padding-inline: 16px;
    }
    .blog-listing__title {
      font-size: 28px !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Stories, style guides, and inspiration from our world of Indian fashion."
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "t:blog.listing.articles_per_page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 9
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ]
}
{% endschema %}
