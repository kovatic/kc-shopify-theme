<div
  class="about-timeline"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="about-timeline__container">

    <div class="about-timeline__header">
      <div class="about-timeline__divider" aria-hidden="true">
        <span class="about-timeline__divider-line"></span>
        <span class="about-timeline__divider-diamond">✦</span>
        <span class="about-timeline__divider-line"></span>
      </div>
      {%- if section.settings.heading != blank -%}
        <h2 class="about-timeline__heading section-title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="about-timeline__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="about-timeline__track">

        {%- for block in section.blocks -%}
          <div
            class="about-timeline__item{% cycle ' about-timeline__item--left', ' about-timeline__item--right' %}"
            {{ block.shopify_attributes }}
          >
            <div class="about-timeline__node" aria-hidden="true">
              <span class="about-timeline__node-ring"></span>
              <span class="about-timeline__node-dot"></span>
            </div>

            <div class="about-timeline__card">
              {%- if block.settings.year != blank -%}
                <span class="about-timeline__year">{{ block.settings.year | escape }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="about-timeline__card-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="about-timeline__card-text">{{ block.settings.description | escape }}</p>
              {%- endif -%}
              {%- if block.settings.image != blank -%}
                <div class="about-timeline__card-media">
                  {{ block.settings.image | image_url: width: 600 | image_tag:
                    class: 'about-timeline__card-image',
                    loading: 'lazy',
                    alt: block.settings.title | escape
                  }}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .about-timeline {
    width: 100%;
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 60px);
    background-color: #faf7f3;
  }

  .about-timeline__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 52px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* Header */
  .about-timeline__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
  }

  .about-timeline__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .about-timeline__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .about-timeline__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .about-timeline__heading {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 2.75rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0;
    line-height: 1.15;
  }

  .about-timeline__subheading {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.075rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
    line-height: 1.6;
    max-width: 680px;
  }

  /* Track — 3-column grid: left | node-column | right */
  .about-timeline__track {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 18px 1fr;
    row-gap: 0;
  }

  /* Vertical spine — absolute line down the centre of the node column */
  .about-timeline__track::before {
    content: '';
    position: absolute;
    left: calc(50% - 1px);
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, transparent 0%, #c69239 4%, #c69239 96%, transparent 100%);
    pointer-events: none;
  }

  /* Each milestone row occupies all 3 columns */
  .about-timeline__item {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 18px 1fr;
    align-items: start;
    padding-bottom: 52px;
  }

  .about-timeline__item:last-child {
    padding-bottom: 0;
  }

  /* Node — always in centre column */
  .about-timeline__node {
    grid-column: 2;
    justify-self: center;
    margin-top: 6px;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    position: relative;
  }

  .about-timeline__node-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid #c69239;
    background: #faf7f3;
  }

  .about-timeline__node-dot {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c69239;
    z-index: 1;
  }

  /* Card — left items go in column 1, right in column 3 */
  .about-timeline__card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .about-timeline__item--left .about-timeline__card {
    grid-column: 1;
    text-align: right;
    align-items: flex-end;
    padding-right: 36px;
  }

  .about-timeline__item--left .about-timeline__node {
    grid-column: 2;
  }

  /* Push right-item card to column 3 */
  .about-timeline__item--right .about-timeline__node {
    grid-column: 2;
  }

  .about-timeline__item--right .about-timeline__card {
    grid-column: 3;
    text-align: left;
    align-items: flex-start;
    padding-left: 36px;
  }

  .about-timeline__year {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 2rem;
    font-weight: 700;
    color: #c69239;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .about-timeline__card-title {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0;
    line-height: 1.3;
  }

  .about-timeline__card-text {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    font-weight: 400;
    color: #494949;
    margin: 0;
    line-height: 1.7;
  }

  .about-timeline__card-media {
    margin-top: 8px;
    overflow: hidden;
    border-radius: 2px;
    max-width: 240px;
  }

  .about-timeline__card-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Mobile — single column */
  @media screen and (max-width: 767px) {
    .about-timeline__container {
      padding: 0 20px;
      gap: 40px;
    }

    .about-timeline__heading {
      font-size: 1.875rem;
    }

    .about-timeline__subheading {
      font-size: 0.9rem;
    }

    .about-timeline__track {
      grid-template-columns: 18px 1fr;
    }

    .about-timeline__track::before {
      left: 9px;
    }

    .about-timeline__item--left,
    .about-timeline__item--right {
      grid-template-columns: 18px 1fr;
      padding-bottom: 40px;
    }

    .about-timeline__item--left .about-timeline__node,
    .about-timeline__item--right .about-timeline__node {
      grid-column: 1;
    }

    .about-timeline__item--left .about-timeline__card,
    .about-timeline__item--right .about-timeline__card {
      grid-column: 2;
      text-align: left;
      align-items: flex-start;
      padding-left: 24px;
      padding-right: 0;
    }

    .about-timeline__card-media {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_timeline.name",
  "blocks": [
    {
      "type": "milestone",
      "name": "t:sections.about_timeline.blocks.milestone.name",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "t:sections.about_timeline.blocks.milestone.year",
          "default": "1968"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "The beginning"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:labels.text",
          "default": "K. Chinnadurai & Co. was founded with a single store in Thoothukudi, dedicated to bringing the finest handloom sarees to discerning customers."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.title",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subtitle",
      "default": "Five decades of craftsmanship, heritage, and community."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.about_timeline.name",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "year": "1968",
            "title": "The beginning",
            "description": "K. Chinnadurai & Co. was founded with a single store in Thoothukudi, dedicated to bringing the finest handloom sarees."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "1980",
            "title": "Expanding our roots",
            "description": "A second location opened in Tirunelveli, bringing our curated collection to a wider community of saree enthusiasts."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "1995",
            "title": "A legacy of weaving",
            "description": "We established direct partnerships with master weavers in Kanchipuram and Madurai, ensuring authenticity in every thread."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2010",
            "title": "The next generation",
            "description": "The second generation of the Chinnadurai family joined the business, blending heritage with a modern vision."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "56 years & beyond",
            "description": "Now spanning multiple stores across Tamil Nadu, K. Chinnadurai & Co. continues to honour tradition while embracing the future."
          }
        }
      ]
    }
  ]
}
{% endschema %}
