{% comment %}
  Search results page — product grid UI matches the collection page.
{% endcomment %}

<div class="search-page">
  <div class="search-page__container">

    <div class="collection-page__header search-page__header-row">
      <div>
        <h2>{{ 'search.title' | t }}</h2>
        {%- if search.performed and search.terms != blank -%}
          <p class="search-page__count">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>
        {%- endif -%}
      </div>
      <form class="search-page__form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-page__input-wrap">
          <svg class="search-page__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/>
            <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <input
            class="search-page__input"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'search.placeholder' | t }}"
            aria-label="{{ 'search.placeholder' | t }}"
            autocomplete="off"
          >
        </div>
        <button class="search-page__submit" type="submit">{{ 'search.submit' | t }}</button>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p class="search-page__no-results">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {%- else -%}

        {% paginate search.results by 20 %}

          <div class="collection-page__layout">

            {%- comment -%} ── LEFT: Facet filters (Search & Discovery) ── {%- endcomment -%}
            <aside class="collection-page__sidebar" id="search-filters">

              {%- comment -%} Active filters — clear pills {%- endcomment -%}
              {%- assign has_active = false -%}
              {%- for filter in search.filters -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                    {%- assign has_active = true -%}
                  {%- endif -%}
                {%- else -%}
                  {%- if filter.active_values.size > 0 -%}
                    {%- assign has_active = true -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_active -%}
                <div class="facet-active">
                  {%- for filter in search.filters -%}
                    {%- for value in filter.active_values -%}
                      <a class="facet-active__pill" href="{{ value.url_to_remove }}">
                        {{ value.label }}
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                      </a>
                    {%- endfor -%}
                    {%- if filter.type == 'price_range' -%}
                      {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                        <a class="facet-active__pill" href="{{ filter.url_to_remove }}">
                          {{ filter.label }}
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                        </a>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- for filter in search.filters -%}
                <div class="facet-group">
                  <button class="facet-group__toggle" aria-expanded="true" aria-controls="search-facet-{{ filter.param_name | handleize }}">
                    {{ filter.label }}
                    <svg class="facet-group__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true"><polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <div class="facet-group__body" id="search-facet-{{ filter.param_name | handleize }}">

                    {%- case filter.type -%}

                      {%- when 'list' -%}
                        <ul class="facet-list">
                          {%- for value in filter.values -%}
                            <li class="facet-list__item">
                              <a class="facet-list__link{% if value.active %} is-active{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}"
                                 href="{{ value.url_to_add | default: value.url_to_remove }}">
                                <span class="facet-list__check"></span>
                                {{ value.label }}
                                <span class="facet-list__count">({{ value.count }})</span>
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>

                      {%- when 'price_range' -%}
                        <form class="facet-price-form" id="search-facet-price-form">
                          {%- assign min_val = filter.min_value.value | default: '' -%}
                          {%- assign max_val = filter.max_value.value | default: '' -%}
                          {%- for f in search.filters -%}
                            {%- if f.type == 'list' -%}
                              {%- for v in f.active_values -%}
                                <input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">
                              {%- endfor -%}
                            {%- endif -%}
                          {%- endfor -%}
                          <input type="hidden" name="q" value="{{ search.terms | escape }}">
                          <input type="hidden" name="type" value="product">
                          <div class="facet-price-form__fields">
                            <div class="facet-price-form__field">
                              <label class="facet-price-form__label" for="search-price-min">From</label>
                              <div class="facet-price-form__input-wrap">
                                <span class="facet-price-form__currency">{{ cart.currency.symbol }}</span>
                                <input class="facet-price-form__input" type="number" id="search-price-min"
                                  name="{{ filter.min_value.param_name }}" min="0" placeholder="0"
                                  value="{% if min_val != blank %}{{ min_val | money_without_currency | remove: ',' }}{% endif %}">
                              </div>
                            </div>
                            <div class="facet-price-form__field">
                              <label class="facet-price-form__label" for="search-price-max">To</label>
                              <div class="facet-price-form__input-wrap">
                                <span class="facet-price-form__currency">{{ cart.currency.symbol }}</span>
                                <input class="facet-price-form__input" type="number" id="search-price-max"
                                  name="{{ filter.max_value.param_name }}" min="0" placeholder="Any"
                                  value="{% if max_val != blank %}{{ max_val | money_without_currency | remove: ',' }}{% endif %}">
                              </div>
                            </div>
                          </div>
                          <button class="facet-price-form__btn" type="submit">Apply</button>
                        </form>

                    {%- endcase -%}

                  </div>
                </div>
              {%- endfor -%}

            </aside>

            {%- comment -%} ── RIGHT: Grid + pagination ── {%- endcomment -%}
            <div class="collection-page__main">
              <div class="collection-page__grid" id="search-grid">
            {%- for result in search.results -%}
              {%- if result.object_type == 'product' -%}
                {%- if result.tags contains 'Archived' -%}{%- continue -%}{%- endif -%}
                {%- assign product = result -%}
                {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
                {%- assign is_available = product.available -%}
                <div class="product-list__item{% unless is_available %} is-sold-out{% endunless %}" data-variant-id="{{ first_variant.id }}" data-available="{{ is_available }}">
                  <a class="product-list__item-link" href="{{ product.url }}">
                    <div class="product-list__image-wrapper">
                      {%- if product.featured_image != blank -%}
                        {{ product.featured_image | image_url: width: 600, height: 700, crop: 'center' | image_tag: class: 'product-list__image', loading: 'lazy', alt: product.title | escape }}
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'product-list__image product-list__image--placeholder' }}
                      {%- endif -%}

                      {% comment %} Glowing Discount Badge on Top Left Corner {% endcomment %}
                      {%- if product.compare_at_price_min > product.price_min -%}
                        {%- assign grid_savings = product.compare_at_price_min | minus: product.price_min | times: 100 | divided_by: product.compare_at_price_min -%}
                        <span class="product-grid__glow-discount-badge">-{{ grid_savings }}%</span>
                      {%- endif -%}

                      <button class="product-card-wishlist" type="button" aria-label="Add to wishlist">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>

                      <div class="product-card-actions">
                        <div class="product-card-actions__cart-wrap">
                          {%- if is_available -%}
                            <button class="product-card-actions__btn product-card-actions__btn--cart js-cart-toggle" type="button" aria-label="Add to cart">
                              <svg class="icon-cart" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                              <svg class="icon-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </button>
                            <span class="product-card-tooltip js-cart-tooltip">Add to cart</span>
                          {%- else -%}
                            <span class="product-card-oos-label">Out of stock</span>
                          {%- endif -%}
                        </div>
                        <button class="product-card-actions__btn product-card-actions__btn--similar" type="button" aria-label="View similar">
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                            <path d="M11 8v6M8 11h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                          </svg>
                        </button>
                      </div>

                      <div class="product-card-mobile-bar">
                        {%- if is_available -%}
                          <button class="product-card-mobile-bar__cart js-cart-toggle" type="button">ADD TO CART</button>
                        {%- else -%}
                          <button class="product-card-mobile-bar__cart product-card-mobile-bar__cart--soldout" type="button" disabled>OUT OF STOCK</button>
                        {%- endif -%}
                        <button class="product-card-mobile-bar__similar" type="button" aria-label="View similar">
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="20">
                            <rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                            <rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/>
                          </svg>
                        </button>
                      </div>
                    </div>

                    <div class="product-list__info">
                      <span class="product-list__name">{{ product.title | escape }}</span>
                      <!-- <span class="product-list__price">{{ product.price | money }}</span> -->
                     <div class="product-card__price-atc-wrapper">
                        <!-- <span class="product-list__price">{{ product.price_min | money }}</span> -->
                          <div class="product-grid__price-stacked-layout">
                      {%- if product.compare_at_price_min > product.price_min -%}
                        {% comment %} Displays active sale price and struck out original price side-by-side on the same line {% endcomment %}
                        <div class="product-grid__price-meta-row">
                          <div class="product-page__price-current grid is-on-sale">{{ product.price_min | money }}</div>
                          <div class="product-page__price-compare">{{ product.compare_at_price_min | money }}</div>
                        </div>
                      {%- else -%}
                        {% comment %} Normal pricing view if item isn't marked down {% endcomment %}
                        <div class="product-grid__price-meta-row">
                          <span class="product-page__price-current grid">{{ product.price_min | money }}</span>
                        </div>
                      {%- endif -%}
                    </div>
                        
                        {%- if product.available -%}
                          <form method="post" action="/cart/add" class="product-card__inline-form">
                            <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" name="add" class="product-card__inline-atc-btn js-inline-atc-submit">
                              <span class="inline-atc-btn__text">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" style="display: inline-block; vertical-align: middle;"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round"/><path d="M16 10a4 4 0 01-8 0" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Add
                              </span>
                              <svg class="inline-atc-btn__spinner" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="24 48"/>
                              </svg>
                            </button>
                          </form>
                        {%- else -%}
                          <!-- <span class="product-card__inline-oos">OOS</span> -->
                        {%- endif -%}
                      </div>
                       </div>
                  </a>
                </div>

              {%- else -%}
                {%- comment -%} Articles / pages fall back to a simple card {%- endcomment -%}
                <div class="search-result-card">
                  {%- assign featured_image = result.featured_image | default: result.image -%}
                  {%- if featured_image -%}
                    <a class="search-result-card__img-link" href="{{ result.url }}">
                      {{ featured_image | image_url: width: 600, height: 700, crop: 'center' | image_tag: class: 'search-result-card__img', loading: 'lazy', alt: result.title | escape }}
                    </a>
                  {%- endif -%}
                  <div class="product-list__info">
                    <a class="product-list__name" href="{{ result.url }}">{{ result.title | escape }}</a>
                    {%- if result.published_at -%}
                      <span class="product-list__price" style="font-size:0.75rem; font-weight:400; color:#999;">{{ result.published_at | date: '%b %d, %Y' }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
              </div>

              <div class="collection-page__pagination">
                {{ paginate | default_pagination }}
              </div>

            </div>
          </div>

        {% endpaginate %}
      {%- endif -%}
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .search-page {
    padding-top: var(--padding-top, 40px);
    padding-bottom: var(--padding-bottom, 60px);
  }

  .search-page__container {
    max-width: 1900px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .search-page__header-row {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .search-page__form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .search-page__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-page__icon {
    position: absolute;
    left: 0.75rem;
    width: 16px;
    height: 16px;
    color: #999;
    pointer-events: none;
  }

  .search-page__input {
    padding: 0.55rem 1rem 0.55rem 2.2rem;
    border: 1px solid #d9cfc7;
    background: #faf8f5;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem;
    color: #2e1f1f;
    outline: none;
    width: 260px;
    transition: border-color 0.2s;
  }

  .search-page__input:focus { border-color: #2e1f1f; }

  .search-page__submit {
    padding: 0.55rem 1.2rem;
    background: #2e1f1f;
    color: #fff;
    border: none;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .search-page__submit:hover { background: #5a3a2a; }

  .search-page__count {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    color: #999;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .search-page__no-results {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem;
    color: #666;
    padding: 3rem 0;
  }

  .search-result-card {
    display: flex;
    flex-direction: column;
  }

  .search-result-card__img-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 2 / 3;
  }

  .search-result-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .search-result-card__img-link:hover .search-result-card__img {
    transform: scale(1.04);
  }

  @media screen and (max-width: 768px) {
    .search-page__container { padding: 0 1rem; }

    .search-page__header-row {
      flex-direction: column !important;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .search-page__form { width: 100%; }
    .search-page__input { width: 100%; }
    .search-result-card__img-link { aspect-ratio: 3 / 5; }
        .product-card__inline-form {
        display: none !important;
    }

  }
  .product-card__price-atc-wrapper {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 8px !important;
  width: 100% !important;
  margin-top: 6px !important;
}

.product-card__inline-form {
  margin: 0 !important;
  padding: 0 !important;
  display: block;
}

.product-card__inline-atc-btn {
  display: inline-flex !important;
  align-items: center !important;
  gap: 5px !important;
  background-color: #d7116a !important; 
  color: #ffffff !important;
  border: none !important;
  border-radius: 4px !important;
  padding: 6px 10px !important;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 0.72rem !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.04em !important;
  cursor: pointer !important;
  transition: background-color 0.2s ease !important;
  line-height: 1 !important;
}

.product-card__inline-atc-btn:hover {
  background-color: #b80d58 !important;
}

.product-card__inline-oos {
  font-family: 'Montserrat', sans-serif !important;
  font-size: 0.7rem !important;
  color: #a0a0a0 !important;
  font-weight: 700 !important;
  letter-spacing: 0.05em !important;
}
.inline-atc-btn__spinner {
  display: none !important;
  width: 14px !important;
  height: 14px !important;
  color: #ffffff !important;
}

.product-card__inline-atc-btn.is-loading {
  background-color: #b80d58 !important; 
  pointer-events: none !important;
  cursor: wait !important;
}

.product-card__inline-atc-btn.is-loading .inline-atc-btn__text {
  display: none !important; 
}

.product-card__inline-atc-btn.is-loading .inline-atc-btn__spinner {
  display: inline-block !important;
  animation: inlineCardSpin 0.6s linear infinite !important;
}
   @media(max-width:390px){
              .product-card__price-atc-wrapper{
                display: block !important;
              }
              .product-card__inline-atc-btn{
                margin-top:8px !important;
              }
            }
@keyframes inlineCardSpin {
  to { transform: rotate(360deg); }
}
.product-page__price-compare {
    font-size: 15px;
    font-weight: 500 !important;
    color: #556270 !important;
    position: relative !important;
    text-decoration: none !important;
  }

  .product-page__price-compare::after {
    content: "" !important;
    position: absolute !important;
    left: -3px;
    right: -3px;
    top: 50% !important;
    height: 1px !important;
    background-color: #d15b47 !important; 
    transform: rotate(-17deg) !important;
    transform-origin: center !important;
  }
  .product-page__price-current {
    font-size: 1.65rem !important;
    font-weight: 700 !important;
    letter-spacing: -0.02em !important;
  }
  .product-page__price-current.is-on-sale {
    color: #1a7a3c !important;
  }
        @media screen and (min-width: 1321px) {
   .product-page__price-current.grid, product-page__price-current{
        font-size: 1.375rem !important;
  }
}

  @media (max-width: 1320px) and (min-width: 769px) {
    .product-grid__price-meta-row{
    display: block !important;
  }
  .product-page__price-compare{
    margin-top:4px;
  }
}
 @media (max-width: 990px) and (min-width: 769px) {
    .product-page__price-current, .product-page__price-current.grid{
   font-size: 14px !important;
  }
}
.product-list__image-wrapper {
  position: relative !important;
}

.product-grid__glow-discount-badge {
  position: absolute !important;
  top: 12px !important;
  left: 12px !important;
  z-index: 10 !important;
  background: linear-gradient(135deg, #ff5fa2 0%, #e34196 35%, #8424c8 100%) !important;
  color: #ffffff !important;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 0.75rem !important;
  font-weight: 700 !important;
  padding: 5px 9px !important;
  border-radius: 6px !important;
  letter-spacing: 0.03em !important;
  line-height: 1 !important;
  pointer-events: none !important;
  border: 1px solid rgba(255, 255, 255, 0.35) !important;
  box-shadow: 0 6px 16px rgb(0 0 0 / 16%), 0 0 8px rgb(255 95 162 / 30%);
  transform-origin: center center !important;
  will-change: transform;
  animation: sugarPulse 2s infinite ease-in-out !important;
}

@keyframes sugarPulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.06);
  }
  100% {
    transform: scale(1);
  }
}
{% endstylesheet %}

{% javascript %}
  (function() {
    function applyCardState(card) {
      var variantId = card.dataset.variantId;
      var isAvailable = card.dataset.available === 'true';
      var iconBtn = card.querySelector('.product-card-actions__btn--cart');
      var mobileBtn = card.querySelector('.product-card-mobile-bar__cart');
      if (!isAvailable) {
        if (iconBtn) { iconBtn.disabled = true; }
        if (mobileBtn) { mobileBtn.disabled = true; mobileBtn.textContent = 'OUT OF STOCK'; mobileBtn.classList.add('product-card-mobile-bar__cart--soldout'); }
      }
    }

    document.querySelectorAll('.search-page .product-list__item[data-variant-id]').forEach(applyCardState);

    document.querySelectorAll('.search-page .js-cart-toggle').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var card = btn.closest('.product-list__item');
        var variantId = card && card.dataset.variantId;
        if (!variantId) return;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        })
        .then(function(res) { return res.json(); })
        .then(function() {
          var iconBtn = card.querySelector('.product-card-actions__btn--cart');
          var mobileBtn = card.querySelector('.product-card-mobile-bar__cart');
          if (iconBtn) { iconBtn.classList.add('is-added'); }
          if (mobileBtn) { mobileBtn.textContent = 'ADDED TO CART'; mobileBtn.classList.add('is-added'); }
          setTimeout(function() {
            if (iconBtn) { iconBtn.classList.remove('is-added'); }
            if (mobileBtn) { mobileBtn.textContent = 'ADD TO CART'; mobileBtn.classList.remove('is-added'); }
          }, 2000);
        });
      });
    });
  })();
{% endjavascript %}

