<div
  class="about-team"
  style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="about-team__container">

    <div class="about-team__header">
      <div class="about-team__divider" aria-hidden="true">
        <span class="about-team__divider-line"></span>
        <span class="about-team__divider-diamond">✦</span>
        <span class="about-team__divider-line"></span>
      </div>
      {%- if section.settings.heading != blank -%}
        <h2 class="about-team__heading section-title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="about-team__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="about-team__grid" style="--columns: {{ section.settings.columns }};">
        {%- for block in section.blocks -%}
          <div class="about-team__member" {{ block.shopify_attributes }}>
            <div class="about-team__member-media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 560 | image_tag:
                  class: 'about-team__member-photo',
                  loading: 'lazy',
                  alt: block.settings.name | escape
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'about-team__member-photo about-team__member-photo--placeholder' }}
              {%- endif -%}
            </div>
            <div class="about-team__member-info">
              {%- if block.settings.name != blank -%}
                <h3 class="about-team__member-name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="about-team__member-role">{{ block.settings.role | escape }}</p>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="about-team__member-bio">{{ block.settings.bio | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .about-team {
    width: 100%;
    padding-top: var(--padding-top, 60px);
    padding-bottom: var(--padding-bottom, 60px);
    background-color: #fbf4ed;
  }

  .about-team__container {
    max-width: 1336px;
    margin: 0 auto;
    padding: 0 52px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* Header */
  .about-team__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
  }

  .about-team__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .about-team__divider-line {
    display: block;
    width: 7.5rem;
    height: 1px;
    background: linear-gradient(to right, transparent, #c69239 50%, transparent);
  }

  .about-team__divider-diamond {
    color: #c69239;
    font-size: 1.1rem;
    line-height: 1;
  }

  .about-team__heading {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 2.75rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0;
    line-height: 1.15;
  }

  .about-team__subheading {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1.075rem;
    font-weight: 400;
    color: #7e6767;
    margin: 0;
    line-height: 1.6;
    max-width: 680px;
  }

  /* Grid */
  .about-team__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 4), 1fr);
    gap: 36px 28px;
  }

  /* Member card */
  .about-team__member {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .about-team__member-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #e8ddd0;
  }

  .about-team__member-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .about-team__member-photo--placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .about-team__member:hover .about-team__member-photo {
    transform: scale(1.04);
  }

  .about-team__member-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .about-team__member-name {
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 1.125rem;
    font-weight: 700;
    color: #2e1f1f;
    margin: 0;
    line-height: 1.3;
  }

  .about-team__member-role {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: #c69239;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .about-team__member-bio {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8125rem;
    font-weight: 400;
    color: #7e6767;
    margin: 4px 0 0;
    line-height: 1.65;
  }

  /* Tablet */
  @media screen and (max-width: 1024px) {
    .about-team__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Mobile */
  @media screen and (max-width: 767px) {
    .about-team__container {
      padding: 0 20px;
      gap: 40px;
    }

    .about-team__heading {
      font-size: 1.875rem;
    }

    .about-team__subheading {
      font-size: 0.9rem;
    }

    .about-team__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
  }

  @media screen and (max-width: 400px) {
    .about-team__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.about_team.name",
  "blocks": [
    {
      "type": "member",
      "name": "t:sections.about_team.blocks.member.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.about_team.blocks.member.name_label",
          "default": "Team member"
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:sections.about_team.blocks.member.role",
          "default": "Role"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "t:sections.about_team.blocks.member.bio"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.title",
      "default": "Meet the team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subtitle",
      "default": "The people who bring K. Chinnadurai & Co. to life every day."
    },
    {
      "type": "select",
      "id": "columns",
      "label": "t:sections.about_team.columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.about_team.name",
      "blocks": [
        { "type": "member" },
        { "type": "member" },
        { "type": "member" },
        { "type": "member" }
      ]
    }
  ]
}
{% endschema %}
