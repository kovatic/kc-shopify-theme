    font-size: 0.6rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Category nav ── */
  .header-nav {
    background-color: #efeee9;
    border-top: 1px solid #e0dfd9;
    border-bottom: 1px solid #e0dfd9;
    padding: 0.5rem 1rem;
    width: 100%;
  }
  .header-nav__list {
    display: flex;
    align-items: center;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: var(--page-width, 1900px);
    gap: 4px;
  }
  .header-nav__item { position: relative; }
  .header-nav__link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 16px;
    text-decoration: none;
    color: #42464b;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    white-space: nowrap;
  }
  .header-nav__link:hover { color: var(--color-primary); }
  .header-nav__chevron { width: 10px; height: 10px; color: #888; transition: transform 0.2s ease; }
  .header-nav__item--has-dropdown:hover .header-nav__chevron { transform: rotate(180deg); }

  /* ── Dropdowns & Mega Menus ── */
  .header-nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid #e0dfd9;
    list-style: none;
    padding: 8px 0;
    min-width: 200px;
    z-index: 100;
  }
  .header-nav__item--has-dropdown:hover .header-nav__dropdown { display: block; }
  .header-nav__dropdown-link { display: block; padding: 9px 20px; color: #42464b; text-decoration: none; }
  .header-nav__dropdown-link:hover { background-color: #f5f4f0; color: var(--color-primary); }

  .mega-menu {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    background-color: #efeee9;
    z-index: 299;
    border-top: 1px solid #e0dfd9;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .header-nav__item--mega.is-open .mega-menu { display: block; }
  .mega-menu__inner { display: flex; gap: 48px; padding: 48px 80px 56px; max-width: var(--page-width, 1900px); margin: 0 auto; }
  .mega-menu__cols { display: flex; gap: 64px; flex: 1; }
  .mega-menu__col { display: flex; flex-direction: column; gap: 16px; min-width: 160px; }
  .mega-menu__col-heading { font-size: 1rem; font-weight: 500; color: #42464b; text-decoration: underline; margin: 0; }
  .mega-menu__links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 20px; }
  .mega-menu__link { text-decoration: none; color: #42464b; font-size: 1rem; }
  .mega-menu__link:hover { color: var(--color-primary); }
  .mega-menu__link--promo { color: #ce0570; }

  .mega-menu__cards { display: flex; gap: 16px; }
  .mega-menu__card { position: relative; display: block; width: 280px; height: 380px; overflow: hidden; }
  .mega-menu__card-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
  .mega-menu__card:hover .mega-menu__card-img { transform: scale(1.04); }
  .mega-menu__card-label { position: absolute; bottom: 20px; left: 20px; color: #fff; font-size: 1.1rem; font-weight: 600; }

  /* ── Promo Bar ── */
  .header-promo-bar { display: flex; align-items: center; justify-content: center; background-color: #ce0570; min-height: 34px; overflow: hidden; position: relative; }
  .header-promo-bar__track { position: relative; width: 100%; height: 1.05rem; }
  .header-promo-bar__item { color: #fff; font-size: 0.75rem; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease, transform 0.4s ease; margin: 0; }
  .header-promo-bar__item.is-active { opacity: 1; transform: translateY(0); }
  .header-promo-bar__item.is-exiting { opacity: 0; transform: translateY(-8px); }

  /* ── Mobile Nav Base Overrides ── */
  .mobile-nav-drawer { display: none; }
  .mobile-nav-drawer.is-open { display: block !important; }
  .mobile-nav-drawer__overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; }
  .mobile-nav-drawer__panel { position: fixed; top: 0; left: 0; bottom: 0; width: 280px; background: #fff; z-index: 201; overflow-y: auto; padding: 16px 0 32px; }
  .mobile-nav-drawer__close { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: none; border: none; margin: 0 0 8px 16px; }
  .mobile-nav-drawer__list { list-style: none; margin: 0; padding: 0; }
  .mobile-nav-drawer__item { border-bottom: 1px solid #f0efe9; }

  @media screen and (max-width: 768px) {
    .site-header__topbar-wrap { max-height: 0 !important; opacity: 0 !important; transition: none !important; }
    .header-topbar { display: none; }
    .header-main__left { display: flex; }
    .header-hamburger { display: flex; }
    .header-icon-btn--search-mobile { display: flex; }
    .header-main__inner { height: 70px; justify-content: space-between; }
    .header-main__logo-link--mobile { display: block; }
    .has-mobile-logo .header-main__logo-link--desktop { display: none; }
    .header-main__logo { position: absolute; left: 50%; transform: translateX(-50%); }
    .header-main__logo-img { max-height: 44px; }
    .header-icon-btn { background: none; }
    .header-icon-btn--account-desktop, .header-shop-live-btn, .header-login-btn, .header-nav, .header-main__icons .header-icon-btn--search { display: none; }
    .header-main__icons { gap: 4px; }

    /* Slider specific dimensions */
    .mobile-nav-slider-container { width: 100%; overflow: hidden; position: relative; }
    .mobile-nav-slider-track { display: flex; width: 100%; transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
    .mobile-nav-level { width: 100%; flex-shrink: 0; box-sizing: border-box; }
    .mobile-nav-arrow-icon { font-size: 1.2rem; color: #888; font-weight: bold; }
    .mobile-nav-drawer__back-btn { display: flex; align-items: center; gap: 12px; width: 100%; padding: 16px 20px; background: #f8f7f3; border: none; border-bottom: 1px solid #e0dfd9; font-family: 'Montserrat', sans-serif; font-size: 0.95rem; font-weight: 600; color: #2e1f1f; text-align: left; }
    .mobile-nav-drawer__link--shop-all { font-weight: 600 !important; color: #ce0570 !important; }
    .mobile-nav-drawer__banner { padding: 20px; width: 100%; box-sizing: border-box; }
    .mobile-nav-drawer__banner img { width: 100%; height: auto; border-radius: 6px; object-fit: cover; display: block; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
  }

  /* ── Search overlay ── */
  .header-search-overlay { position: fixed; inset: 0; z-index: 400; pointer-events: none; opacity: 0; transition: opacity 0.2s ease; }
  .header-search-overlay.is-open { pointer-events: auto; opacity: 1; }
  .header-search-overlay__backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.25); }
  .header-search-overlay__panel { position: fixed; top: 0; left: 0; right: 0; background: #f2f2f0; transform: translateY(-6px); transition: transform 0.2s ease; max-height: 100vh; overflow-y: auto; z-index: 401; }
  .header-search-overlay.is-open .header-search-overlay__panel { transform: translateY(0); }
  .header-search-overlay__bar { display: flex; align-items: center; gap: 0.75rem; padding: 4rem 1.5rem; border-bottom: 1px solid #e0dfd9; max-width: var(--page-width, 1900px); margin: 0 auto; }
  .header-search-overlay__form-wrap { display: flex; align-items: center; flex: 1; background: #e8e8e6; border-radius: 6px; padding: 0 1rem; height: 52px; gap: 0.5rem; }
  .header-search-overlay__input { flex: 1; background: none; border: none; outline: none; padding: 0 0.5rem; font-family: 'Montserrat', sans-serif; font-size: 1rem; color: #2e1f1f; }
  .header-search-overlay__clear { background: none; border: none; color: #666; font-size: 0.85rem; }
  .header-search-overlay__close { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: none; border: none; color: #666; border-radius: 50%; }
  .header-search-results { padding: 1.5rem 1.5rem 0; }
  .header-search-results__inner { display: flex; gap: 2rem; max-width: var(--page-width, 1900px); margin: 0 auto; padding-bottom: 1.5rem; }
  .header-search-results__col--suggestions { flex: 0 0 200px; border-right: 1px solid #e0dfd9; padding-right: 2rem; }
  .header-search-results__col--products { flex: 1; min-width: 0; }
  .header-search-results__heading { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; color: #999; margin-bottom: 1rem; }
  .header-search-suggestions { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .header-search-suggestions li a { font-size: 0.9rem; color: #42464b; text-decoration: none; }
  .header-search-products { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 2rem; }
  .header-search-product { display: flex; gap: 0.85rem; text-decoration: none; color: inherit; }
  .header-search-product__img { width: 72px; height: 88px; object-fit: cover; border-radius: 2px; }
  .header-search-product__info { display: flex; flex-direction: column; gap: 0.2rem; }
  .header-search-product__title { font-size: 0.875rem; color: #2e1f1f; }
  .header-search-product__price { font-size: 0.875rem; color: #2e1f1f; font-weight: 500; }
  .header-search-results__footer { border-top: 1px solid #e0dfd9; padding: 1.25rem 1.5rem; display: flex; justify-content: center; }
  .header-search-results__view-all { display: inline-block; padding: 0.85rem 2.5rem; background: #2e1f1f; color: #fff; text-transform: uppercase; text-decoration: none; }
{% endstylesheet %}

{% javascript %}
  (function() {
    var siteHeader = document.getElementById('site-header');
    var spacer = document.getElementById('site-header-spacer');
    var topbarWrap = siteHeader && siteHeader.querySelector('.site-header__topbar-wrap');
    var THRESHOLD = 10;

    function headerBottom() { return siteHeader ? siteHeader.getBoundingClientRect().bottom : 0; }

    function updateSpacer() {
      if (spacer && siteHeader) {
        var h = siteHeader.offsetHeight;
        if (h > 0) spacer.style.height = h + 'px';
      }
    }
    updateSpacer();
    document.addEventListener('DOMContentLoaded', updateSpacer);
    window.addEventListener('load', updateSpacer);
    window.addEventListener('resize', updateSpacer);
    
    if (topbarWrap) {
      topbarWrap.addEventListener('transitionend', function() {
        updateSpacer();
        updateMegaMenuTops();
      });
    }

    function updateMegaMenuTops() {
      var bottom = headerBottom();
      document.querySelectorAll('.mega-menu').forEach(function(mm) {
        mm.style.top = bottom + 'px';
      });
    }
    updateMegaMenuTops();
    window.addEventListener('resize', updateMegaMenuTops);

    document.querySelectorAll('.header-nav__item--mega').forEach(function(item) {
      var closeTimer = null;
      function openMenu() { clearTimeout(closeTimer); updateMegaMenuTops(); item.classList.add('is-open'); }
      function scheduleClose() { closeTimer = setTimeout(function() { item.classList.remove('is-open'); }, 80); }
      var megaMenu = item.querySelector('.mega-menu');
      item.addEventListener('mouseenter', openMenu);
      item.addEventListener('mouseleave', scheduleClose);
      if (megaMenu) {
        megaMenu.addEventListener('mouseenter', function() { clearTimeout(closeTimer); });
        megaMenu.addEventListener('mouseleave', scheduleClose);
      }
    });

    function onScroll() {
      if (window.scrollY > THRESHOLD) { siteHeader.classList.add('is-scrolled'); } 
      else { siteHeader.classList.remove('is-scrolled'); }
      updateSpacer();
      updateMegaMenuTops();
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    var hamburger = document.querySelector('.header-hamburger');
    var drawer = document.getElementById('mobile-nav-drawer');
    var closeBtn = document.querySelector('.mobile-nav-drawer__close');
    var overlay = document.querySelector('.mobile-nav-drawer__overlay');
    var sliderTrack = document.getElementById('mobile-nav-track');

    function openDrawer() {
      if (!drawer) return;
      if (sliderTrack) { sliderTrack.style.transform = 'translateX(0%)'; sliderTrack.setAttribute('data-current-level', '1'); }
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      if (!drawer) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    if (hamburger) hamburger.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);

    document.querySelectorAll('.mobile-slide-next-trigger').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var nextPanelId = this.getAttribute('data-next-panel');
        var targetPanel = document.getElementById(nextPanelId);
        if (targetPanel) {
          var currentLevel = parseInt(sliderTrack.getAttribute('data-current-level') || '1', 10);
          var nextLevel = currentLevel + 1;
          
          document.querySelectorAll('.mobile-nav-level--sub').forEach(function(p) { p.style.display = 'none'; });
          targetPanel.style.display = 'block';
          
          if (sliderTrack) {
            var shiftAmount = (nextLevel - 1) * -100;
            sliderTrack.style.transform = 'translateX(' + shiftAmount + '%)';
            sliderTrack.setAttribute('data-current-level', nextLevel.toString());
          }
        }
      });
    });

    document.querySelectorAll('.mobile-slide-back-trigger').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var targetLevel = parseInt(this.getAttribute('data-back-to') || '1', 10);
        if (sliderTrack) {
          var shiftAmount = (targetLevel - 1) * -100;
          sliderTrack.style.transform = 'translateX(' + shiftAmount + '%)';
          sliderTrack.setAttribute('data-current-level', targetLevel.toString());
        }
      });
    });

    var searchOverlay = document.getElementById('header-search-overlay');
    var searchInput = document.getElementById('header-search-input');
    var searchClear = document.getElementById('header-search-clear');
    var searchBackdrop = document.getElementById('header-search-backdrop');
    var searchBtns = document.querySelectorAll('.header-icon-btn--search, .header-icon-btn--search-mobile');
    var searchResults = document.getElementById('header-search-results');
    var suggestionsEl = document.getElementById('header-search-suggestions');
    var productsEl = document.getElementById('header-search-products');
    var viewAllEl = document.getElementById('header-search-view-all');
    var predictiveTimer = null;

    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.add('is-open');
      searchOverlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (searchInput) { setTimeout(function() { searchInput.focus(); }, 50); }
    }
    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    searchBtns.forEach(function(btn) { btn.addEventListener('click', openSearch); });
    if (searchBackdrop) searchBackdrop.addEventListener('click', closeSearch);
    var searchCloseBtn = document.getElementById('header-search-close');
    if (searchCloseBtn) searchCloseBtn.addEventListener('click', closeSearch);
  })();

  (function() {
    var items = document.querySelectorAll('.header-promo-bar__item');
    if (items.length < 2) return;
    var current = 0;
    setInterval(function() {
      var next = (current + 1) % items.length;
      items[current].classList.add('is-exiting');
      items[current].classList.remove('is-active');
      items[next].classList.add('is-active');
      var exiting = items[current];
      setTimeout(function() { exiting.classList.remove('is-exiting'); }, 450);
      current = next;
    }, 3500);
  })();
{% endjavascript %}

