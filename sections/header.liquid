<div class="site-header" id="site-header">
{% comment %} Mobile promo bar — outside topbar-wrap so it shows on mobile {% endcomment %}
<div class="header-promo-bar">
  <p class="header-promo-bar__text">{{ section.settings.promo_text }}</p>
</div>

<div class="site-header__topbar-wrap">
{% comment %} Row 1: Top bar {% endcomment %}
<div class="header-topbar">
  <div class="header-topbar__inner">
    <nav class="header-topbar__nav" aria-label="{{ 'header.top_nav_label' | t }}">
      {% for link in section.settings.top_menu.links %}
        <a href="{{ link.url }}" class="header-topbar__link"{% if link.type == 'http' %} target="_blank" rel="noopener"{% endif %}>{{ link.title }}</a>
      {% endfor %}
    </nav>
    <p class="header-topbar__contact">
      {{ 'header.whatsapp_text' | t }}
      <a href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: '-' | remove: ' ' }}" class="header-topbar__phone">{{ section.settings.whatsapp_number }}</a>
    </p>
  </div>
</div>
</div>{% comment %} /site-header__topbar-wrap {% endcomment %}
<div class="site-header__sticky">
{% comment %} Row 2: Logo + Icons {% endcomment %}
<div class="header-main">
  <div class="header-main__inner">

    <div class="header-main__left">
      <button class="header-hamburger" aria-label="{{ 'header.menu_label' | t }}" aria-expanded="false" aria-controls="mobile-nav-drawer">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M2.5 5H17.5M2.5 10H17.5M2.5 15H17.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <button class="header-icon-btn header-icon-btn--search header-icon-btn--search-mobile" aria-label="{{ 'header.search_label' | t }}">
        {{ 'icon-search.svg' | inline_asset_content }}
      </button>
    </div>

    <div class="header-main__spacer" aria-hidden="true"></div>

    <div class="header-main__logo{% if section.settings.logo_mobile %} has-mobile-logo{% endif %}">
      {%- if section.settings.logo_mobile -%}
        <a href="{{ routes.root_url }}" class="header-main__logo-link--mobile">
          {{- section.settings.logo_mobile | image_url: width: 320 | image_tag:
              alt: shop.name,
              class: 'header-main__logo-img',
              widths: '160, 320',
              sizes: '160px'
          -}}
        </a>
      {%- endif -%}
      {%- if section.settings.logo -%}
        <a href="{{ routes.root_url }}" class="header-main__logo-link--desktop">
          {{- section.settings.logo | image_url: width: 440 | image_tag:
              alt: shop.name,
              class: 'header-main__logo-img',
              widths: '220, 440, 660',
              sizes: '220px'
          -}}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="header-main__shop-name header-main__logo-link--desktop">{{ shop.name }}</a>
      {%- endif -%}
    </div>

    <div class="header-main__icons">
      <button class="header-icon-btn header-icon-btn--search" aria-label="{{ 'header.search_label' | t }}">
        {{ 'icon-search.svg' | inline_asset_content }}
      </button>

      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="header-icon-btn header-icon-btn--account-desktop" aria-label="{{ 'header.account_label' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}

      <a href="/pages/wishlist" class="header-icon-btn header-icon-btn--wishlist" aria-label="{{ 'header.wishlist_label' | t }}">
        {{ 'icon-wishlist.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="header-wishlist-count">0</span>
        {% endif %}
      </a>

      <a href="{{ routes.cart_url }}" class="header-icon-btn header-icon-btn--cart" aria-label="{{ 'header.cart_label' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="header-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

  </div>
</div>

{% comment %} Mobile nav drawer {% endcomment %}
<div class="mobile-nav-drawer" id="mobile-nav-drawer" aria-hidden="true">
  <div class="mobile-nav-drawer__overlay"></div>
  <div class="mobile-nav-drawer__panel">
    <button class="mobile-nav-drawer__close" aria-label="{{ 'header.close_menu_label' | t }}">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>
    <nav aria-label="{{ 'header.main_nav_label' | t }}">
      <ul class="mobile-nav-drawer__list">
        {% for link in section.settings.menu.links %}
          <li class="mobile-nav-drawer__item{% if link.links.size > 0 %} mobile-nav-drawer__item--has-children{% endif %}">
            {% if link.links.size > 0 %}
              <button class="mobile-nav-drawer__link mobile-nav-drawer__toggle" aria-expanded="false">
                {{- link.title -}}
                <svg class="mobile-nav-drawer__chevron" width="12" height="12" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="mobile-nav-drawer__sub">
                {% for child_link in link.links %}
                  <li><a href="{{ child_link.url }}" class="mobile-nav-drawer__sub-link"{% if child_link.type == 'http' %} target="_blank" rel="noopener"{% endif %}>{{ child_link.title }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <a href="{{ link.url }}" class="mobile-nav-drawer__link"{% if link.type == 'http' %} target="_blank" rel="noopener"{% endif %}>{{- link.title -}}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</div>

{% comment %} Row 3: Category nav + mega menus {% endcomment %}
<nav class="header-nav" aria-label="{{ 'header.main_nav_label' | t }}">
  <ul class="header-nav__list">
    {% for link in section.settings.menu.links %}
      {%- assign mega = nil -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'mega_menu' and block.settings.nav_link == link.title -%}
          {%- assign mega = block -%}
        {%- endif -%}
      {%- endfor -%}

      <li class="header-nav__item{% if mega or link.links.size > 0 %} header-nav__item--has-dropdown{% if mega %} header-nav__item--mega{% endif %}{% endif %}">
        <a href="{{ link.url }}" class="header-nav__link"{% if link.type == 'http' %} target="_blank" rel="noopener"{% endif %}>
          {{- link.title -}}
          {% if mega or link.links.size > 0 %}
            <svg class="header-nav__chevron" aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
        </a>

        {% if mega %}
          <div class="mega-menu" {{ mega.shopify_attributes }}>
            <div class="mega-menu__inner">

              {% comment %} Columns {% endcomment %}
              <div class="mega-menu__cols">
                {% if mega.settings.col1_menu != blank %}
                  <div class="mega-menu__col">
                    {% if mega.settings.col1_heading != blank %}
                      <p class="mega-menu__col-heading">{{ mega.settings.col1_heading }}</p>
                    {% endif %}
                    <ul class="mega-menu__links">
                      {% for item in linklists[mega.settings.col1_menu].links %}
                        <li>
                          <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.type == 'http' %} target="_blank" rel="noopener"{% endif %}>
                            {{ item.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% if mega.settings.col2_menu != blank %}
                  <div class="mega-menu__col">
                    {% if mega.settings.col2_heading != blank %}
                      <p class="mega-menu__col-heading">{{ mega.settings.col2_heading }}</p>
                    {% endif %}
                    <ul class="mega-menu__links">
                      {% for item in linklists[mega.settings.col2_menu].links %}
                        <li>
                          <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.type == 'http' %} target="_blank" rel="noopener"{% endif %}>
                            {{ item.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% if mega.settings.col3_menu != blank %}
                  <div class="mega-menu__col">
                    {% if mega.settings.col3_heading != blank %}
                      <p class="mega-menu__col-heading">{{ mega.settings.col3_heading }}</p>
                    {% endif %}
                    <ul class="mega-menu__links">
                      {% for item in linklists[mega.settings.col3_menu].links %}
                        <li>
                          <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.type == 'http' %} target="_blank" rel="noopener"{% endif %}>
                            {{ item.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

              {% comment %} Image cards {% endcomment %}
              {% if mega.settings.card1_image or mega.settings.card2_image or mega.settings.card3_image %}
                <div class="mega-menu__cards">
                  {% if mega.settings.card1_image %}
                    <a href="{{ mega.settings.card1_url | default: '#' }}" class="mega-menu__card">
                      {{ mega.settings.card1_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card1_label | escape }}
                      <div class="mega-menu__card-gradient"></div>
                      {% if mega.settings.card1_label != blank %}
                        <span class="mega-menu__card-label">{{ mega.settings.card1_label }}</span>
                      {% endif %}
                    </a>
                  {% endif %}
                  {% if mega.settings.card2_image %}
                    <a href="{{ mega.settings.card2_url | default: '#' }}" class="mega-menu__card">
                      {{ mega.settings.card2_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card2_label | escape }}
                      <div class="mega-menu__card-gradient"></div>
                      {% if mega.settings.card2_label != blank %}
                        <span class="mega-menu__card-label">{{ mega.settings.card2_label }}</span>
                      {% endif %}
                    </a>
                  {% endif %}
                  {% if mega.settings.card3_image %}
                    <a href="{{ mega.settings.card3_url | default: '#' }}" class="mega-menu__card">
                      {{ mega.settings.card3_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card3_label | escape }}
                      <div class="mega-menu__card-gradient"></div>
                      {% if mega.settings.card3_label != blank %}
                        <span class="mega-menu__card-label">{{ mega.settings.card3_label }}</span>
                      {% endif %}
                    </a>
                  {% endif %}
                </div>
              {% endif %}

            </div>
          </div>

        {% elsif link.links.size > 0 %}
          <ul class="header-nav__dropdown">
            {% for child_link in link.links %}
              <li>
                <a href="{{ child_link.url }}" class="header-nav__dropdown-link"{% if child_link.type == 'http' %} target="_blank" rel="noopener"{% endif %}>{{ child_link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
</div>{% comment %} /site-header__sticky {% endcomment %}
</div>{% comment %} /site-header {% endcomment %}

{% comment %} Search overlay {% endcomment %}
<div class="header-search-overlay" id="header-search-overlay" aria-hidden="true" role="dialog" aria-label="{{ 'search.title' | t }}">
  <div class="header-search-overlay__backdrop" id="header-search-backdrop"></div>
  <div class="header-search-overlay__panel">

    {% comment %} Search input bar {% endcomment %}
    <div class="header-search-overlay__bar">
      <div class="header-search-overlay__form-wrap">
        <svg class="header-search-overlay__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <input
          class="header-search-overlay__input"
          id="header-search-input"
          type="search"
          name="q"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          aria-label="{{ 'search.placeholder' | t }}"
        >
        <button class="header-search-overlay__clear" type="button" id="header-search-clear" aria-label="Clear search">
          Clear
        </button>
      </div>
      <button class="header-search-overlay__close" type="button" id="header-search-close" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" width="24" height="24" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {% comment %} Predictive results {% endcomment %}
    <div class="header-search-results" id="header-search-results" aria-live="polite" style="display:none;">
      <div class="header-search-results__inner">
        <div class="header-search-results__col header-search-results__col--suggestions">
          <p class="header-search-results__heading">Suggestions</p>
          <ul class="header-search-suggestions" id="header-search-suggestions"></ul>
        </div>
        <div class="header-search-results__col header-search-results__col--products">
          <p class="header-search-results__heading">Products</p>
          <div class="header-search-products" id="header-search-products"></div>
        </div>
      </div>
      <div class="header-search-results__footer">
        <a class="header-search-results__view-all" id="header-search-view-all" href="{{ routes.search_url }}">
          SEARCH FOR ""
        </a>
      </div>
    </div>

  </div>
</div>

<div class="site-header-spacer" id="site-header-spacer"></div>

{% stylesheet %}
  /* ── Fixed site header wrapper ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
  }

  /* Topbar wrap — collapses on scroll */
  .site-header__topbar-wrap {
    overflow: hidden;
    max-height: 80px;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 1;
  }

  .site-header.is-scrolled .site-header__topbar-wrap {
    max-height: 0;
    opacity: 0;
  }

  /* Spacer that compensates for fixed header height */
  .site-header-spacer {
    display: block;
    height: 150px; /* fallback until JS measures actual header height */
  }

  @media screen and (max-width: 768px) {
    .site-header-spacer {
      height: 70px; /* mobile header is always 70px */
    }
  }

  /* ── Top bar ── */
  .header-topbar {
    background-color: var(--color-primary);
    color: #fff;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px var(--page-margin, 24px);
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
  }
  .header-topbar__nav {
    display: flex;
    gap: 28px;
  }
  .header-topbar__link {
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .header-topbar__link:hover { opacity: 0.85; }
  .header-topbar__contact {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    color: #fff;
    margin: 0;
  }
  .header-topbar__phone {
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
  }
  .header-topbar__phone:hover { text-decoration: underline; }

  /* ── Main row ── */
  .header-main {
    background-color: #efeee9;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-main__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin, 24px);
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    height: 80px;
  }
  .header-main__spacer {
    flex: 0 0 auto;
    width: 188px;
  }
  .header-main__logo {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .header-main__logo-img {
    max-height: 72px;
    width: auto;
    height: auto;
    display: block;
  }
  .header-main__logo-link--mobile { display: none; }
  .header-main__shop-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }
  .header-main__icons {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 0 0 auto;
  }
  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: #dddcd6;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    color: #42464b;
    padding: 0;
    position: relative;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .header-icon-btn:hover {
    background-color: var(--color-primary);
    color: #fff;
  }
  .header-icon-btn svg { width: 20px; height: 20px; }
  .header-cart-count {
    position: absolute;
    top: -5px;
    right: -5px;
    background-color: var(--color-primary);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .header-icon-btn:hover .header-cart-count {
    background-color: #fff;
    color: var(--color-primary);
  }

  /* ── Category nav ── */
  .header-nav {
    background-color: #efeee9;
    border-top: 1px solid #e0dfd9;
    border-bottom: 1px solid #e0dfd9;
    padding: 0.5rem 1rem;
    width: 100%;
  }
  .header-nav__list {
    display: flex;
    align-items: center;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: var(--page-width, 1900px);
    gap: 4px;
  }
  .header-nav__item { position: relative; }
  .header-nav__link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 16px;
    text-decoration: none;
    color: #42464b;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .header-nav__link:hover { color: var(--color-primary); }
  .header-nav__chevron {
    width: 10px;
    height: 10px;
    color: #888;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .header-nav__item--has-dropdown:hover .header-nav__chevron {
    transform: rotate(180deg);
  }

  /* ── Simple dropdown ── */
  .header-nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid #e0dfd9;
    list-style: none;
    padding: 8px 0;
    margin: 0;
    min-width: 200px;
    z-index: 100;
  }
  .header-nav__item--has-dropdown:hover .header-nav__dropdown { display: block; }
  .header-nav__dropdown-link {
    display: block;
    padding: 9px 20px;
    color: #42464b;
    text-decoration: none;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 400;
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .header-nav__dropdown-link:hover {
    background-color: #f5f4f0;
    color: var(--color-primary);
  }

  /* ── Mega menu ── */
  /*
    The mega-menu uses position:fixed so it escapes the site-header stacking
    context and spans the full viewport width. Its top is set by JS to match
    the bottom of the fixed header at the time of hover.
  */
  .mega-menu {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    /* top is set dynamically by JS */
    background-color: #efeee9;
    z-index: 299;
    border-top: 1px solid #e0dfd9;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .site-header__sticky {
    position: static;
  }
  .header-nav__item--mega.is-open .mega-menu { display: block; }
  .mega-menu__inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
    padding: 48px 80px 56px;
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
  }
  .mega-menu__cols {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 64px;
    flex: 1;
  }
  .mega-menu__col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
    min-width: 160px;
  }
  .mega-menu__col-heading {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 500;
    color: #42464b;
    margin: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .mega-menu__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mega-menu__link {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    color: #42464b;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .mega-menu__link:hover { color: var(--color-primary); }
  .mega-menu__link--promo { color: #ce0570; }
  .mega-menu__link--promo:hover { color: #a8045c; }

  /* Image cards */
  .mega-menu__cards {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
    flex-shrink: 0;
  }
  .mega-menu__card {
    position: relative;
    display: block;
    width: 280px;
    height: 380px;
    overflow: hidden;
    flex-shrink: 0;
    text-decoration: none;
  }
  .mega-menu__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }
  .mega-menu__card:hover .mega-menu__card-img { transform: scale(1.04); }
  .mega-menu__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(44,36,33,0.80) 0%, rgba(44,36,33,0.10) 40%, rgba(44,36,33,0) 65%);
    pointer-events: none;
  }
  .mega-menu__card-label {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    font-family: var(--font-heading--family, 'Playfair Display', serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  /* ── Promo bar (mobile only) ── */
  .header-promo-bar {
    display: none;
    background-color: #ce0570;
    padding: 7px 16px;
    text-align: center;
  }
  .header-promo-bar__text {
    color: #fff;
    font-family: var(--font-body--family, 'Poppins', sans-serif);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Left group (hamburger + mobile search) ── */
  .header-main__left {
    display: none;
    align-items: center;
    gap: 4px;
  }
  .header-icon-btn--search-mobile { display: none; }

  /* ── Hamburger (mobile only) ── */
  .header-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: #42464b;
    padding: 0;
    flex-shrink: 0;
  }

  /* ── Mobile nav drawer ── */
  .mobile-nav-drawer { display: none; }
  .mobile-nav-drawer.is-open { display: block; }
  .mobile-nav-drawer__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 200;
  }
  .mobile-nav-drawer__panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    background: #fff;
    z-index: 201;
    overflow-y: auto;
    padding: 16px 0 32px;
  }
  .mobile-nav-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: #42464b;
    margin: 0 0 8px 16px;
    padding: 0;
  }
  .mobile-nav-drawer__list { list-style: none; margin: 0; padding: 0; }
  .mobile-nav-drawer__item { border-bottom: 1px solid #f0efe9; }
  .mobile-nav-drawer__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: #42464b;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .mobile-nav-drawer__link:hover { color: var(--color-primary); }
  .mobile-nav-drawer__chevron { transition: transform 0.2s ease; flex-shrink: 0; }
  .mobile-nav-drawer__toggle[aria-expanded="true"] .mobile-nav-drawer__chevron { transform: rotate(180deg); }
  .mobile-nav-drawer__sub {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0 0 8px;
    background: #f8f7f3;
  }
  .mobile-nav-drawer__toggle[aria-expanded="true"] + .mobile-nav-drawer__sub { display: block; }
  .mobile-nav-drawer__sub-link {
    display: block;
    padding: 11px 20px 11px 32px;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    color: #42464b;
    text-decoration: none;
  }
  .mobile-nav-drawer__sub-link:hover { color: var(--color-primary); }

  /* ── Wishlist badge ── */
  .header-icon-btn--wishlist { position: relative; }
  .header-wishlist-count {
    position: absolute;
    top: -5px;
    right: -5px;
    background-color: #a42829;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── Search overlay ── */
  .header-search-overlay {
    position: fixed;
    inset: 0;
    z-index: 400;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .header-search-overlay.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .header-search-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
  }

  .header-search-overlay__panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: #f2f2f0;
    transform: translateY(-6px);
    transition: transform 0.2s ease;
    max-height: 100vh;
    overflow-y: auto;
    z-index: 401;
  }

  .header-search-overlay.is-open .header-search-overlay__panel {
    transform: translateY(0);
  }

  /* Input bar — note: top padding is set by JS to clear the fixed header */
  .header-search-overlay__bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 4rem 1.5rem;
    border-bottom: 1px solid #e0dfd9;
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
  }

  .header-search-overlay__form-wrap {
    display: flex;
    align-items: center;
    flex: 1;
    background: #e8e8e6;
    border-radius: 6px;
    padding: 0 1rem;
    height: 52px;
    gap: 0.5rem;
  }

  .header-search-overlay__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: #666;
  }

  .header-search-overlay__input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    padding: 0 0.5rem;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 1rem;
    color: #2e1f1f;
    height: 100%;
    min-width: 0;
  }

  .header-search-overlay__input::placeholder { color: #999; }

  .header-search-overlay__clear {
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.85rem;
    padding: 0 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .header-search-overlay__clear:hover { color: #2e1f1f; }

  .header-search-overlay__close {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    border-radius: 50%;
    transition: color 0.15s, background-color 0.15s;
  }
  .header-search-overlay__close:hover {
    color: #2e1f1f;
    background-color: #e8e8e6;
  }

  /* Results panel */
  .header-search-results {
    padding: 1.5rem 1.5rem 0;
  }

  .header-search-results__inner {
    display: flex;
    gap: 2rem;
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    padding-bottom: 1.5rem;
  }

  .header-search-results__col--suggestions {
    flex: 0 0 200px;
    border-right: 1px solid #e0dfd9;
    padding-right: 2rem;
  }

  .header-search-results__col--products {
    flex: 1;
    min-width: 0;
  }

  .header-search-results__heading {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #999;
    margin: 0 0 1rem;
  }

  /* Suggestions list */
  .header-search-suggestions {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .header-search-suggestions li a {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    color: #42464b;
    text-decoration: none;
    display: block;
  }

  .header-search-suggestions li a:hover { color: var(--color-primary, #2e1f1f); }

  .header-search-suggestions li a strong {
    font-weight: 700;
  }

  /* Products grid — 2 columns */
  .header-search-products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 2rem;
  }

  .header-search-product {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }

  .header-search-product__img {
    width: 72px;
    height: 88px;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: 2px;
    background: #e8e8e6;
  }

  .header-search-product__img--placeholder {
    width: 72px;
    height: 88px;
    flex-shrink: 0;
    background: #e8e8e6;
    border-radius: 2px;
  }

  .header-search-product__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 0.2rem;
  }

  .header-search-product__vendor {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
  }

  .header-search-product__title {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    color: #2e1f1f;
    line-height: 1.35;
  }

  .header-search-product__price {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    color: #2e1f1f;
    font-weight: 500;
    margin-top: 0.1rem;
  }

  .header-search-product:hover .header-search-product__title {
    text-decoration: underline;
  }

  /* Footer CTA */
  .header-search-results__footer {
    border-top: 1px solid #e0dfd9;
    padding: 1.25rem 1.5rem;
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .header-search-results__view-all {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: #2e1f1f;
    color: #fff;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
  }

  .header-search-results__view-all:hover { background: #5a3a2a; }

  .header-search-results__empty {
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
    font-size: 0.9rem;
    color: #999;
    padding: 1rem 0;
  }

  @media screen and (max-width: 768px) {
    .header-search-results__col--suggestions { display: none; }
    .header-search-products { grid-template-columns: 1fr; }
    .header-search-overlay__bar { padding: 1rem; }
  }

  /* ── Compact nav for mid-range widths ── */
  @media screen and (max-width: 1380px) {
    .header-nav__list { gap: 0; }
    .header-nav__link { padding: 10px 10px; font-size: 0.9rem; }
  }

  @media screen and (max-width: 1180px) {
    .header-nav__link { padding: 10px 7px; font-size: 0.82rem; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    /* On mobile the topbar-wrap is always collapsed — no transition needed */
    .site-header__topbar-wrap {
      max-height: 0 !important;
      opacity: 0 !important;
      transition: none !important;
    }
    .header-topbar { display: none; }
    .header-promo-bar { display: block; }
    .header-main__left { display: flex; }
    .header-hamburger { display: flex; }
    .header-icon-btn--search-mobile { display: flex; }
    .header-main__inner { height: 70px; justify-content: space-between; }
    .header-main { box-shadow: 0 1px 6px rgba(0,0,0,0.08); }
    .header-main__logo-link--mobile { display: block; }
    .has-mobile-logo .header-main__logo-link--desktop { display: none; }
    .header-main__spacer { display: none; }
    .header-main__logo { flex: 1; justify-content: center; }
    .header-main__logo-img { max-height: 56px; }
    .header-icon-btn { width: 36px; height: 36px; background: none; }
    .header-icon-btn:hover { background: none; color: var(--color-primary); }
    .header-icon-btn--account-desktop { display: none; }
    .header-icon-btn--wishlist { display: flex; }
    .header-main__icons .header-icon-btn--search { display: none; }
    .header-main__icons { gap: 4px; }
    .header-nav { display: none; }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var siteHeader = document.getElementById('site-header');
    var spacer = document.getElementById('site-header-spacer');
    var topbarWrap = siteHeader && siteHeader.querySelector('.site-header__topbar-wrap');
    var THRESHOLD = 10;

    /* ── Measure header bottom edge ── */
    function headerBottom() {
      return siteHeader ? siteHeader.getBoundingClientRect().bottom : 0;
    }

    /* ── Spacer: compensate for fixed header ── */
    function updateSpacer() {
      if (spacer && siteHeader) {
        var h = siteHeader.offsetHeight;
        if (h > 0) spacer.style.height = h + 'px';
      }
    }
    updateSpacer();
    document.addEventListener('DOMContentLoaded', updateSpacer);
    window.addEventListener('load', updateSpacer);
    window.addEventListener('resize', updateSpacer);
    if (topbarWrap) {
      topbarWrap.addEventListener('transitionend', function() {
        updateSpacer();
        updateMegaMenuTops();
      });
    }

    /* ── Mega menu: position fixed top = header bottom ── */
    function updateMegaMenuTops() {
      var bottom = headerBottom();
      document.querySelectorAll('.mega-menu').forEach(function(mm) {
        mm.style.top = bottom + 'px';
      });
    }
    updateMegaMenuTops();
    window.addEventListener('resize', updateMegaMenuTops);

    /* ── Mega menu: JS hover (CSS hover breaks with position:fixed detached menus) ── */
    document.querySelectorAll('.header-nav__item--mega').forEach(function(item) {
      var closeTimer = null;

      function openMenu() {
        clearTimeout(closeTimer);
        updateMegaMenuTops(); // ensure top is current before showing
        item.classList.add('is-open');
      }

      function scheduleClose() {
        closeTimer = setTimeout(function() {
          item.classList.remove('is-open');
        }, 80); // small delay so cursor can move into the mega menu
      }

      var megaMenu = item.querySelector('.mega-menu');

      item.addEventListener('mouseenter', openMenu);
      item.addEventListener('mouseleave', scheduleClose);

      if (megaMenu) {
        megaMenu.addEventListener('mouseenter', function() {
          clearTimeout(closeTimer);
        });
        megaMenu.addEventListener('mouseleave', scheduleClose);
      }
    });

    /* ── Scroll: hide topbar ── */
    function onScroll() {
      if (window.scrollY > THRESHOLD) {
        siteHeader.classList.add('is-scrolled');
      } else {
        siteHeader.classList.remove('is-scrolled');
      }
      updateSpacer();
      updateMegaMenuTops();
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    /* ── Mobile drawer ── */
    var hamburger = document.querySelector('.header-hamburger');
    var drawer = document.getElementById('mobile-nav-drawer');
    var closeBtn = document.querySelector('.mobile-nav-drawer__close');
    var overlay = document.querySelector('.mobile-nav-drawer__overlay');

    function openDrawer() {
      if (!drawer) return;
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      if (!drawer) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (hamburger) hamburger.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);

    document.querySelectorAll('.mobile-nav-drawer__toggle').forEach(function(toggle) {
      toggle.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      });
    });

    /* ── Search overlay ── */
    var searchOverlay  = document.getElementById('header-search-overlay');
    var searchInput    = document.getElementById('header-search-input');
    var searchClear    = document.getElementById('header-search-clear');
    var searchBackdrop = document.getElementById('header-search-backdrop');
    var searchBtn      = document.querySelector('.header-icon-btn--search');
    var searchBtns     = document.querySelectorAll('.header-icon-btn--search');
    var searchResults  = document.getElementById('header-search-results');
    var suggestionsEl  = document.getElementById('header-search-suggestions');
    var productsEl     = document.getElementById('header-search-products');
    var viewAllEl      = document.getElementById('header-search-view-all');
    var predictiveTimer = null;

    function positionPanel() {
      /* no-op: panel is fixed at top:0 via CSS */
    }

    function openSearch() {
      if (!searchOverlay) return;
      positionPanel();
      searchOverlay.classList.add('is-open');
      searchOverlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (searchInput) { setTimeout(function() { searchInput.focus(); }, 50); }
    }

    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (searchInput) searchInput.value = '';
      if (searchResults) searchResults.style.display = 'none';
    }

    /* Predictive search using Shopify /search/suggest.json */
    function renderSuggestions(queries, term) {
      if (!suggestionsEl) return;
      suggestionsEl.innerHTML = '';
      queries.slice(0, 6).forEach(function(q) {
        var li = document.createElement('li');
        var a  = document.createElement('a');
        a.href = '/search?type=product&q=' + encodeURIComponent(q.text);
        /* bold the part that matches the typed term */
        var label = q.text;
        var idx = label.toLowerCase().indexOf(term.toLowerCase());
        if (idx > -1) {
          var before = label.slice(0, idx);
          var match  = label.slice(idx, idx + term.length);
          var after  = label.slice(idx + term.length);
          a.innerHTML = (before ? escHtml(before) : '') +
                        '<strong>' + escHtml(match) + '</strong>' +
                        escHtml(after);
        } else {
          a.textContent = label;
        }
        li.appendChild(a);
        suggestionsEl.appendChild(li);
      });
    }

    function renderProducts(products) {
      if (!productsEl) return;
      productsEl.innerHTML = '';
      if (products.length === 0) {
        productsEl.innerHTML = '<p class="header-search-results__empty">No products found.</p>';
        return;
      }
      products.slice(0, 4).forEach(function(p) {
        var a = document.createElement('a');
        a.className = 'header-search-product';
        a.href = p.url;
        var imgHtml = p.featured_image && p.featured_image.url
          ? '<img class="header-search-product__img" src="' + p.featured_image.url + '&width=144" alt="' + escHtml(p.title) + '" width="72" height="88" loading="lazy">'
          : '<div class="header-search-product__img--placeholder"></div>';
        var priceRaw = p.price_min ? parseFloat(p.price_min) : 0;
        var price = priceRaw ? formatMoney(priceRaw * 100) : '';
        a.innerHTML = imgHtml +
          '<div class="header-search-product__info">' +
            (p.vendor ? '<span class="header-search-product__vendor">' + escHtml(p.vendor) + '</span>' : '') +
            '<span class="header-search-product__title">' + escHtml(p.title) + '</span>' +
            (price ? '<span class="header-search-product__price">From ' + price + '</span>' : '') +
          '</div>';
        productsEl.appendChild(a);
      });
    }

    function formatMoney(cents) {
      var fmt = window.shopMoneyFormat || 'Rs. {{amount}}';
      var val = cents / 100;
      var amt   = val.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      var amtNd = Math.floor(val).toLocaleString('en-IN');
      return fmt
        .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/, amtNd)
        .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, amt)
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/, amtNd)
        .replace(/\{\{\s*amount\s*\}\}/, amt);
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function runPredictive(term) {
      if (!term || term.length < 2) {
        if (searchResults) searchResults.style.display = 'none';
        return;
      }
      var url = '/search/suggest.json?q=' + encodeURIComponent(term) +
                '&resources[type]=product,query&resources[limit]=6' +
                '&resources[options][unavailable_products]=last' +
                '&resources[options][fields]=title,product_type,variants.title,vendor';
      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var res        = data.resources && data.resources.results;
          var products   = (res && res.products)   || [];
          var queries    = (res && res.queries)     || [];
          renderSuggestions(queries, term);
          renderProducts(products);
          if (viewAllEl) {
            viewAllEl.textContent = 'SEARCH FOR "' + term.toUpperCase() + '"';
            viewAllEl.href = '/search?type=product&q=' + encodeURIComponent(term);
          }
          if (searchResults) searchResults.style.display = 'block';
        })
        .catch(function() {});
    }

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var val = this.value.trim();
        /* clear button always visible — no toggle needed */
        clearTimeout(predictiveTimer);
        predictiveTimer = setTimeout(function() { runPredictive(val); }, 220);
      });
    }

    if (searchClear) {
      searchClear.addEventListener('click', function() {
        if (searchInput) { searchInput.value = ''; searchInput.focus(); }
        if (searchResults) searchResults.style.display = 'none';
      });
    }

    searchBtns.forEach(function(btn) { btn.addEventListener('click', openSearch); });
    if (searchBackdrop) searchBackdrop.addEventListener('click', closeSearch);
    var searchCloseBtn = document.getElementById('header-search-close');
    if (searchCloseBtn) searchCloseBtn.addEventListener('click', closeSearch);

    window.addEventListener('resize', positionPanel);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchOverlay && searchOverlay.classList.contains('is-open')) {
        closeSearch();
      }
    });
  })();
{% endjavascript %}

