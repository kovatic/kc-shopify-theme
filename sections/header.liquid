  .header-login-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 16px;
    background-color: var(--color-primary);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    border-radius: 5px;
    text-decoration: none;
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: #dddcd6;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    color: #42464b;
    position: relative;
    text-decoration: none;
  }
  .header-icon-btn:hover {
    background-color: var(--color-primary);
    color: #fff;
  }
  .header-icon-btn svg { width: 20px; height: 20px; }
  .header-cart-count, .header-wishlist-count {
    position: absolute;
    top: -5px;
    right: -5px;
