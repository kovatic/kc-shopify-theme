{% comment %} Row 1: Top bar {% endcomment %}
<div class="header-topbar">
  <div class="header-topbar__inner">
    <nav class="header-topbar__nav" aria-label="{{ 'header.top_nav_label' | t }}">
      {% for link in section.settings.top_menu.links %}
        <a href="{{ link.url }}" class="header-topbar__link">{{ link.title }}</a>
      {% endfor %}
    </nav>
    <p class="header-topbar__contact">
      {{ 'header.whatsapp_text' | t }}
      <a href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: '-' | remove: ' ' }}" class="header-topbar__phone">{{ section.settings.whatsapp_number }}</a>
    </p>
  </div>
</div>

{% comment %} Mobile promo bar {% endcomment %}
<div class="header-promo-bar">
  <p class="header-promo-bar__text">{{ section.settings.promo_text }}</p>
</div>

{% comment %} Row 2: Logo + Icons {% endcomment %}
<div class="header-main">
  <div class="header-main__inner">

    {% comment %} Hamburger — mobile only {% endcomment %}
    <button class="header-hamburger" aria-label="{{ 'header.menu_label' | t }}" aria-expanded="false" aria-controls="mobile-nav-drawer">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M2.5 5H17.5M2.5 10H17.5M2.5 15H17.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>

    {% comment %} Spacer left — mirrors icon group width so logo is truly centered (desktop only) {% endcomment %}
    <div class="header-main__spacer" aria-hidden="true"></div>

    <div class="header-main__logo">
      {% if section.settings.logo %}
        <a href="{{ routes.root_url }}">
          {{- section.settings.logo | image_url: width: 220 | image_tag: alt: shop.name, class: 'header-main__logo-img' -}}
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="header-main__shop-name">{{ shop.name }}</a>
      {% endif %}
    </div>

    <div class="header-main__icons">
      <button class="header-icon-btn" aria-label="{{ 'header.search_label' | t }}">
        {{ 'icon-search.svg' | inline_asset_content }}
      </button>

      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="header-icon-btn header-icon-btn--account-desktop" aria-label="{{ 'header.account_label' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}

      <a href="{{ routes.search_url }}?type=product&q=wishlist" class="header-icon-btn header-icon-btn--wishlist" aria-label="{{ 'header.wishlist_label' | t }}">
        {{ 'icon-wishlist.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="header-wishlist-count">0</span>
        {% endif %}
      </a>

      <a href="{{ routes.cart_url }}" class="header-icon-btn header-icon-btn--cart" aria-label="{{ 'header.cart_label' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="header-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

  </div>
</div>

{% comment %} Mobile nav drawer {% endcomment %}
<div class="mobile-nav-drawer" id="mobile-nav-drawer" aria-hidden="true">
  <div class="mobile-nav-drawer__overlay"></div>
  <div class="mobile-nav-drawer__panel">
    <button class="mobile-nav-drawer__close" aria-label="{{ 'header.close_menu_label' | t }}">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>
    <nav aria-label="{{ 'header.main_nav_label' | t }}">
      <ul class="mobile-nav-drawer__list">
        {% for link in section.settings.menu.links %}
          <li class="mobile-nav-drawer__item{% if link.links.size > 0 %} mobile-nav-drawer__item--has-children{% endif %}">
            {% if link.links.size > 0 %}
              <button class="mobile-nav-drawer__link mobile-nav-drawer__toggle" aria-expanded="false">
                {{- link.title -}}
                <svg class="mobile-nav-drawer__chevron" width="12" height="12" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="mobile-nav-drawer__sub">
                {% for child_link in link.links %}
                  <li><a href="{{ child_link.url }}" class="mobile-nav-drawer__sub-link">{{ child_link.title }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <a href="{{ link.url }}" class="mobile-nav-drawer__link">{{- link.title -}}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</div>

{% comment %} Row 3: Category nav {% endcomment %}
<nav class="header-nav" aria-label="{{ 'header.main_nav_label' | t }}">
  <ul class="header-nav__list">
    {% for link in section.settings.menu.links %}
      {%- assign link_index = forloop.index0 -%}
      {%- assign mega_blocks = section.blocks | where: 'type', 'mega_menu' -%}
      {%- assign has_mega = false -%}
      {%- for mb in mega_blocks -%}
        {%- if mb.settings.nav_link_title == link.title -%}
          {%- assign has_mega = true -%}
          {%- assign mega_block = mb -%}
        {%- endif -%}
      {%- endfor -%}

      <li class="header-nav__item{% if link.links.size > 0 %} header-nav__item--has-dropdown{% if has_mega %} header-nav__item--mega{% endif %}{% endif %}">
        <a href="{{ link.url }}" class="header-nav__link">
          {{- link.title -}}
          {% if link.links.size > 0 %}
            <svg class="header-nav__chevron" aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
        </a>

        {% if link.links.size > 0 %}
          {% if has_mega %}
            {% comment %} Mega menu panel {% endcomment %}
            <div class="mega-menu">
              <div class="mega-menu__inner">

                {% comment %} Column 1: first half of child links {% endcomment %}
                {%- assign half = link.links.size | divided_by: 2 -%}
                <div class="mega-menu__col">
                  <p class="mega-menu__col-heading">{{ mega_block.settings.col1_heading | default: link.title }}</p>
                  <ul class="mega-menu__links">
                    {% for child_link in link.links %}
                      {% if forloop.index0 < half %}
                        <li>
                          <a href="{{ child_link.url }}" class="mega-menu__link{% if child_link.title contains '₹' %} mega-menu__link--promo{% endif %}">
                            {{ child_link.title }}
                          </a>
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>

                {% comment %} Column 2: second half of child links {% endcomment %}
                {% if mega_block.settings.col2_heading != blank %}
                  <div class="mega-menu__col">
                    <p class="mega-menu__col-heading">{{ mega_block.settings.col2_heading }}</p>
                    <ul class="mega-menu__links">
                      {% for child_link in link.links %}
                        {% if forloop.index0 >= half %}
                          <li>
                            <a href="{{ child_link.url }}" class="mega-menu__link{% if child_link.title contains '₹' %} mega-menu__link--promo{% endif %}">
                              {{ child_link.title }}
                            </a>
                          </li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% comment %} Image cards {% endcomment %}
                {% if mega_block.settings.card1_image or mega_block.settings.card2_image or mega_block.settings.card3_image %}
                  <div class="mega-menu__cards">
                    {% if mega_block.settings.card1_image %}
                      <a href="{{ mega_block.settings.card1_url | default: '#' }}" class="mega-menu__card">
                        {{ mega_block.settings.card1_image | image_url: width: 500 | image_tag: class: 'mega-menu__card-img', alt: mega_block.settings.card1_label | escape }}
                        <div class="mega-menu__card-gradient"></div>
                        {% if mega_block.settings.card1_label != blank %}
                          <span class="mega-menu__card-label">{{ mega_block.settings.card1_label }}</span>
                        {% endif %}
                      </a>
                    {% endif %}
                    {% if mega_block.settings.card2_image %}
                      <a href="{{ mega_block.settings.card2_url | default: '#' }}" class="mega-menu__card">
                        {{ mega_block.settings.card2_image | image_url: width: 500 | image_tag: class: 'mega-menu__card-img', alt: mega_block.settings.card2_label | escape }}
                        <div class="mega-menu__card-gradient"></div>
                        {% if mega_block.settings.card2_label != blank %}
                          <span class="mega-menu__card-label">{{ mega_block.settings.card2_label }}</span>
                        {% endif %}
                      </a>
                    {% endif %}
                    {% if mega_block.settings.card3_image %}
                      <a href="{{ mega_block.settings.card3_url | default: '#' }}" class="mega-menu__card">
                        {{ mega_block.settings.card3_image | image_url: width: 500 | image_tag: class: 'mega-menu__card-img', alt: mega_block.settings.card3_label | escape }}
                        <div class="mega-menu__card-gradient"></div>
                        {% if mega_block.settings.card3_label != blank %}
                          <span class="mega-menu__card-label">{{ mega_block.settings.card3_label }}</span>
                        {% endif %}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}

              </div>
            </div>
          {% else %}
            {% comment %} Simple dropdown {% endcomment %}
            <ul class="header-nav__dropdown">
              {% for child_link in link.links %}
                <li>
                  <a href="{{ child_link.url }}" class="header-nav__dropdown-link">{{ child_link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>

{% stylesheet %}
  /* ── Top bar ── */
  .header-topbar {
    background-color: var(--color-primary);
    color: #fff;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px var(--page-margin, 24px);
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
  }
  .header-topbar__nav {
    display: flex;
    gap: 28px;
  }
  .header-topbar__link {
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .header-topbar__link:hover {
    opacity: 0.85;
  }
  .header-topbar__contact {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.8rem !important;
    color: #fff;
    margin: 0;
  }
  .header-topbar__phone {
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem !important
    text-decoration: none;
  }
  .header-topbar__phone:hover {
    text-decoration: underline;
  }

  /* ── Main row ── */
  .header-main {
    background-color: #efeee9;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-main__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin, 24px);
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    height: 80px;
  }
  .header-main__spacer {
    /* mirrors .header-main__icons width so logo stays centered */
    flex: 0 0 auto;
    width: 188px;
  }
  .header-main__logo {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .header-main__logo-img {
    max-height: 56px;
    width: auto;
    height: auto;
    display: block;
  }
  .header-main__shop-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }
  .header-main__icons {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 0 0 auto;
  }
  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: #dddcd6;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    color: #42464b;
    padding: 0;
    position: relative;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .header-icon-btn:hover {
    background-color: var(--color-primary);
    color: #fff;
  }
  .header-icon-btn svg {
    width: 20px;
    height: 20px;
  }
  .header-cart-count {
    position: absolute;
    top: -5px;
    right: -5px;
    background-color: var(--color-primary);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .header-icon-btn:hover .header-cart-count {
    background-color: #fff;
    color: var(--color-primary);
  }

  /* ── Category nav ── */
  .header-nav {
    background-color: #efeee9;
    border-top: 1px solid #e0dfd9;
    padding: 0.5rem 1rem;
    width: 100%;
  }
  .header-nav__list {
    display: flex;
    align-items: center;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: var(--page-width, 1400px);
    gap: 4px;
  }
  .header-nav__item {
    position: relative;
  }
  .header-nav__link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 16px;
    text-decoration: none;
    color: #42464b;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .header-nav__link:hover {
    color: var(--color-primary);
  }
  .header-nav__chevron {
    width: 10px;
    height: 10px;
    color: #888;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .header-nav__item--has-dropdown:hover .header-nav__chevron {
    transform: rotate(180deg);
  }

  /* ── Simple dropdown ── */
  .header-nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid #e0dfd9;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    list-style: none;
    padding: 8px 0;
    margin: 0;
    min-width: 200px;
    z-index: 100;
  }
  .header-nav__item--has-dropdown:hover .header-nav__dropdown {
    display: block;
  }
  .header-nav__dropdown-link {
    display: block;
    padding: 9px 20px;
    color: #42464b;
    text-decoration: none;
    font-family: var(--font-primary--family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 400;
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .header-nav__dropdown-link:hover {
    background-color: #f5f4f0;
    color: var(--color-primary);
  }

  /* ── Mega menu ── */
  .mega-menu {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    background-color: #efeee9;
    z-index: 99;
    border-top: 1px solid #e0dfd9;
  }
  .header-nav__item--mega:hover .mega-menu {
    display: block;
  }
  .mega-menu__inner {
    display: flex;
    align-items: flex-start;
    gap: 72px;
    padding: 48px 80px 56px;
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
  }

  /* Link columns */
  .mega-menu__col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
    min-width: 160px;
  }
  .mega-menu__col-heading {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 500;
    color: #42464b;
    margin: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .mega-menu__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mega-menu__link {
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 400;
    color: #42464b;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .mega-menu__link:hover {
    color: var(--color-primary);
  }
  .mega-menu__link--promo {
    color: #ce0570;
  }
  .mega-menu__link--promo:hover {
    color: #a8045c;
  }

  /* Image cards */
  .mega-menu__cards {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
  }
  .mega-menu__card {
    position: relative;
    display: block;
    width: 290px;
    height: 390px;
    overflow: hidden;
    flex-shrink: 0;
    text-decoration: none;
  }
  .mega-menu__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }
  .mega-menu__card:hover .mega-menu__card-img {
    transform: scale(1.04);
  }
  .mega-menu__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(44,36,33,0.80) 0%,
      rgba(44,36,33,0.10) 40%,
      rgba(44,36,33,0) 65%
    );
    pointer-events: none;
  }
  .mega-menu__card-label {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    font-family: var(--font-heading--family, 'Playfair Display', serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }

  /* ── Promo bar (mobile only) ── */
  .header-promo-bar {
    display: none;
    background-color: #ce0570;
    padding: 7px 16px;
    text-align: center;
  }
  .header-promo-bar__text {
    color: #fff;
    font-family: var(--font-body--family, 'Poppins', sans-serif);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Hamburger (mobile only) ── */
  .header-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: #42464b;
    padding: 0;
    flex-shrink: 0;
  }

  /* ── Mobile nav drawer ── */
  .mobile-nav-drawer {
    display: none;
  }
  .mobile-nav-drawer.is-open {
    display: block;
  }
  .mobile-nav-drawer__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 200;
  }
  .mobile-nav-drawer__panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    background: #fff;
    z-index: 201;
    overflow-y: auto;
    padding: 16px 0 32px;
    transform: translateX(0);
  }
  .mobile-nav-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: #42464b;
    margin: 0 0 8px 16px;
    padding: 0;
  }
  .mobile-nav-drawer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mobile-nav-drawer__item {
    border-bottom: 1px solid #f0efe9;
  }
  .mobile-nav-drawer__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: #42464b;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .mobile-nav-drawer__link:hover {
    color: var(--color-primary);
  }
  .mobile-nav-drawer__chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .mobile-nav-drawer__toggle[aria-expanded="true"] .mobile-nav-drawer__chevron {
    transform: rotate(180deg);
  }
  .mobile-nav-drawer__sub {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0 0 8px;
    background: #f8f7f3;
  }
  .mobile-nav-drawer__toggle[aria-expanded="true"] + .mobile-nav-drawer__sub {
    display: block;
  }
  .mobile-nav-drawer__sub-link {
    display: block;
    padding: 11px 20px 11px 32px;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    color: #42464b;
    text-decoration: none;
  }
  .mobile-nav-drawer__sub-link:hover {
    color: var(--color-primary);
  }

  /* ── Wishlist count badge ── */
  .header-icon-btn--wishlist {
    position: relative;
  }
  .header-wishlist-count {
    position: absolute;
    top: -5px;
    right: -5px;
    background-color: #a42829;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .header-topbar {
      display: none;
    }
    .header-promo-bar {
      display: block;
    }
    .header-hamburger {
      display: flex;
    }
    .header-main__inner {
      height: 70px;
      justify-content: space-between;
    }
    .header-main__spacer {
      display: none;
    }
    .header-main__logo {
      flex: 1;
      justify-content: center;
    }
    .header-main__logo-img {
      max-height: 44px;
    }
    .header-icon-btn {
      width: 36px;
      height: 36px;
      background: none;
    }
    .header-icon-btn:hover {
      background: none;
      color: var(--color-primary);
    }
    .header-icon-btn--account-desktop {
      display: none;
    }
    .header-main__icons {
      gap: 4px;
    }
    .header-nav {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var hamburger = document.querySelector('.header-hamburger');
    var drawer = document.getElementById('mobile-nav-drawer');
    var closeBtn = document.querySelector('.mobile-nav-drawer__close');
    var overlay = document.querySelector('.mobile-nav-drawer__overlay');

    function openDrawer() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (hamburger) hamburger.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);

    document.querySelectorAll('.mobile-nav-drawer__toggle').forEach(function(toggle) {
      toggle.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      });
    });
  })();
{% endjavascript %}

