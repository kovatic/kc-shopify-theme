<div class="site-header" id="site-header">
  {% comment %} Mobile promo bar — outside topbar-wrap so it shows on mobile {% endcomment %}
  <div class="header-promo-bar">
    <div class="header-promo-bar__track" aria-live="polite">
      {%- assign promo_str = '' -%}
      {%- for i in (1..5) -%}
        {%- assign key = 'promo_text_' | append: i -%}
        {%- assign val = section.settings[key] -%}
        {%- if val != blank -%}
          {%- if promo_str != '' -%}{%- assign promo_str = promo_str | append: '|||' -%}{%- endif -%}
          {%- assign promo_str = promo_str | append: val -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if promo_str == blank -%}
        <p class="header-promo-bar__item is-active">{{ section.settings.promo_text_1 | default: 'Free Shipping on Orders Above ₹2,999' }}</p>
      {%- else -%}
        {%- assign promo_items = promo_str | split: '|||' -%}
        {%- for item in promo_items -%}
          <p class="header-promo-bar__item{% if forloop.first %} is-active{% endif %}">{{ item }}</p>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.top_menu.links.size > 0 -%}
    <div class="site-header__topbar-wrap">
      {% comment %} Row 1: Top bar {% endcomment %}
      <div class="header-topbar">
        <div class="header-topbar__inner">
          <nav class="header-topbar__nav" aria-label="{{ 'header.top_nav_label' | t }}">
            {% for link in section.settings.top_menu.links %}
              <a href="{{ link.url }}" class="header-topbar__link"{% if link.url contains 'http' %} target="_blank" rel="noopener"{% endif %}>{{ link.title }}</a>
            {% endfor %}
          </nav>
        </div>
      </div>
    </div>{% comment %} /site-header__topbar-wrap {% endcomment %}
  {%- endif -%}

  <div class="site-header__sticky">
    {% comment %} Row 2: Logo + Icons {% endcomment %}
    <div class="header-main">
      <div class="header-main__inner">

        <div class="header-main__left">
          <button class="header-hamburger" aria-label="{{ 'header.menu_label' | t }}" aria-expanded="false" aria-controls="mobile-nav-drawer">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2.5 5H17.5M2.5 10H17.5M2.5 15H17.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </button>
          <button class="header-icon-btn header-icon-btn--search header-icon-btn--search-mobile" aria-label="{{ 'header.search_label' | t }}">
            {{ 'icon-search.svg' | inline_asset_content }}
          </button>
        </div>

        <div class="header-main__spacer" aria-hidden="true"></div>

        <div class="header-main__logo{% if section.settings.logo_mobile %} has-mobile-logo{% endif %}">
          {%- if section.settings.logo_mobile -%}
            <a href="{{ routes.root_url }}" class="header-main__logo-link--mobile">
              {{- section.settings.logo_mobile | image_url: width: 320 | image_tag: alt: shop.name, class: 'header-main__logo-img', loading: 'eager', width: nil, height: nil -}}
            </a>
          {%- endif -%}
          {%- if section.settings.logo -%}
            <a href="{{ routes.root_url }}" class="header-main__logo-link--desktop">
              {{- section.settings.logo | image_url: width: 440 | image_tag: alt: shop.name, class: 'header-main__logo-img', loading: 'eager', width: nil, height: nil -}}
            </a>
          {%- else -%}
            <a href="{{ routes.root_url }}" class="header-main__shop-name header-main__logo-link--desktop">{{ shop.name }}</a>
          {%- endif -%}
        </div>

        <div class="header-main__icons">
          {%- if section.settings.shop_live_url != blank -%}
            <a href="{{ section.settings.shop_live_url }}" class="header-shop-live-btn">
              <span class="header-shop-live-btn__dot" aria-hidden="true"></span>
              <svg class="header-shop-live-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
              {{ section.settings.shop_live_label | default: 'Shop Live' }}
            </a>
          {%- endif -%}

          <button class="header-icon-btn header-icon-btn--search" aria-label="{{ 'header.search_label' | t }}">
            {{ 'icon-search.svg' | inline_asset_content }}
          </button>

          <a href="/pages/wishlist" class="header-icon-btn header-icon-btn--wishlist" aria-label="{{ 'header.wishlist_label' | t }}">
            {{ 'icon-wishlist.svg' | inline_asset_content }}
            {% if cart.item_count > 0 %}
              <span class="header-wishlist-count">0</span>
            {% endif %}
          </a>

          <a href="{{ routes.cart_url }}" class="header-icon-btn header-icon-btn--cart" aria-label="{{ 'header.cart_label' | t }}">
            {{ 'icon-cart.svg' | inline_asset_content }}
            {%- assign visible_cart_count = 0 -%}
            {%- for item in cart.items -%}
              {%- unless item.product.tags contains 'Archived' -%}
                {%- assign visible_cart_count = visible_cart_count | plus: item.quantity -%}
              {%- endunless -%}
            {%- endfor -%}
            {% if visible_cart_count > 0 %}
              <span class="header-cart-count">{{ visible_cart_count }}</span>
            {% endif %}
          </a>

          {% if shop.customer_accounts_enabled %}
            {% if customer %}
              <a href="{{ routes.account_url }}" class="header-icon-btn header-icon-btn--account-desktop" aria-label="{{ 'header.account_label' | t }}">
                {{ 'icon-account.svg' | inline_asset_content }}
              </a>
            {% else %}
              <a href="{{ routes.account_login_url }}" class="header-login-btn" aria-label="{{ 'header.login_label' | t }}">
                {{ 'header.login_label' | t }}
              </a>
            {% endif %}
          {% endif %}
        </div>

      </div>
    </div>

    {% comment %} Mobile nav drawer — Block Synced Sliding Framework {% endcomment %}
    <div class="mobile-nav-drawer" id="mobile-nav-drawer" aria-hidden="true">
      <div class="mobile-nav-drawer__overlay"></div>
      <div class="mobile-nav-drawer__panel">
        
        <button class="mobile-nav-drawer__close" aria-label="{{ 'header.close_menu_label' | t }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </button>

        <div class="mobile-nav-slider-container">
          <div class="mobile-nav-slider-track" id="mobile-nav-track" data-current-level="1">
            
            {%- comment -%} LEVEL 1: Main Menu Rows {%- endcomment -%}
            <div class="mobile-nav-level" id="level-1">
              <nav aria-label="Main navigation">
                <ul class="mobile-nav-drawer__list">
                  {% for link in section.settings.menu.links %}
                    {%- assign matching_mega = nil -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'mega_menu' and block.settings.nav_link == link.title -%}
                        {%- assign matching_mega = block -%}
                      {%- endif -%}
                    {%- endfor -%}

                    <li class="mobile-nav-drawer__item">
                      {% if matching_mega != blank or link.links.size > 0 %}
                        <button type="button" class="mobile-nav-drawer__link mobile-slide-next-trigger" data-next-panel="level-2-{{ forloop.index }}">
                          <span>{{ link.title }}</span>
                          <span class="mobile-nav-arrow-icon">›</span>
                        </button>
                      {% else %}
                        <a href="{{ link.url }}" class="mobile-nav-drawer__link">{{ link.title }}</a>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </nav>
            </div>

            {%- comment -%} LEVEL 2 & 3: Sliding Submenu Blocks Panel Engine {%- endcomment -%}
            {% for link in section.settings.menu.links %}
              {%- assign matching_mega = nil -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'mega_menu' and block.settings.nav_link == link.title -%}
                  {%- assign matching_mega = block -%}
                {%- endif -%}
              {%- endfor -%}

              {% assign level1_index = forloop.index %}

              {% if matching_mega != blank %}
                {%- comment -%} LEVEL 2 PANEL: Dynamic Column Titles {%- endcomment -%}
                <div class="mobile-nav-level mobile-nav-level--sub" id="level-2-{{ level1_index }}" style="display: none;">
                  <button type="button" class="mobile-nav-drawer__back-btn mobile-slide-back-trigger" data-back-to="1">
                    <span class="back-arrow">❮</span> {{ link.title }}
                  </button>
                  
                  <ul class="mobile-nav-drawer__list">
                    <li class="mobile-nav-drawer__item">
                      <a href="{{ link.url }}" class="mobile-nav-drawer__link mobile-nav-drawer__link--shop-all">Shop All {{ link.title }}</a>
                    </li>
                    
                    {% if matching_mega.settings.col1_menu != blank and matching_mega.settings.col1_heading != blank %}
                      <li class="mobile-nav-drawer__item">
                        <button type="button" class="mobile-nav-drawer__link mobile-slide-next-trigger" data-next-panel="level-3-{{ level1_index }}-1">
                          <span>{{ matching_mega.settings.col1_heading }}</span>
                          <span class="mobile-nav-arrow-icon">›</span>
                        </button>
                      </li>
                    {% endif %}

                    {% if matching_mega.settings.col2_menu != blank and matching_mega.settings.col2_heading != blank %}
                      <li class="mobile-nav-drawer__item">
                        <button type="button" class="mobile-nav-drawer__link mobile-slide-next-trigger" data-next-panel="level-3-{{ level1_index }}-2">
                          <span>{{ matching_mega.settings.col2_heading }}</span>
                          <span class="mobile-nav-arrow-icon">›</span>
                        </button>
                      </li>
                    {% endif %}

                    {% if matching_mega.settings.col3_menu != blank and matching_mega.settings.col3_heading != blank %}
                      <li class="mobile-nav-drawer__item">
                        <button type="button" class="mobile-nav-drawer__link mobile-slide-next-trigger" data-next-panel="level-3-{{ level1_index }}-3">
                          <span>{{ matching_mega.settings.col3_heading }}</span>
                          <span class="mobile-nav-arrow-icon">›</span>
                        </button>
                      </li>
                    {% endif %}
                  </ul>
                </div>

                {%- comment -%} LEVEL 3 PANEL: Deep Products Links Grid Panel {%- endcomment -%}
                {%- for i in (1..3) -%}
                  {%- assign menu_key = 'col' | append: i | append: '_menu' -%}
                  {%- assign heading_key = 'col' | append: i | append: '_heading' -%}
                  {%- assign active_menu_handle = matching_mega.settings[menu_key] -%}
                  {%- assign active_heading = matching_mega.settings[heading_key] -%}

                  {% if active_menu_handle != blank %}
                    <div class="mobile-nav-level mobile-nav-level--sub" id="level-3-{{ level1_index }}-{{ i }}" style="display: none;">
                      <button type="button" class="mobile-nav-drawer__back-btn mobile-slide-back-trigger" data-back-to="2">
                        <span class="back-arrow">❮</span> {{ active_heading }}
                      </button>
                      
                      <ul class="mobile-nav-drawer__list">
                        {% for item in linklists[active_menu_handle].links %}
                          <li class="mobile-nav-drawer__item">
                            <a href="{{ item.url }}" class="mobile-nav-drawer__sub-link {% if item.title contains '₹' %}mega-menu__link--promo{% endif %}">
                              {{ item.title }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>

                      <div class="mobile-nav-drawer__banner">
                        {% if matching_mega.settings.card1_image != blank %}
                          <img src="{{ matching_mega.settings.card1_image | image_url: width: 500 }}" alt="Menu Banner" loading="lazy">
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {%- endfor -%}

              {% endif %}
            {% endfor %}

          </div>
        </div>

      </div>
    </div>

    {% comment %} Row 3: Category nav + mega menus {% endcomment %}
    <nav class="header-nav" aria-label="{{ 'header.main_nav_label' | t }}">
      <ul class="header-nav__list">
        {% for link in section.settings.menu.links %}
          {%- assign mega = nil -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'mega_menu' and block.settings.nav_link == link.title -%}
              {%- assign mega = block -%}
            {%- endif -%}
          {%- endfor -%}

          {%- assign is_highlight = false -%}
          {%- if section.settings.highlight_nav_item != blank and link.title == section.settings.highlight_nav_item -%}
            {%- assign is_highlight = true -%}
          {%- endif -%}
          <li class="header-nav__item{% if mega or link.links.size > 0 %} header-nav__item--has-dropdown{% if mega %} header-nav__item--mega{% endif %}{% endif %}">
            <a href="{{ link.url }}" class="header-nav__link{% if is_highlight %} header-nav__link--highlight header-nav__link--highlight-{{ section.settings.highlight_nav_style }}{% endif %}"{% if link.url contains 'http' %} target="_blank" rel="noopener"{% endif %}{% if is_highlight and section.settings.highlight_nav_style == 'button' %} style="--btn-color: {{ section.settings.highlight_btn_color }}; --btn-hover-color: {{ section.settings.highlight_btn_hover_color }};"{% endif %}>
              {%- if is_highlight and section.settings.highlight_nav_style == 'image' and section.settings.highlight_nav_image -%}
                {{- section.settings.highlight_nav_image | image_url: width: 120 | image_tag: class: 'header-nav__highlight-img', alt: link.title -}}
              {%- else -%}
                {%- if is_highlight and section.settings.highlight_nav_style == 'button' and section.settings.highlight_nav_icon -%}
                  {{- section.settings.highlight_nav_icon | image_url: width: section.settings.highlight_nav_icon.width | image_tag: class: 'header-nav__highlight-icon', alt: '', aria-hidden: 'true', loading: 'eager' -}}
                {%- endif -%}
                {{- link.title -}}
              {%- endif -%}
              {% if mega or link.links.size > 0 %}
                <svg class="header-nav__chevron" aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {% endif %}
            </a>

            {% if mega %}
              <div class="mega-menu" {{ mega.shopify_attributes }}>
                <div class="mega-menu__inner">
                  <div class="mega-menu__cols">
                    {% if mega.settings.col1_menu != blank %}
                      <div class="mega-menu__col">
                        {% if mega.settings.col1_heading != blank %}
                          <p class="mega-menu__col-heading">{{ mega.settings.col1_heading }}</p>
                        {% endif %}
                        <ul class="mega-menu__links">
                          {% for item in linklists[mega.settings.col1_menu].links %}
                            <li>
                              <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.url contains 'http' %} target="_blank" rel="noopener"{% endif %}>
                                {{ item.title }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    {% endif %}

                    {% if mega.settings.col2_menu != blank %}
                      <div class="mega-menu__col">
                        {% if mega.settings.col2_heading != blank %}
                          <p class="mega-menu__col-heading">{{ mega.settings.col2_heading }}</p>
                        {% endif %}
                        <ul class="mega-menu__links">
                          {% for item in linklists[mega.settings.col2_menu].links %}
                            <li>
                              <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.url contains 'http' %} target="_blank" rel="noopener"{% endif %}>
                                {{ item.title }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    {% endif %}

                    {% if mega.settings.col3_menu != blank %}
                      <div class="mega-menu__col">
                        {% if mega.settings.col3_heading != blank %}
                          <p class="mega-menu__col-heading">{{ mega.settings.col3_heading }}</p>
                        {% endif %}
                        <ul class="mega-menu__links">
                          {% for item in linklists[mega.settings.col3_menu].links %}
                            <li>
                              <a href="{{ item.url }}" class="mega-menu__link{% if item.title contains '₹' %} mega-menu__link--promo{% endif %}"{% if item.url contains 'http' %} target="_blank" rel="noopener"{% endif %}>
                                {{ item.title }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    {% endif %}
                  </div>

                  {% if mega.settings.card1_image or mega.settings.card2_image or mega.settings.card3_image %}
                    <div class="mega-menu__cards">
                      {% if mega.settings.card1_image %}
                        <a href="{{ mega.settings.card1_url | default: '#' }}" class="mega-menu__card"{% if mega.settings.card1_url != blank %} target="_blank" rel="noopener"{% endif %}>
                          {{ mega.settings.card1_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card1_label | escape }}
                          <div class="mega-menu__card-gradient"></div>
                          {% if mega.settings.card1_label != blank %}
                            <span class="mega-menu__card-label">{{ mega.settings.card1_label }}</span>
                          {% endif %}
                        </a>
                      {% endif %}
                      {% if mega.settings.card2_image %}
                        <a href="{{ mega.settings.card2_url | default: '#' }}" class="mega-menu__card"{% if mega.settings.card2_url != blank %} target="_blank" rel="noopener"{% endif %}>
                          {{ mega.settings.card2_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card2_label | escape }}
                          <div class="mega-menu__card-gradient"></div>
                          {% if mega.settings.card2_label != blank %}
                            <span class="mega-menu__card-label">{{ mega.settings.card2_label }}</span>
                          {% endif %}
                        </a>
                      {% endif %}
                      {% if mega.settings.card3_image %}
                        <a href="{{ mega.settings.card3_url | default: '#' }}" class="mega-menu__card"{% if mega.settings.card3_url != blank %} target="_blank" rel="noopener"{% endif %}>
                          {{ mega.settings.card3_image | image_url: width: 600 | image_tag: class: 'mega-menu__card-img', alt: mega.settings.card3_label | escape }}
                          <div class="mega-menu__card-gradient"></div>
                          {% if mega.settings.card3_label != blank %}
                            <span class="mega-menu__card-label">{{ mega.settings.card3_label }}</span>
                          {% endif %}
                        </a>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% elsif link.links.size > 0 %}
              <ul class="header-nav__dropdown">
                {% for child_link in link.links %}
                  <li>
                    <a href="{{ child_link.url }}" class="header-nav__dropdown-link"{% if child_link.url contains 'http' %} target="_blank" rel="noopener"{% endif %}>{{ child_link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>{% comment %} /site-header__sticky ── {% endcomment %}
</div>{% comment %} /site-header ── {% endcomment %}

{% comment %} Search overlay {% endcomment %}
<div class="header-search-overlay" id="header-search-overlay" aria-hidden="true" role="dialog" aria-label="{{ 'search.title' | t }}">
  <div class="header-search-overlay__backdrop" id="header-search-backdrop"></div>
  <div class="header-search-overlay__panel">
    <div class="header-search-overlay__bar">
      <div class="header-search-overlay__form-wrap">
        <svg class="header-search-overlay__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <input class="header-search-overlay__input" id="header-search-input" type="search" name="q" placeholder="{{ 'search.placeholder' | t }}" autocomplete="off" autocorrect="off" spellcheck="false" aria-label="{{ 'search.placeholder' | t }}">
        <button class="header-search-overlay__clear" type="button" id="header-search-clear" aria-label="Clear search">Clear</button>
      </div>
      <button class="header-search-overlay__close" type="button" id="header-search-close" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" width="24" height="24" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="header-search-results" id="header-search-results" aria-live="polite" style="display:none;">
      <div class="header-search-results__inner">
        <div class="header-search-results__col header-search-results__col--suggestions">
          <p class="header-search-results__heading">Suggestions</p>
          <ul class="header-search-suggestions" id="header-search-suggestions"></ul>
        </div>
        <div class="header-search-results__col header-search-results__col--products">
          <p class="header-search-results__heading">Products</p>
          <div class="header-search-products" id="header-search-products"></div>
        </div>
      </div>
      <div class="header-search-results__footer">
        <a class="header-search-results__view-all" id="header-search-view-all" href="{{ routes.search_url }}">SEARCH FOR ""</a>
      </div>
    </div>
  </div>
</div>

<div class="site-header-spacer" id="site-header-spacer"></div>

{% stylesheet %}
  /* ── Fixed site header wrapper ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
  }

  /* Topbar wrap — collapses on scroll */
  .site-header__topbar-wrap {
    overflow: hidden;
    max-height: 80px;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    opacity: 1;
  }

  .site-header.is-scrolled .site-header__topbar-wrap {
    max-height: 0;
    opacity: 0;
  }

  /* Spacer that compensates for fixed header height */
  .site-header-spacer {
    display: block;
    height: 150px;
  }

  @media screen and (max-width: 768px) {
    .site-header-spacer {
      height: 70px;
    }
  }

  /* ── Top bar ── */
  .header-topbar {
    background-color: var(--color-primary);
    color: #fff;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px var(--page-margin, 24px);
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
  }
  .header-topbar__nav {
    display: flex;
    gap: 28px;
  }
  .header-topbar__link {
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body--family, 'Montserrat', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .header-topbar__link:hover { opacity: 0.85; }

  /* ── Main row ── */
  .header-main {
    background-color: #efeee9;
    padding: 0 1.5rem;
    width: 100%;
  }
  .header-main__inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 var(--page-margin, 24px);
    max-width: var(--page-width, 1900px);
    margin: 0 auto;
    height: 80px;
    position: relative;
  }
  .header-main__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .header-main__logo-img {
    max-height: 56px;
    width: auto;
    height: auto;
    display: block;
  }
  .header-main__logo-link--mobile { display: none; }
  .header-main__shop-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
