{% doc %}
  Renders a single category item with a circular ornamental image and a label.
  Used inside the category section.

  @example
  {% content_for 'block', type: 'category_item', id: 'category-item-1' %}
{% enddoc %}

{%- assign item_url = block.settings.url | default: '#' -%}

<div class="category-item" {{ block.shopify_attributes }}>
  <a class="category-item__link" href="{{ item_url }}">
    <div class="category-item__frame">
      <svg class="category-item__ornament" viewBox="0 0 138 138" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="69" cy="69" r="65" fill="none" stroke="#2e1f1f" stroke-width="1" stroke-dasharray="4 3" opacity="0.6"/>
        <circle cx="69" cy="69" r="60" fill="none" stroke="#2e1f1f" stroke-width="0.5" opacity="0.3"/>
      </svg>
      <div class="category-item__image-wrapper">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 300, height: 300, crop: 'center' | image_tag: class: 'category-item__image', loading: 'lazy', alt: block.settings.label | escape }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'category-item__image category-item__image--placeholder' }}
        {%- endif -%}
      </div>
    </div>

    {%- if block.settings.label != blank -%}
      <span class="category-item__label">{{ block.settings.label | escape }}</span>
    {%- endif -%}
  </a>
</div>

{% stylesheet %}
  .category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 13.8rem;
  }

  .category-item__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .category-item__link:hover .category-item__frame {
    transform: scale(1.05);
  }

  .category-item__frame {
    position: relative;
    width: 13.8rem;
    height: 13.8rem;
    transition: transform 0.3s ease;
  }

  .category-item__ornament {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .category-item__image-wrapper {
    position: absolute;
    inset: 11px;
    border-radius: 50%;
    overflow: hidden;
    opacity: 0.85;
  }

  .category-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .category-item__image--placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: block;
    background-color: #e8e0d5;
  }

  .category-item__label {
    font-size: 1.4rem;
    font-weight: 500;
    color: #212121;
    text-align: center;
    line-height: 1.71;
    font-family: var(--font-body-family, 'Montserrat', sans-serif);
  }

  @media screen and (min-width: 768px) {
    .category-item {
      width: 13.8rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.category_item",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:labels.label",
      "default": "Category name"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.url"
    }
  ],
  "presets": [{ "name": "t:general.category_item" }]
}
{% endschema %}
