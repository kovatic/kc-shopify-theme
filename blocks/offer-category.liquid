{% doc %}
  Renders one offer category (e.g. Sarees & Lehenga) as an icon + heading
  followed by a grid of nested offer-item blocks. Used inside the offer-grid
  section. Background band color alternates automatically per category.

  @example
  {% content_for 'block', type: 'offer-category', id: 'offer-category-1' %}
{% enddoc %}

<div class="offer-category" {{ block.shopify_attributes }}>
  <div class="offer-category__divider" aria-hidden="true">
    <span class="offer-category__divider-line"></span>
    <span class="offer-category__divider-diamond">✦</span>
    <span class="offer-category__divider-line"></span>
  </div>

  {%- if block.settings.title != blank -%}
    <h3 class="offer-category__title">
      <span class="offer-category__title-text">
        {%- if block.settings.icon != blank -%}
          <span class="offer-category__icon" aria-hidden="true">{{ block.settings.icon }}</span>
        {%- endif -%}
        {{ block.settings.title | escape }}
      </span>
    </h3>
  {%- endif -%}

  <div class="offer-category__grid">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .offer-category {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 36px 24px;
    border-radius: 20px;
  }

  .offer-category:nth-of-type(6n+1) { background: rgba(179, 18, 44, 0.18); }
  .offer-category:nth-of-type(6n+2) { background: rgba(142, 14, 33, 0.22); }
  .offer-category:nth-of-type(6n+3) { background: rgba(94, 8, 33, 0.22); }
  .offer-category:nth-of-type(6n+4) { background: rgba(179, 18, 44, 0.14); }
  .offer-category:nth-of-type(6n+5) { background: rgba(142, 14, 33, 0.16); }
  .offer-category:nth-of-type(6n+6) { background: rgba(94, 8, 33, 0.16); }

  .offer-category__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 320px;
  }

  .offer-category__divider-line {
    display: block;
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, #ffd75e 50%, transparent);
  }

  .offer-category__divider-diamond {
    color: #ffd75e;
    font-size: 1rem;
    line-height: 1;
  }

  .offer-category__title {
    display: flex;
    justify-content: center;
    margin: 0;
  }

  .offer-category__title-text {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 28px;
    font-family: var(--font-heading-family, 'Playfair Display', serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #b3122c;
    background: #ffd75e;
    border-radius: 999px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }

  .offer-category__icon {
    font-size: 1.25rem;
    line-height: 1;
  }

  .offer-category__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    width: 100%;
  }

  @media screen and (max-width: 768px) {
    .offer-category {
      padding: 28px 16px;
      border-radius: 16px;
    }

    .offer-category__title-text {
      font-size: 1.15rem;
      padding: 6px 20px;
    }

    .offer-category__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.offer_category.name",
  "blocks": [{ "type": "offer-item" }],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Category name"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "t:blocks.offer_category.icon",
      "info": "t:blocks.offer_category.icon_info",
      "default": "🛍️"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.offer_category.name",
      "blocks": [{ "type": "offer-item" }, { "type": "offer-item" }, { "type": "offer-item" }]
    }
  ]
}
{% endschema %}
