        "label": "t:general.primary"
      },
      {
        "type": "font_picker",
        "id": "headings_font",
        "default": "work_sans_n4",
        "label": "t:general.headings"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "work_sans_n4",
        "label": "t:general.body"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          },
          {
            "value": "120rem",
            "label": "t:options.page_width.full"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 0
      }
    ]
  },
  {
    "name": "t:general.social",
    "settings": [
      {
        "type": "image_picker",
