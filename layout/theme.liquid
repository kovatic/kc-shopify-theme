<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}


    {% style %}
      {{ settings.headings_font | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_face: font_display: 'swap' }}
      body, h1, h2, h3, h4, h5, h6, p {
        font-family: {{ settings.body_font.family }};
        font-weight: {{ settings.body_font.weight }};
        font-style: {{ settings.body_font.style }};
      }
      p {
        color: {{ settings.secondary_text_color }};
      }
      h1, h2, h3, h4, h5, h6 {
        color: {{ settings.primary_text_color }};
      }
      .section-title {
        font-family: {{ settings.headings_font.family }};
        font-weight: {{ settings.headings_font.weight }};
        font-style: {{ settings.headings_font.style }};
      }
    {% endstyle %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'cart-drawer.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    {% sections 'header-group' %}
    {% render 'cart-drawer' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
    <script>window.shopMoneyFormat = {{ shop.money_format | json }};</script>
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
  </body>
</html>
