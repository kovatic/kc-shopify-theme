{% doc %}
  Renders the "Try with AI" upload modal. Customer picks/uploads a photo of
  themselves; the photo is uploaded directly to the KC Wear AI backend, which
  generates an AI saree try-on image using the product image, and the result
  is polled for and displayed.

  Requires the KC Wear AI backend base URL, configured via the theme setting
  `try_with_ai_backend_url`.

  @param {product} product - The product being tried on
  @param {string} [backend_url] - Base URL of the KC Wear AI backend (e.g. https://kc-wear-ai.vercel.app)

  @example
  {% render 'try-with-ai-modal', product: product, backend_url: settings.try_with_ai_backend_url %}
{% enddoc %}

<div
  class="try-ai-modal"
  id="try-ai-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="try-ai-modal-title"
  data-backend-url="{{ backend_url }}"
  data-product-image="https:{{ product.featured_image | image_url: width: 1024 }}"
  data-product-id="{{ product.id }}"
  data-customer-id="{{ customer.id }}"
  data-i18n-upload-button="{{ 'try_with_ai.upload_button' | t | escape }}"
  data-i18n-uploading="{{ 'try_with_ai.uploading' | t | escape }}"
  data-i18n-generating="{{ 'try_with_ai.generating' | t | escape }}"
  data-i18n-upload-success="{{ 'try_with_ai.upload_success' | t | escape }}"
  data-i18n-upload-error="{{ 'try_with_ai.upload_error' | t | escape }}"
  data-i18n-step-uploading="{{ 'try_with_ai.step_uploading' | t | escape }}"
  data-i18n-step-styling="{{ 'try_with_ai.step_styling' | t | escape }}"
  data-i18n-step-finishing="{{ 'try_with_ai.step_finishing' | t | escape }}"
  data-i18n-view-original="{{ 'try_with_ai.view_original' | t | escape }}"
  data-i18n-view-result="{{ 'try_with_ai.view_result' | t | escape }}"
  data-i18n-add-to-cart="{{ 'try_with_ai.add_to_cart' | t | escape }}"
  data-i18n-added-to-cart="{{ 'try_with_ai.added_to_cart' | t | escape }}"
  data-i18n-download="{{ 'try_with_ai.download' | t | escape }}"
  data-i18n-share="{{ 'try_with_ai.share' | t | escape }}"
>
  <div class="try-ai-modal__backdrop"></div>
  <div class="try-ai-modal__panel">

    <div class="try-ai-modal__header">
      <h2 class="try-ai-modal__title" id="try-ai-modal-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="try-ai-modal__title-icon">
          <path d="M12 2.5l1.8 4.9 4.9 1.8-4.9 1.8L12 15.9l-1.8-4.9-4.9-1.8 4.9-1.8L12 2.5z"/>
          <path d="M19 14l.9 2.5L22.4 17.4l-2.5.9L19 20.8l-.9-2.5-2.5-.9 2.5-.9L19 14z"/>
        </svg>
        <span class="try-ai-modal__title-text">{{ 'try_with_ai.modal_title' | t }}</span>
      </h2>
      <button type="button" class="try-ai-modal__close" aria-label="{{ 'try_with_ai.close' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="try-ai-modal__body">

      <div class="try-ai-modal__step" id="try-ai-step-upload">
        <p class="try-ai-modal__prompt">{{ 'try_with_ai.upload_prompt' | t }}</p>

        <label class="try-ai-modal__dropzone" for="try-ai-file-input" id="try-ai-dropzone">
          <img class="try-ai-modal__preview-img" id="try-ai-preview-img" alt="" hidden>
          <span class="try-ai-modal__dropzone-placeholder" id="try-ai-dropzone-placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 16V4M12 4l-4 4M12 4l4 4"/>
              <path d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>
            </svg>
            <span>{{ 'try_with_ai.choose_photo' | t }}</span>
          </span>
        </label>
        <input type="file" accept="image/*" id="try-ai-file-input" class="try-ai-modal__file-input">
      </div>

      <div class="try-ai-modal__step" id="try-ai-step-loading" hidden>
        <div class="try-ai-modal__loading">
          <img class="try-ai-modal__loading-img" id="try-ai-loading-img" alt="" aria-hidden="true">
          <div class="try-ai-modal__loading-scan" aria-hidden="true">
            <span class="try-ai-modal__loading-scan-line"></span>
            <span class="try-ai-modal__loading-corner try-ai-modal__loading-corner--tl"></span>
            <span class="try-ai-modal__loading-corner try-ai-modal__loading-corner--tr"></span>
            <span class="try-ai-modal__loading-corner try-ai-modal__loading-corner--bl"></span>
            <span class="try-ai-modal__loading-corner try-ai-modal__loading-corner--br"></span>
          </div>
          <div class="try-ai-modal__loading-overlay">
            <div class="try-ai-modal__loading-sparkle" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.5l1.8 4.9 4.9 1.8-4.9 1.8L12 15.9l-1.8-4.9-4.9-1.8 4.9-1.8L12 2.5z"/>
              </svg>
            </div>
            <p class="try-ai-modal__loading-step" id="try-ai-loading-step"></p>
            <div class="try-ai-modal__loading-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="try-ai-modal__step" id="try-ai-step-result" hidden>
        <div class="try-ai-modal__compare" id="try-ai-compare">
          <img class="try-ai-modal__compare-img try-ai-modal__compare-img--after" id="try-ai-result-img" alt="{{ 'try_with_ai.result_alt' | t }}">
          <div class="try-ai-modal__compare-before-wrap" id="try-ai-compare-before-wrap">
            <img class="try-ai-modal__compare-img try-ai-modal__compare-img--before" id="try-ai-original-img" alt="{{ 'try_with_ai.original_alt' | t }}">
          </div>
          <div class="try-ai-modal__compare-handle" id="try-ai-compare-handle">
            <span class="try-ai-modal__compare-handle-grip">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/>
              </svg>
            </span>
          </div>
          <span class="try-ai-modal__compare-label try-ai-modal__compare-label--before">{{ 'try_with_ai.view_original' | t }}</span>
          <span class="try-ai-modal__compare-label try-ai-modal__compare-label--after">{{ 'try_with_ai.view_result' | t }}</span>
        </div>

        <div class="try-ai-modal__result-actions">
          <button type="button" class="try-ai-modal__icon-btn" id="try-ai-download-btn" aria-label="{{ 'try_with_ai.download' | t | escape }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3v12M12 15l-4-4M12 15l4-4"/>
              <path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>
            </svg>
            <span>{{ 'try_with_ai.download' | t }}</span>
          </button>
          <button type="button" class="try-ai-modal__icon-btn" id="try-ai-share-btn" aria-label="{{ 'try_with_ai.share' | t | escape }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="18" cy="5" r="2.4"/><circle cx="6" cy="12" r="2.4"/><circle cx="18" cy="19" r="2.4"/>
              <path d="M8.2 10.8l7.6-4.4M8.2 13.2l7.6 4.4"/>
            </svg>
            <span>{{ 'try_with_ai.share' | t }}</span>
          </button>
        </div>
      </div>

      <p class="try-ai-modal__status" id="try-ai-status" aria-live="polite"></p>
    </div>

    <div class="try-ai-modal__footer" id="try-ai-footer-upload">
      <button type="button" class="try-ai-modal__upload-btn" id="try-ai-upload-btn" disabled>
        {{ 'try_with_ai.upload_button' | t }}
      </button>
    </div>

    <div class="try-ai-modal__footer" id="try-ai-footer-result" hidden>
      <button type="button" class="try-ai-modal__upload-btn try-ai-modal__upload-btn--secondary" id="try-ai-retry-btn">
        {{ 'try_with_ai.try_another_photo' | t }}
      </button>
      <button type="button" class="try-ai-modal__upload-btn" id="try-ai-atc-btn">
        {{ 'try_with_ai.add_to_cart' | t }}
      </button>
    </div>

  </div>
</div>

{% stylesheet %}
  .try-ai-modal {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .try-ai-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .try-ai-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }
  .try-ai-modal__panel {
    position: relative;
    background: #faf8f4;
    border-radius: 8px;
    width: 94%;
    max-width: 720px;
    max-height: 96vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(10px);
    transition: transform 0.25s ease;
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
  }
  .try-ai-modal.is-open .try-ai-modal__panel {
    transform: translateY(0);
  }

  .try-ai-modal__header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 40px;
    border-bottom: 1px solid #e8e2d9;
    position: relative;
    flex-shrink: 0;
    min-height: 0;
  }
  .try-ai-modal__title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    text-align: center;
  }
  .try-ai-modal__title-text {
    background: linear-gradient(100deg, #4b2a7b, #9c2a8f 45%, #c3134e 75%, #d98a2b 100%);
    background-size: 220% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: #2e1f1f;
    animation: try-ai-btn-gradient 6s ease infinite;
  }
  .try-ai-modal__title-icon {
    flex-shrink: 0;
    color: #9c2a8f;
    animation: try-ai-btn-icon-twinkle 2.4s ease-in-out infinite;
  }
  @keyframes try-ai-btn-gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  @keyframes try-ai-btn-icon-twinkle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.75; transform: scale(0.9); }
  }
  .try-ai-modal__close {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .try-ai-modal__close:hover { color: #2e1f1f; }

  .try-ai-modal__body {
    overflow-y: auto;
    flex: 1;
    padding: 14px 20px 20px;
  }
  .try-ai-modal__prompt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    color: #42464b;
    margin: 0 0 10px;
  }

  .try-ai-modal__dropzone {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 2 / 3;
    max-height: 640px;
    margin: 0 auto;
    border: 1.5px dashed #d4cdc4;
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .try-ai-modal__dropzone:hover {
    border-color: #2e1f1f;
  }
  .try-ai-modal__dropzone-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: #888;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
  }
  .try-ai-modal__dropzone-placeholder[hidden] {
    display: none;
  }
  .try-ai-modal__preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .try-ai-modal__preview-img[hidden] {
    display: none;
  }
  .try-ai-modal__file-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .try-ai-modal__step[hidden] {
    display: none;
  }

  /* ── Loading state: AI scan effect over the uploaded photo ── */
  .try-ai-modal__loading {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 2 / 3;
    max-height: 640px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1420;
    border: 1.5px solid #e8e2d9;
  }
  .try-ai-modal__loading-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.7) brightness(0.55);
  }
  .try-ai-modal__loading-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .try-ai-modal__loading-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #d98a2b, #c3134e, #9c2a8f, transparent);
    box-shadow: 0 0 16px 3px rgba(195, 19, 78, 0.7);
    animation: try-ai-scan-move 2.6s ease-in-out infinite;
  }
  @keyframes try-ai-scan-move {
    0%   { top: 4%; opacity: 0; }
    8%   { opacity: 1; }
    50%  { top: 92%; opacity: 1; }
    92%  { opacity: 1; }
    100% { top: 4%; opacity: 0; }
  }
  .try-ai-modal__loading-corner {
    position: absolute;
    width: 26px;
    height: 26px;
    border: 2px solid rgba(255,255,255,0.85);
    opacity: 0.9;
  }
  .try-ai-modal__loading-corner--tl {
    top: 14px; left: 14px;
    border-right: none; border-bottom: none;
    border-radius: 4px 0 0 0;
  }
  .try-ai-modal__loading-corner--tr {
    top: 14px; right: 14px;
    border-left: none; border-bottom: none;
    border-radius: 0 4px 0 0;
  }
  .try-ai-modal__loading-corner--bl {
    bottom: 14px; left: 14px;
    border-right: none; border-top: none;
    border-radius: 0 0 0 4px;
  }
  .try-ai-modal__loading-corner--br {
    bottom: 14px; right: 14px;
    border-left: none; border-top: none;
    border-radius: 0 0 4px 0;
  }
  .try-ai-modal__loading-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 20px 24px;
    background: linear-gradient(180deg, transparent, rgba(20, 14, 26, 0.85) 55%);
  }
  .try-ai-modal__loading-sparkle {
    color: #fff;
    filter: drop-shadow(0 0 8px rgba(195, 19, 78, 0.8));
    animation: try-ai-btn-icon-twinkle 1.6s ease-in-out infinite;
  }
  .try-ai-modal__loading-step {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    color: #fff;
    margin: 0;
    text-align: center;
    min-height: 1.4em;
  }
  .try-ai-modal__loading-dots {
    display: flex;
    gap: 6px;
  }
  .try-ai-modal__loading-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: linear-gradient(100deg, #d98a2b, #c3134e, #9c2a8f);
    opacity: 0.3;
    animation: try-ai-pulse 1.2s ease-in-out infinite;
  }
  .try-ai-modal__loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .try-ai-modal__loading-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes try-ai-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  /* ── Result / before-after compare ── */
  .try-ai-modal__compare {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 2 / 3;
    max-height: 640px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    border: 1.5px solid #e8e2d9;
    user-select: none;
    touch-action: pan-y;
  }
  .try-ai-modal__compare-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  .try-ai-modal__compare-before-wrap {
    position: absolute;
    inset: 0;
    width: 50%;
    overflow: hidden;
  }
  .try-ai-modal__compare-before-wrap .try-ai-modal__compare-img {
    width: var(--compare-width, 100vw);
    max-width: none;
  }
  .try-ai-modal__compare-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 36px;
    margin-left: -18px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ew-resize;
  }
  .try-ai-modal__compare-handle::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    margin-left: -1px;
    background: #fff;
    box-shadow: 0 0 6px rgba(0,0,0,0.3);
  }
  .try-ai-modal__compare-handle-grip {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #fff;
    color: #2e1f1f;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }
  .try-ai-modal__compare-label {
    position: absolute;
    bottom: 10px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(0,0,0,0.5);
    padding: 3px 10px;
    border-radius: 20px;
    pointer-events: none;
  }
  .try-ai-modal__compare-label--before { left: 10px; }
  .try-ai-modal__compare-label--after { right: 10px; }

  .try-ai-modal__result-actions {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .try-ai-modal__icon-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 40px;
    background: #fff;
    border: 1.5px solid #d4cdc4;
    border-radius: 5px;
    color: #2e1f1f;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .try-ai-modal__icon-btn:hover {
    border-color: #2e1f1f;
  }

  .try-ai-modal__status {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    margin: 12px 0 0;
    min-height: 1.2em;
    color: #666;
  }
  .try-ai-modal__status.is-error {
    color: #ce0570;
  }
  .try-ai-modal__status.is-success {
    color: #2e7d32;
  }

  .try-ai-modal__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    padding: 12px 20px;
    border-top: 1px solid #e8e2d9;
    flex-shrink: 0;
    background: #faf8f4;
  }
  .try-ai-modal__footer[hidden] {
    display: none;
  }
  .try-ai-modal__upload-btn {
    height: 44px;
    padding: 0 28px;
    background: var(--color-primary, #2e1f1f);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .try-ai-modal__upload-btn:hover {
    opacity: 0.88;
  }
  .try-ai-modal__upload-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .try-ai-modal__upload-btn--secondary {
    background: transparent;
    color: #2e1f1f;
    border: 1.5px solid #d4cdc4;
  }
  .try-ai-modal__upload-btn--secondary:hover {
    opacity: 1;
    border-color: #2e1f1f;
  }
  .try-ai-modal__upload-btn.is-loading {
    opacity: 0.7;
    cursor: wait;
  }

  @media screen and (max-width: 600px) {
    .try-ai-modal__panel {
      width: 100%;
      max-width: 100%;
      max-height: 95vh;
      border-radius: 12px 12px 0 0;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var modal = document.getElementById('try-ai-modal');
    if (!modal) return;

    var BACKEND_URL             = (modal.dataset.backendUrl || '').replace(/\/+$/, '');
    var PRODUCT_IMAGE_URL       = modal.dataset.productImage || '';
    var PRODUCT_ID              = modal.dataset.productId || '';
    var CUSTOMER_ID             = modal.dataset.customerId || '';
    var POLL_INTERVAL_MS        = 2500;
    var POLL_TIMEOUT_MS         = 120000;
    var DEBUG = /[?&]try_ai_debug=1/.test(window.location.search) || window.localStorage.getItem('tryAiDebug') === '1';

    function debugLog() {
      if (!DEBUG) return;
      var args = Array.prototype.slice.call(arguments);
      args.unshift('[Try with AI]');
      console.log.apply(console, args);
    }

    var I18N = {
      uploadButton:  modal.dataset.i18nUploadButton  || 'Generate try-on',
      uploading:     modal.dataset.i18nUploading      || 'Uploading…',
      generating:    modal.dataset.i18nGenerating     || 'Generating your try-on…',
      uploadSuccess: modal.dataset.i18nUploadSuccess  || 'Here is your AI try-on!',
      uploadError:   modal.dataset.i18nUploadError    || 'Something went wrong. Please try again.',
      stepUploading: modal.dataset.i18nStepUploading  || 'Uploading your photo…',
      stepStyling:   modal.dataset.i18nStepStyling    || 'AI is styling your saree…',
      stepFinishing: modal.dataset.i18nStepFinishing  || 'Adding finishing touches…',
      addToCart:     modal.dataset.i18nAddToCart      || 'Add to cart',
      addedToCart:   modal.dataset.i18nAddedToCart    || 'Added!',
      download:      modal.dataset.i18nDownload       || 'Download',
      share:         modal.dataset.i18nShare          || 'Share'
    };

    var dropzone           = document.getElementById('try-ai-dropzone');
    var fileInput          = document.getElementById('try-ai-file-input');
    var previewImg         = document.getElementById('try-ai-preview-img');
    var placeholder        = document.getElementById('try-ai-dropzone-placeholder');
    var statusEl           = document.getElementById('try-ai-status');
    var uploadBtn          = document.getElementById('try-ai-upload-btn');
    var retryBtn           = document.getElementById('try-ai-retry-btn');
    var atcBtn             = document.getElementById('try-ai-atc-btn');
    var downloadBtn        = document.getElementById('try-ai-download-btn');
    var shareBtn           = document.getElementById('try-ai-share-btn');
    var resultImg          = document.getElementById('try-ai-result-img');
    var originalImg        = document.getElementById('try-ai-original-img');
    var compareEl          = document.getElementById('try-ai-compare');
    var compareBeforeWrap  = document.getElementById('try-ai-compare-before-wrap');
    var compareHandle      = document.getElementById('try-ai-compare-handle');
    var loadingStepEl      = document.getElementById('try-ai-loading-step');
    var loadingImg         = document.getElementById('try-ai-loading-img');

    var stepUpload  = document.getElementById('try-ai-step-upload');
    var stepLoading = document.getElementById('try-ai-step-loading');
    var stepResult  = document.getElementById('try-ai-step-result');
    var footerUpload = document.getElementById('try-ai-footer-upload');
    var footerResult = document.getElementById('try-ai-footer-result');

    var selectedFile = null;
    var pollTimer = null;
    var loadingStepTimer = null;

    function setStatus(text, type) {
      statusEl.textContent = text || '';
      statusEl.classList.remove('is-error', 'is-success');
      if (type) statusEl.classList.add('is-' + type);
    }

    function stopPolling() {
      if (pollTimer) {
        clearTimeout(pollTimer);
        pollTimer = null;
      }
    }

    function stopLoadingSteps() {
      if (loadingStepTimer) {
        clearInterval(loadingStepTimer);
        loadingStepTimer = null;
      }
    }

    function startLoadingSteps() {
      var steps = [I18N.stepUploading, I18N.stepStyling, I18N.stepFinishing];
      var i = 0;
      loadingStepEl.textContent = steps[0];
      stopLoadingSteps();
      loadingStepTimer = setInterval(function () {
        i = Math.min(i + 1, steps.length - 1);
        loadingStepEl.textContent = steps[i];
      }, 7000);
    }

    function showUploadStep() {
      stepUpload.hidden = false;
      stepLoading.hidden = true;
      stepResult.hidden = true;
      footerUpload.hidden = false;
      footerResult.hidden = true;
      stopLoadingSteps();
    }

    function showLoadingStep(photoUrl) {
      stepUpload.hidden = true;
      stepLoading.hidden = false;
      stepResult.hidden = true;
      footerUpload.hidden = true;
      footerResult.hidden = true;
      if (photoUrl) loadingImg.src = photoUrl;
      startLoadingSteps();
    }

    function showResultStep() {
      stepUpload.hidden = true;
      stepLoading.hidden = true;
      stepResult.hidden = false;
      footerUpload.hidden = true;
      footerResult.hidden = false;
      stopLoadingSteps();
      requestAnimationFrame(function () { setCompareRatio(0.5); });
    }

    function setCompareRatio(ratio) {
      ratio = Math.max(0, Math.min(1, ratio));
      var widthPx = compareEl.getBoundingClientRect().width;
      compareBeforeWrap.style.width = (ratio * 100) + '%';
      compareBeforeWrap.style.setProperty('--compare-width', widthPx + 'px');
      compareHandle.style.left = (ratio * 100) + '%';
    }

    function resetState() {
      stopPolling();
      selectedFile = null;
      fileInput.value = '';
      previewImg.src = '';
      previewImg.hidden = true;
      placeholder.hidden = false;
      resultImg.src = '';
      originalImg.src = '';
      loadingImg.src = '';
      uploadBtn.disabled = true;
      uploadBtn.textContent = I18N.uploadButton;
      uploadBtn.classList.remove('is-loading');
      atcBtn.textContent = I18N.addToCart;
      atcBtn.disabled = false;
      setStatus('', null);
      showUploadStep();
    }

    function openModal() {
      resetState();
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      stopPolling();
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    modal.querySelectorAll('.try-ai-modal__close').forEach(function (btn) {
      btn.addEventListener('click', closeModal);
    });
    modal.querySelector('.try-ai-modal__backdrop').addEventListener('click', closeModal);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });

    retryBtn.addEventListener('click', resetState);

    fileInput.addEventListener('change', function () {
      var file = fileInput.files && fileInput.files[0];
      if (!file || file.type.indexOf('image/') !== 0) {
        selectedFile = null;
        uploadBtn.disabled = true;
        return;
      }
      selectedFile = file;
      previewImg.src = URL.createObjectURL(file);
      previewImg.hidden = false;
      placeholder.hidden = true;
      uploadBtn.disabled = false;
      setStatus('', null);
    });

    /* ── Before/after compare slider ── */
    var dragging = false;

    function ratioFromClientX(clientX) {
      var rect = compareEl.getBoundingClientRect();
      return (clientX - rect.left) / rect.width;
    }

    function onDragMove(clientX) {
      setCompareRatio(ratioFromClientX(clientX));
    }

    compareHandle.addEventListener('mousedown', function (e) {
      dragging = true;
      e.preventDefault();
    });
    compareHandle.addEventListener('touchstart', function () {
      dragging = true;
    }, { passive: true });

    document.addEventListener('mousemove', function (e) {
      if (dragging) onDragMove(e.clientX);
    });
    document.addEventListener('touchmove', function (e) {
      if (dragging && e.touches[0]) onDragMove(e.touches[0].clientX);
    }, { passive: true });

    document.addEventListener('mouseup', function () { dragging = false; });
    document.addEventListener('touchend', function () { dragging = false; });

    compareEl.addEventListener('click', function (e) {
      if (e.target === compareHandle || compareHandle.contains(e.target)) return;
      onDragMove(e.clientX);
    });

    window.addEventListener('resize', function () {
      if (!stepResult.hidden) {
        var current = compareBeforeWrap.getBoundingClientRect().width / compareEl.getBoundingClientRect().width;
        setCompareRatio(current);
      }
    });

    /* ── Result actions: download / share / add to cart ── */
    downloadBtn.addEventListener('click', function () {
      var link = document.createElement('a');
      link.href = resultImg.src;
      link.download = 'try-with-ai-result.jpg';
      link.target = '_blank';
      link.rel = 'noopener';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    shareBtn.addEventListener('click', function () {
      if (navigator.share) {
        navigator.share({
          title: document.title,
          url: resultImg.src
        }).catch(function () {});
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(resultImg.src).then(function () {
          setStatus(I18N.uploadSuccess, 'success');
        }).catch(function () {});
      }
    });

    atcBtn.addEventListener('click', function () {
      var variantInput = document.getElementById('variant-id-input');
      var variantId = variantInput && variantInput.value;
      if (!variantId) return;

      atcBtn.disabled = true;
      atcBtn.classList.add('is-loading');

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(function (r) { return r.json(); })
      .then(function () { return fetch('/cart.js').then(function (r) { return r.json(); }); })
      .then(function (cart) {
        var drawer = document.querySelector('cart-drawer');
        if (drawer) { drawer.renderCart(cart); drawer.open(); }
        atcBtn.textContent = I18N.addedToCart;
      })
      .catch(function (err) {
        debugLog('add to cart failed', err);
        atcBtn.disabled = false;
      })
      .finally(function () {
        atcBtn.classList.remove('is-loading');
      });
    });

    function readErrorBody(r) {
      return r.text().then(function (text) {
        var message = text;
        try {
          var json = JSON.parse(text);
          message = json.error || (json.errors && json.errors.join(', ')) || json.message || text;
        } catch (e) {}
        return message;
      }).catch(function () { return ''; });
    }

    function uploadCustomerPhoto(file) {
      debugLog('uploading photo to', BACKEND_URL + '/api/upload', file);
      return fetch(BACKEND_URL + '/api/upload', {
        method: 'POST',
        body: (function () {
          var formData = new FormData();
          formData.append('file', file);
          return formData;
        })()
      }).then(function (r) {
        if (!r.ok) {
          return readErrorBody(r).then(function (message) {
            debugLog('upload failed', r.status, message);
            throw new Error('Photo upload failed (' + r.status + ')' + (message ? ': ' + message : ''));
          });
        }
        return r.json();
      }).then(function (data) {
        debugLog('upload response', data);
        var url = data && data.data && data.data.url;
        if (!data || !data.success || !url) throw new Error('Backend did not return an uploaded photo URL');
        return url;
      });
    }

    function createTryOnJob(userImageUrl) {
      var payload = {
        customerId: CUSTOMER_ID,
        productId: PRODUCT_ID,
        sareeImageUrl: PRODUCT_IMAGE_URL,
        userImageUrl: userImageUrl
      };
      debugLog('creating try-on job', BACKEND_URL + '/api/try-on', payload);
      return fetch(BACKEND_URL + '/api/try-on', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function (r) {
        if (!r.ok) {
          return readErrorBody(r).then(function (message) {
            debugLog('try-on job creation failed', r.status, message);
            throw new Error('Failed to start AI try-on job (' + r.status + ')' + (message ? ': ' + message : ''));
          });
        }
        return r.json();
      }).then(function (data) {
        debugLog('try-on job created', data);
        var jobId = data && data.data && data.data.jobId;
        if (!data || !data.success || !jobId) throw new Error('Backend did not return a job id');
        return jobId;
      });
    }

    function waitForTryOnJob(jobId) {
      var startedAt = Date.now();
      function poll() {
        return fetch(BACKEND_URL + '/api/try-on/' + jobId).then(function (r) {
          if (!r.ok) {
            return readErrorBody(r).then(function (message) {
              throw new Error('Failed to check AI try-on status (' + r.status + ')' + (message ? ': ' + message : ''));
            });
          }
          return r.json();
        }).then(function (res) {
          debugLog('poll job', jobId, res);
          var job = res && res.data;
          if (!job) throw new Error((res && res.error) || 'Failed to check AI try-on status');
          if (job.status === 'completed' && job.outputImageUrl) {
            return job.outputImageUrl;
          }
          if (job.status === 'failed') {
            throw new Error(job.errorMessage || 'AI try-on generation failed');
          }
          if (Date.now() - startedAt > POLL_TIMEOUT_MS) {
            throw new Error('Timed out waiting for AI try-on result');
          }
          return new Promise(function (resolve) {
            pollTimer = setTimeout(resolve, POLL_INTERVAL_MS);
          }).then(poll);
        });
      }
      return poll();
    }

    uploadBtn.addEventListener('click', function () {
      if (!selectedFile) return;
      if (!BACKEND_URL) {
        setStatus(I18N.uploadError, 'error');
        return;
      }
      var originalObjectUrl = previewImg.src;
      showLoadingStep(originalObjectUrl);
      setStatus('', null);

      uploadCustomerPhoto(selectedFile)
        .then(function (customerImageUrl) {
          return createTryOnJob(customerImageUrl);
        })
        .then(function (jobId) { return waitForTryOnJob(jobId); })
        .then(function (outputImageUrl) {
          originalImg.src = originalObjectUrl;
          resultImg.src = outputImageUrl;
          showResultStep();
          setStatus(I18N.uploadSuccess, 'success');
        })
        .catch(function (err) {
          console.error('Try with AI error:', err);
          var message = I18N.uploadError;
          if (DEBUG && err && err.message) {
            message = I18N.uploadError + ' [debug: ' + err.message + ']';
          }
          showUploadStep();
          setStatus(message, 'error');
          uploadBtn.disabled = false;
          uploadBtn.textContent = I18N.uploadButton;
        });
    });

    window.openTryWithAiModal = openModal;

    window.tryAiDebug = {
      enable: function () { window.localStorage.setItem('tryAiDebug', '1'); location.reload(); },
      disable: function () { window.localStorage.removeItem('tryAiDebug'); location.reload(); },
      config: function () {
        return { backendUrl: BACKEND_URL, productImageUrl: PRODUCT_IMAGE_URL, productId: PRODUCT_ID };
      }
    };
  })();
{% endjavascript %}
