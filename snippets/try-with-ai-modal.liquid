{% doc %}
  Renders the "Try with AI" upload modal. Customer picks/uploads a photo of
  themselves; the photo is uploaded to Shopify Files via the Storefront API.

  Phase 1 scope only: no gallery/list of previously uploaded photos, no
  linking the file to the customer, and no AI processing yet — those land in
  a later phase once a backend is chosen. This modal only proves out the
  upload step and shows a "coming soon" confirmation.

  Requires a Storefront API access token with Files write access, configured
  via the section/theme setting `try_with_ai_storefront_token`.

  @param {product} product - The product being tried on
  @param {string} [storefront_access_token] - Storefront API access token with Files write scope

  @example
  {% render 'try-with-ai-modal', product: product, storefront_access_token: settings.try_with_ai_storefront_token %}
{% enddoc %}

<div
  class="try-ai-modal"
  id="try-ai-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="try-ai-modal-title"
  data-storefront-token="{{ storefront_access_token }}"
>
  <div class="try-ai-modal__backdrop"></div>
  <div class="try-ai-modal__panel">

    <div class="try-ai-modal__header">
      <h2 class="try-ai-modal__title" id="try-ai-modal-title">{{ 'try_with_ai.modal_title' | t }}</h2>
      <button type="button" class="try-ai-modal__close" aria-label="{{ 'try_with_ai.close' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="try-ai-modal__body">
      <p class="try-ai-modal__prompt">{{ 'try_with_ai.upload_prompt' | t }}</p>

      <label class="try-ai-modal__dropzone" for="try-ai-file-input" id="try-ai-dropzone">
        <img class="try-ai-modal__preview-img" id="try-ai-preview-img" alt="" hidden>
        <span class="try-ai-modal__dropzone-placeholder" id="try-ai-dropzone-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 16V4M12 4l-4 4M12 4l4 4"/>
            <path d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>
          </svg>
          <span>{{ 'try_with_ai.choose_photo' | t }}</span>
        </span>
      </label>
      <input type="file" accept="image/*" id="try-ai-file-input" class="try-ai-modal__file-input">

      <p class="try-ai-modal__status" id="try-ai-status" aria-live="polite"></p>
    </div>

    <div class="try-ai-modal__footer">
      <button type="button" class="try-ai-modal__upload-btn" id="try-ai-upload-btn" disabled>
        {{ 'try_with_ai.upload_button' | t }}
      </button>
    </div>

  </div>
</div>

{% stylesheet %}
  .try-ai-modal {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .try-ai-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .try-ai-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }
  .try-ai-modal__panel {
    position: relative;
    background: #faf8f4;
    border-radius: 8px;
    width: 92%;
    max-width: 480px;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(10px);
    transition: transform 0.25s ease;
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
  }
  .try-ai-modal.is-open .try-ai-modal__panel {
    transform: translateY(0);
  }

  .try-ai-modal__header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 24px 16px;
    border-bottom: 1px solid #e8e2d9;
    position: relative;
    flex-shrink: 0;
  }
  .try-ai-modal__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #2e1f1f;
    margin: 0;
    text-align: center;
  }
  .try-ai-modal__close {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .try-ai-modal__close:hover { color: #2e1f1f; }

  .try-ai-modal__body {
    overflow-y: auto;
    flex: 1;
    padding: 24px;
  }
  .try-ai-modal__prompt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    color: #42464b;
    margin: 0 0 16px;
  }

  .try-ai-modal__dropzone {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 1.5px dashed #d4cdc4;
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .try-ai-modal__dropzone:hover {
    border-color: #2e1f1f;
  }
  .try-ai-modal__dropzone-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: #888;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
  }
  .try-ai-modal__preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .try-ai-modal__file-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .try-ai-modal__status {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    margin: 12px 0 0;
    min-height: 1.2em;
    color: #666;
  }
  .try-ai-modal__status.is-error {
    color: #ce0570;
  }
  .try-ai-modal__status.is-success {
    color: #2e7d32;
  }

  .try-ai-modal__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 16px 24px;
    border-top: 1px solid #e8e2d9;
    flex-shrink: 0;
    background: #faf8f4;
  }
  .try-ai-modal__upload-btn {
    height: 44px;
    padding: 0 28px;
    background: var(--color-primary, #2e1f1f);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .try-ai-modal__upload-btn:hover {
    opacity: 0.88;
  }
  .try-ai-modal__upload-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 600px) {
    .try-ai-modal__panel {
      width: 100%;
      max-width: 100%;
      max-height: 95vh;
      border-radius: 12px 12px 0 0;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var modal = document.getElementById('try-ai-modal');
    if (!modal) return;

    var STOREFRONT_ACCESS_TOKEN = modal.dataset.storefrontToken || '';
    var API_VERSION = '2025-01';

    var dropzone           = document.getElementById('try-ai-dropzone');
    var fileInput          = document.getElementById('try-ai-file-input');
    var previewImg         = document.getElementById('try-ai-preview-img');
    var placeholder        = document.getElementById('try-ai-dropzone-placeholder');
    var statusEl           = document.getElementById('try-ai-status');
    var uploadBtn          = document.getElementById('try-ai-upload-btn');

    var selectedFile = null;

    function setStatus(text, type) {
      statusEl.textContent = text || '';
      statusEl.classList.remove('is-error', 'is-success');
      if (type) statusEl.classList.add('is-' + type);
    }

    function resetState() {
      selectedFile = null;
      fileInput.value = '';
      previewImg.src = '';
      previewImg.hidden = true;
      placeholder.hidden = false;
      uploadBtn.disabled = true;
      uploadBtn.textContent = '{{ "try_with_ai.upload_button" | t }}';
      setStatus('', null);
    }

    function openModal() {
      resetState();
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    modal.querySelectorAll('.try-ai-modal__close').forEach(function (btn) {
      btn.addEventListener('click', closeModal);
    });
    modal.querySelector('.try-ai-modal__backdrop').addEventListener('click', closeModal);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });

    fileInput.addEventListener('change', function () {
      var file = fileInput.files && fileInput.files[0];
      if (!file || file.type.indexOf('image/') !== 0) {
        selectedFile = null;
        uploadBtn.disabled = true;
        return;
      }
      selectedFile = file;
      previewImg.src = URL.createObjectURL(file);
      previewImg.hidden = false;
      placeholder.hidden = true;
      uploadBtn.disabled = false;
      setStatus('', null);
    });

    function gqlRequest(query, variables) {
      return fetch('/api/' + API_VERSION + '/graphql.json', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': STOREFRONT_ACCESS_TOKEN
        },
        body: JSON.stringify({ query: query, variables: variables })
      }).then(function (r) { return r.json(); });
    }

    function stagedUploadsCreate(file) {
      var query = 'mutation stagedUploadsCreate($input: [StagedUploadInput!]!) {' +
        ' stagedUploadsCreate(input: $input) {' +
        '   stagedTargets { url resourceUrl parameters { name value } }' +
        '   userErrors { field message }' +
        ' }' +
        '}';
      var variables = {
        input: [{
          resource: 'FILE',
          filename: file.name,
          mimeType: file.type,
          fileSize: String(file.size),
          httpMethod: 'POST'
        }]
      };
      return gqlRequest(query, variables).then(function (res) {
        var payload = res.data && res.data.stagedUploadsCreate;
        if (!payload || (payload.userErrors && payload.userErrors.length)) {
          throw new Error((payload && payload.userErrors[0] && payload.userErrors[0].message) || 'Staged upload failed');
        }
        return payload.stagedTargets[0];
      });
    }

    function putFileToStagedTarget(target, file) {
      var formData = new FormData();
      target.parameters.forEach(function (param) {
        formData.append(param.name, param.value);
      });
      formData.append('file', file);
      return fetch(target.url, { method: 'POST', body: formData }).then(function (r) {
        if (!r.ok) throw new Error('File upload to storage failed');
        return target.resourceUrl;
      });
    }

    function fileCreate(resourceUrl) {
      var query = 'mutation fileCreate($files: [FileCreateInput!]!) {' +
        ' fileCreate(files: $files) {' +
        '   files { id fileStatus }' +
        '   userErrors { field message }' +
        ' }' +
        '}';
      var variables = {
        files: [{ contentType: 'IMAGE', originalSource: resourceUrl }]
      };
      return gqlRequest(query, variables).then(function (res) {
        var payload = res.data && res.data.fileCreate;
        if (!payload || (payload.userErrors && payload.userErrors.length)) {
          throw new Error((payload && payload.userErrors[0] && payload.userErrors[0].message) || 'File create failed');
        }
        return payload.files[0];
      });
    }

    uploadBtn.addEventListener('click', function () {
      if (!selectedFile) return;
      if (!STOREFRONT_ACCESS_TOKEN) {
        setStatus('{{ "try_with_ai.upload_error" | t | escape }}', 'error');
        return;
      }
      uploadBtn.disabled = true;
      uploadBtn.textContent = '{{ "try_with_ai.uploading" | t }}';
      setStatus('', null);

      stagedUploadsCreate(selectedFile)
        .then(function (target) { return putFileToStagedTarget(target, selectedFile); })
        .then(function (resourceUrl) { return fileCreate(resourceUrl); })
        .then(function () {
          setStatus('{{ "try_with_ai.upload_success" | t | escape }}', 'success');
          uploadBtn.textContent = '{{ "try_with_ai.upload_button" | t }}';
        })
        .catch(function (err) {
          console.error('Try with AI upload error:', err);
          setStatus('{{ "try_with_ai.upload_error" | t | escape }}', 'error');
          uploadBtn.disabled = false;
          uploadBtn.textContent = '{{ "try_with_ai.upload_button" | t }}';
        });
    });

    window.openTryWithAiModal = openModal;
  })();
{% endjavascript %}
